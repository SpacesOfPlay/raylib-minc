// NOTE: A pointer to current icons array should be defined
private { u32* guiIconsPtr = guiIcons; }
//----------------------------------------------------------------------------------
// Global Variables Definition
//----------------------------------------------------------------------------------
private { GuiState guiState = STATE_NORMAL; }
// Gui global state, if !STATE_NORMAL, forces defined state
private { Font guiFont; }
// Gui current font (WARNING: highly coupled to raylib)
private { bool guiLocked = false; }
// Gui lock state (no inputs processed)
private { f32 guiAlpha = 1.0f; }
// Gui controls transparency
private { u32 guiIconScale = 1; }
// Gui icon default scale (if icons enabled)
private { bool guiTooltip = false; }
// Tooltip enabled/disabled
private { u8* guiTooltipPtr = null; }
// Tooltip string pointer (string provided by user)
private { bool guiControlExclusiveMode = false; }
// Gui control exclusive mode (no inputs processed except current control)
private { Rectangle guiControlExclusiveRec; }
// Gui control exclusive bounds rectangle, used as an unique identifier
private { i32 textBoxCursorIndex = 0; }
// Cursor index, shared by all GuiTextBox*()
//static int blinkCursorFrameCounter = 0;       // Frame counter for cursor blinking
private { i32 autoCursorCounter = 0; }
// Frame counter for automatic repeated cursor movement on key-down (cooldown and delay)
//----------------------------------------------------------------------------------
// Style data array for all gui style properties (allocated on data segment by default)
//
// NOTE 1: First set of BASE properties are generic to all controls but could be individually
// overwritten per control, first set of EXTENDED properties are generic to all controls and
// can not be overwritten individually but custom EXTENDED properties can be used by control
//
// NOTE 2: A new style set could be loaded over this array using GuiLoadStyle(),
// but default gui style could always be recovered with GuiLoadStyleDefault()
//
// guiStyle size is by default: 16*(16 + 8) = 384*4 = 1536 bytes = 1.5 KB
//----------------------------------------------------------------------------------
private { u32[384] guiStyle; }
private { bool guiStyleLoaded = false; }
// Fade color by an alpha factor
//----------------------------------------------------------------------------------
// Gui Setup Functions Definition
//----------------------------------------------------------------------------------
// Enable gui global state
// NOTE: Checking for STATE_DISABLED to avoid messing custom global state setups
void GuiEnable() {
    if guiState == STATE_DISABLED {
        guiState = STATE_NORMAL;
    }
}
// Disable gui global state
// NOTE: Checking for STATE_NORMAL to avoid messing custom global state setups
void GuiDisable() {
    if guiState == STATE_NORMAL {
        guiState = STATE_DISABLED;
    }
}
// Lock gui global state
void GuiLock() {
    guiLocked = true;
}
// Unlock gui global state
void GuiUnlock() {
    guiLocked = false;
}
// Check if gui is locked (global state)
bool GuiIsLocked() {
    return guiLocked;
}
// Set gui controls alpha global state
void GuiSetAlpha(f32 alpha) {
    if alpha < 0.0f {
        alpha = 0.0f;
    } else if alpha > 1.0f {
        alpha = 1.0f;
    }
    guiAlpha = alpha;
}
// Set gui state (global state)
void GuiSetState(i32 state) {
    guiState = cast(GuiState, state);
}
// Get gui state (global state)
i32 GuiGetState() {
    return guiState;
}
// Set custom gui font
// NOTE: Font loading/unloading is external to raygui
void GuiSetFont(Font font) {
    if font.texture.id > 0 {
        if guiStyleLoaded == 0 {
            GuiLoadStyleDefault();
        }
        guiFont = font;
    }
}
// Get custom gui font
Font GuiGetFont() {
    return guiFont;
}
// Set control style property value
void GuiSetStyle(i32 control, i32 property, i32 value) {
    if guiStyleLoaded == 0 {
        GuiLoadStyleDefault();
    }
    guiStyle[control * (16 + 8) + property] = cast(u32, value);
    if control == 0 && property < 16 {
        for i32 i = 1; i < 16; i++ {
            guiStyle[i * (16 + 8) + property] = cast(u32, value);
        }
    }
}
// Get control style property value
i32 GuiGetStyle(i32 control, i32 property) {
    if guiStyleLoaded == 0 {
        GuiLoadStyleDefault();
    }
    return cast(i32, guiStyle[control * (16 + 8) + property]);
}
//----------------------------------------------------------------------------------
// Gui Controls Functions Definition
//----------------------------------------------------------------------------------
// Window Box control
i32 GuiWindowBox(Rectangle bounds, u8* title) {
    i32 result = 0;
    i32 statusBarHeight = 24;
    i32 statusBorderWidth = GuiGetStyle(STATUSBAR, BORDER_WIDTH);
    var statusBar = Rectangle{bounds.x, bounds.y, bounds.width, cast(f32, statusBarHeight)};
    if bounds.height < cast(f32, statusBarHeight) * 2.0f {
        bounds.height = cast(f32, statusBarHeight) * 2.0f;
    }
    f32 vPadding = cast(f32, statusBarHeight) / 2.0f - 18.0f / 2.0f;
    var windowPanel = Rectangle{bounds.x, bounds.y + cast(f32, statusBarHeight) - cast(f32, statusBorderWidth), bounds.width, bounds.height - cast(f32, statusBarHeight) + cast(f32, statusBorderWidth)};
    var closeButtonRec = Rectangle{statusBar.x + statusBar.width - cast(f32, statusBorderWidth) - 18.0f - vPadding, statusBar.y + vPadding, 18.0f, 18.0f};
    GuiPanel(windowPanel, null);
    GuiStatusBar(statusBar, title);
    i32 tempBorderWidth = GuiGetStyle(BUTTON, BORDER_WIDTH);
    i32 tempTextAlignment = GuiGetStyle(BUTTON, TEXT_ALIGNMENT);
    GuiSetStyle(BUTTON, BORDER_WIDTH, 1);
    GuiSetStyle(BUTTON, TEXT_ALIGNMENT, TEXT_ALIGN_CENTER);
    when defined(RAYGUI_NO_ICONS) {
        result = GuiButton(closeButtonRec, "x");
    } else {
        result = GuiButton(closeButtonRec, GuiIconText(ICON_CROSS_SMALL, null));
    }
    GuiSetStyle(BUTTON, BORDER_WIDTH, tempBorderWidth);
    GuiSetStyle(BUTTON, TEXT_ALIGNMENT, tempTextAlignment);
    return result;
}
// Group Box control with text name
i32 GuiGroupBox(Rectangle bounds, u8* text) {
    i32 result = 0;
    GuiState state = guiState;
    GuiDrawRectangle(Rectangle{bounds.x, bounds.y, 1.0f, bounds.height}, 0, Color{}, GetColor(cast(u32, GuiGetStyle(DEFAULT, state == STATE_DISABLED ? BORDER_COLOR_DISABLED : LINE_COLOR))));
    GuiDrawRectangle(Rectangle{bounds.x, bounds.y + bounds.height - 1.0f, bounds.width, 1.0f}, 0, Color{}, GetColor(cast(u32, GuiGetStyle(DEFAULT, state == STATE_DISABLED ? BORDER_COLOR_DISABLED : LINE_COLOR))));
    GuiDrawRectangle(Rectangle{bounds.x + bounds.width - 1.0f, bounds.y, 1.0f, bounds.height}, 0, Color{}, GetColor(cast(u32, GuiGetStyle(DEFAULT, state == STATE_DISABLED ? BORDER_COLOR_DISABLED : LINE_COLOR))));
    GuiLine(Rectangle{bounds.x, bounds.y - cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE) / 2), bounds.width, cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE))}, text);
    return result;
}
// Line control
i32 GuiLine(Rectangle bounds, u8* text) {
    i32 result = 0;
    GuiState state = guiState;
    Color color = GetColor(cast(u32, GuiGetStyle(DEFAULT, state == STATE_DISABLED ? BORDER_COLOR_DISABLED : LINE_COLOR)));
    if text == null {
        GuiDrawRectangle(Rectangle{bounds.x, bounds.y + bounds.height / 2.0f, bounds.width, 1.0f}, 0, Color{}, color);
    } else {
        Rectangle textBounds;
        textBounds.width = cast(f32, GuiGetTextWidth(text)) + 2.0f;
        textBounds.height = bounds.height;
        textBounds.x = bounds.x + 12.0f;
        textBounds.y = bounds.y;
        GuiDrawRectangle(Rectangle{bounds.x, bounds.y + bounds.height / 2.0f, cast(f32, 12 - 4), 1.0f}, 0, Color{}, color);
        GuiDrawText(text, textBounds, TEXT_ALIGN_LEFT, color);
        GuiDrawRectangle(Rectangle{bounds.x + 12.0f + textBounds.width + 4.0f, bounds.y + bounds.height / 2.0f, bounds.width - textBounds.width - 12.0f - 4.0f, 1.0f}, 0, Color{}, color);
    }
    return result;
}
// Panel control
i32 GuiPanel(Rectangle bounds, u8* text) {
    i32 result = 0;
    GuiState state = guiState;
    var statusBar = Rectangle{bounds.x, bounds.y, bounds.width, cast(f32, 24)};
    if text != null && bounds.height < 24.0f * 2.0f {
        bounds.height = 24.0f * 2.0f;
    }
    if text != null {
        bounds.y += cast(f32, 24) - 1.0f;
        bounds.height -= cast(f32, 24) - 1.0f;
    }
    if text != null {
        GuiStatusBar(statusBar, text);
    }
    GuiDrawRectangle(bounds, 1, GetColor(cast(u32, GuiGetStyle(DEFAULT, state == STATE_DISABLED ? BORDER_COLOR_DISABLED : LINE_COLOR))), GetColor(cast(u32, GuiGetStyle(DEFAULT, state == STATE_DISABLED ? BASE_COLOR_DISABLED : BACKGROUND_COLOR))));
    return result;
}
// Tab Bar control
// NOTE: Using GuiToggle() for the TABS
i32 GuiTabBar(Rectangle bounds, u8** text, i32 count, i32* active) {
    i32 result = -1;
    var tabBounds = Rectangle{bounds.x, bounds.y, 148.0f, bounds.height};
    if *active < 0 {
        *active = 0;
    } else if *active > count - 1 {
        *active = count - 1;
    }
    i32 offsetX = 0;
    offsetX = *active * 148 - GetScreenWidth();
    if offsetX < 0 {
        offsetX = 0;
    }
    bool toggle = false;
    for i32 i = 0; i < count; i++ {
        tabBounds.x = bounds.x + cast(f32, (148 + 4) * i) + cast(f32, offsetX);
        if tabBounds.x < cast(f32, GetScreenWidth()) {
            i32 textAlignment = GuiGetStyle(TOGGLE, TEXT_ALIGNMENT);
            i32 textPadding = GuiGetStyle(TOGGLE, TEXT_PADDING);
            GuiSetStyle(TOGGLE, TEXT_ALIGNMENT, TEXT_ALIGN_LEFT);
            GuiSetStyle(TOGGLE, TEXT_PADDING, 8);
            if i == *active {
                toggle = true;
                GuiToggle(tabBounds, text[i], &toggle);
            } else {
                toggle = false;
                GuiToggle(tabBounds, text[i], &toggle);
                if toggle != 0 {
                    *active = i;
                }
            }
            if CheckCollisionPointRec(GetMousePosition(), tabBounds) && IsMouseButtonPressed(MOUSE_BUTTON_MIDDLE) {
                result = i;
            }
            GuiSetStyle(TOGGLE, TEXT_PADDING, textPadding);
            GuiSetStyle(TOGGLE, TEXT_ALIGNMENT, textAlignment);
            i32 tempBorderWidth = GuiGetStyle(BUTTON, BORDER_WIDTH);
            i32 tempTextAlignment = GuiGetStyle(BUTTON, TEXT_ALIGNMENT);
            GuiSetStyle(BUTTON, BORDER_WIDTH, 1);
            GuiSetStyle(BUTTON, TEXT_ALIGNMENT, TEXT_ALIGN_CENTER);
            when defined(RAYGUI_NO_ICONS) {
                if GuiButton(Rectangle{tabBounds.x + tabBounds.width - 14.0f - 5.0f, tabBounds.y + 5.0f, 14.0f, 14.0f}, "x") != 0 {
                    result = i;
                }
            } else {
                if GuiButton(Rectangle{tabBounds.x + tabBounds.width - 14.0f - 5.0f, tabBounds.y + 5.0f, 14.0f, 14.0f}, GuiIconText(ICON_CROSS_SMALL, null)) != 0 {
                    result = i;
                }
            }
            GuiSetStyle(BUTTON, BORDER_WIDTH, tempBorderWidth);
            GuiSetStyle(BUTTON, TEXT_ALIGNMENT, tempTextAlignment);
        }
    }
    GuiDrawRectangle(Rectangle{bounds.x, bounds.y + bounds.height - 1.0f, bounds.width, 1.0f}, 0, Color{}, GetColor(cast(u32, GuiGetStyle(TOGGLE, BORDER_COLOR_NORMAL))));
    return result;
}
// Scroll Panel control
i32 GuiScrollPanel(Rectangle bounds, u8* text, Rectangle content, Vector2* scroll, Rectangle* view) {
    i32 result = 0;
    GuiState state = guiState;
    Rectangle temp;
    if view == null {
        view = &temp;
    }
    var scrollPos = Vector2{0.0f, 0.0f};
    if scroll != null {
        scrollPos = *scroll;
    }
    var statusBar = Rectangle{bounds.x, bounds.y, bounds.width, cast(f32, 24)};
    if bounds.height < 24.0f * 2.0f {
        bounds.height = 24.0f * 2.0f;
    }
    if text != null {
        bounds.y += cast(f32, 24) - 1.0f;
        bounds.height -= cast(f32, 24) + 1.0f;
    }
    bool hasHorizontalScrollBar = (content.width > bounds.width - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) ? true : false) != 0;
    bool hasVerticalScrollBar = (content.height > bounds.height - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) ? true : false) != 0;
    if hasHorizontalScrollBar == 0 {
        hasHorizontalScrollBar = hasVerticalScrollBar && content.width > bounds.width - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, GuiGetStyle(LISTVIEW, SCROLLBAR_WIDTH)) ? true : false;
    }
    if hasVerticalScrollBar == 0 {
        hasVerticalScrollBar = hasHorizontalScrollBar && content.height > bounds.height - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, GuiGetStyle(LISTVIEW, SCROLLBAR_WIDTH)) ? true : false;
    }
    i32 horizontalScrollBarWidth = hasHorizontalScrollBar != 0 ? GuiGetStyle(LISTVIEW, SCROLLBAR_WIDTH) : 0;
    i32 verticalScrollBarWidth = hasVerticalScrollBar != 0 ? GuiGetStyle(LISTVIEW, SCROLLBAR_WIDTH) : 0;
    var horizontalScrollBar = Rectangle{(GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE) == 0 ? bounds.x + cast(f32, verticalScrollBarWidth) : bounds.x) + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.y + bounds.height - cast(f32, horizontalScrollBarWidth) - cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.width - cast(f32, verticalScrollBarWidth) - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)), cast(f32, horizontalScrollBarWidth)};
    var verticalScrollBar = Rectangle{GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE) == 0 ? bounds.x + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)) : bounds.x + bounds.width - cast(f32, verticalScrollBarWidth) - cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.y + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), cast(f32, verticalScrollBarWidth), bounds.height - cast(f32, horizontalScrollBarWidth) - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH))};
    if horizontalScrollBar.width < 40.0f {
        horizontalScrollBar.width = 40.0f;
    }
    if verticalScrollBar.height < 40.0f {
        verticalScrollBar.height = 40.0f;
    }
    *view = GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE) == 0 ? Rectangle{bounds.x + cast(f32, verticalScrollBarWidth) + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.y + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.width - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, verticalScrollBarWidth), bounds.height - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, horizontalScrollBarWidth)} : Rectangle{bounds.x + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.y + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)), bounds.width - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, verticalScrollBarWidth), bounds.height - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, horizontalScrollBarWidth)};
    if view.width > content.width {
        view.width = content.width;
    }
    if view.height > content.height {
        view.height = content.height;
    }
    f32 horizontalMin = hasHorizontalScrollBar != 0 ? (GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE) == 0 ? cast(f32, -verticalScrollBarWidth) : 0.0f) - cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)) : (cast(f32, GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE)) == 0.0f ? cast(f32, -verticalScrollBarWidth) : 0.0f) - cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH));
    f32 horizontalMax = hasHorizontalScrollBar != 0 ? content.width - bounds.width + cast(f32, verticalScrollBarWidth) + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)) - (cast(f32, GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE)) == 0.0f ? cast(f32, verticalScrollBarWidth) : 0.0f) : cast(f32, -GuiGetStyle(DEFAULT, BORDER_WIDTH));
    f32 verticalMin = -cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH));
    f32 verticalMax = hasVerticalScrollBar != 0 ? content.height - bounds.height + cast(f32, horizontalScrollBarWidth) + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)) : cast(f32, -GuiGetStyle(DEFAULT, BORDER_WIDTH));
    if state != STATE_DISABLED && !guiLocked {
        Vector2 mousePoint = GetMousePosition();
        if CheckCollisionPointRec(mousePoint, bounds) != 0 {
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else {
                state = STATE_FOCUSED;
            }
            f32 scrollDelta = GetMouseWheelMove() + (GetGamepadAxisMovement(0, GAMEPAD_AXIS_RIGHT_TRIGGER) + 1.0f) - (GetGamepadAxisMovement(0, GAMEPAD_AXIS_LEFT_TRIGGER) + 1.0f);
            var scrollSpeed = Vector2{content.width / bounds.width, content.height / bounds.height};
            if scrollSpeed.x < 20.0f {
                scrollSpeed.x = 20.0f;
            }
            if scrollSpeed.y < 20.0f {
                scrollSpeed.y = 20.0f;
            }
            if hasHorizontalScrollBar && (IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_LEFT_SHIFT)) {
                scrollPos.x += scrollDelta * scrollSpeed.x;
            } else {
                scrollPos.y += scrollDelta * scrollSpeed.y;
            }
        }
    }
    if scrollPos.x > -horizontalMin {
        scrollPos.x = -horizontalMin;
    }
    if scrollPos.x < -horizontalMax {
        scrollPos.x = -horizontalMax;
    }
    if scrollPos.y > -verticalMin {
        scrollPos.y = -verticalMin;
    }
    if scrollPos.y < -verticalMax {
        scrollPos.y = -verticalMax;
    }
    if text != null {
        GuiStatusBar(statusBar, text);
    }
    GuiDrawRectangle(bounds, 0, Color{}, GetColor(cast(u32, GuiGetStyle(DEFAULT, BACKGROUND_COLOR))));
    i32 slider = GuiGetStyle(SCROLLBAR, SCROLL_SLIDER_SIZE);
    if hasHorizontalScrollBar != 0 {
        GuiSetStyle(SCROLLBAR, SCROLL_SLIDER_SIZE, cast(i32, (bounds.width - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, verticalScrollBarWidth)) / cast(f32, cast(i32, content.width)) * cast(f32, cast(i32, bounds.width) - 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH) - verticalScrollBarWidth)));
        scrollPos.x = cast(f32, -GuiScrollBar(horizontalScrollBar, cast(i32, -scrollPos.x), cast(i32, horizontalMin), cast(i32, horizontalMax)));
    } else {
        scrollPos.x = 0.0f;
    }
    if hasVerticalScrollBar != 0 {
        GuiSetStyle(SCROLLBAR, SCROLL_SLIDER_SIZE, cast(i32, (bounds.height - cast(f32, 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH)) - cast(f32, horizontalScrollBarWidth)) / cast(f32, cast(i32, content.height)) * cast(f32, cast(i32, bounds.height) - 2 * GuiGetStyle(DEFAULT, BORDER_WIDTH) - horizontalScrollBarWidth)));
        scrollPos.y = cast(f32, -GuiScrollBar(verticalScrollBar, cast(i32, -scrollPos.y), cast(i32, verticalMin), cast(i32, verticalMax)));
    } else {
        scrollPos.y = 0.0f;
    }
    if hasHorizontalScrollBar && hasVerticalScrollBar {
        var corner = Rectangle{GuiGetStyle(LISTVIEW, SCROLLBAR_SIDE) == 0 ? bounds.x + cast(f32, GuiGetStyle(DEFAULT, BORDER_WIDTH)) + 2.0f : horizontalScrollBar.x + horizontalScrollBar.width + 2.0f, verticalScrollBar.y + verticalScrollBar.height + 2.0f, cast(f32, horizontalScrollBarWidth) - 4.0f, cast(f32, verticalScrollBarWidth) - 4.0f};
        GuiDrawRectangle(corner, 0, Color{}, GetColor(cast(u32, GuiGetStyle(LISTVIEW, TEXT + state * 3))));
    }
    GuiDrawRectangle(bounds, GuiGetStyle(LISTVIEW, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(LISTVIEW, BORDER + state * 3))), Color{});
    GuiSetStyle(SCROLLBAR, SCROLL_SLIDER_SIZE, slider);
    if scroll != null {
        *scroll = scrollPos;
    }
    return result;
}
// Label control
i32 GuiLabel(Rectangle bounds, u8* text) {
    i32 result = 0;
    GuiState state = guiState;
    GuiDrawText(text, GetTextBounds(LABEL, bounds), GuiGetStyle(LABEL, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(LABEL, TEXT + state * 3))));
    return result;
}
// Button control, returns true when clicked
i32 GuiButton(Rectangle bounds, u8* text) {
    i32 result = 0;
    GuiState state = guiState;
    if state != STATE_DISABLED && !guiLocked && !guiControlExclusiveMode {
        Vector2 mousePoint = GetMousePosition();
        if CheckCollisionPointRec(mousePoint, bounds) != 0 {
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else {
                state = STATE_FOCUSED;
            }
            if IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                result = 1;
            }
        }
    }
    GuiDrawRectangle(bounds, GuiGetStyle(BUTTON, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(BUTTON, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(BUTTON, BASE + state * 3))));
    GuiDrawText(text, GetTextBounds(BUTTON, bounds), GuiGetStyle(BUTTON, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(BUTTON, TEXT + state * 3))));
    if state == STATE_FOCUSED {
        GuiTooltip(bounds);
    }
    return result;
}
// Label button control
i32 GuiLabelButton(Rectangle bounds, u8* text) {
    GuiState state = guiState;
    bool pressed = false;
    var textWidth = cast(f32, GuiGetTextWidth(text));
    if bounds.width - cast(f32, 2 * GuiGetStyle(LABEL, BORDER_WIDTH)) - cast(f32, 2 * GuiGetStyle(LABEL, TEXT_PADDING)) < textWidth {
        bounds.width = textWidth + cast(f32, 2 * GuiGetStyle(LABEL, BORDER_WIDTH)) + cast(f32, 2 * GuiGetStyle(LABEL, TEXT_PADDING)) + 2.0f;
    }
    if state != STATE_DISABLED && !guiLocked && !guiControlExclusiveMode {
        Vector2 mousePoint = GetMousePosition();
        if CheckCollisionPointRec(mousePoint, bounds) != 0 {
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else {
                state = STATE_FOCUSED;
            }
            if IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                pressed = true;
            }
        }
    }
    GuiDrawText(text, GetTextBounds(LABEL, bounds), GuiGetStyle(LABEL, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(LABEL, TEXT + state * 3))));
    return pressed;
}
// Toggle Button control
i32 GuiToggle(Rectangle bounds, u8* text, bool* active) {
    i32 result = 0;
    GuiState state = guiState;
    bool temp = false;
    if active == null {
        active = &temp;
    }
    if state != STATE_DISABLED && !guiLocked && !guiControlExclusiveMode {
        Vector2 mousePoint = GetMousePosition();
        if CheckCollisionPointRec(mousePoint, bounds) != 0 {
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else if IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_NORMAL;
                *active = !*active;
            } else {
                state = STATE_FOCUSED;
            }
        }
    }
    if state == STATE_NORMAL {
        GuiDrawRectangle(bounds, GuiGetStyle(TOGGLE, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(TOGGLE, *active != 0 ? BORDER_COLOR_PRESSED : BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(TOGGLE, *active != 0 ? BASE_COLOR_PRESSED : BASE + state * 3))));
        GuiDrawText(text, GetTextBounds(TOGGLE, bounds), GuiGetStyle(TOGGLE, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(TOGGLE, *active != 0 ? TEXT_COLOR_PRESSED : TEXT + state * 3))));
    } else {
        GuiDrawRectangle(bounds, GuiGetStyle(TOGGLE, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(TOGGLE, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(TOGGLE, BASE + state * 3))));
        GuiDrawText(text, GetTextBounds(TOGGLE, bounds), GuiGetStyle(TOGGLE, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(TOGGLE, TEXT + state * 3))));
    }
    if state == STATE_FOCUSED {
        GuiTooltip(bounds);
    }
    return result;
}
// Toggle Group control
i32 GuiToggleGroup(Rectangle bounds, u8* text, i32* active) {
    i32 result = 0;
    f32 initBoundsX = bounds.x;
    i32 temp = 0;
    if active == null {
        active = &temp;
    }
    bool toggle = false;
    i32[32] rows;
    i32 itemCount = 0;
    u8** items = GuiTextSplit(text, 59, &itemCount, rows);
    i32 prevRow = rows[0];
    for i32 i = 0; i < itemCount; i++ {
        if prevRow != rows[i] {
            bounds.x = initBoundsX;
            bounds.y += bounds.height + cast(f32, GuiGetStyle(TOGGLE, GROUP_PADDING));
            prevRow = rows[i];
        }
        if i == *active {
            toggle = true;
            GuiToggle(bounds, items[i], &toggle);
        } else {
            toggle = false;
            GuiToggle(bounds, items[i], &toggle);
            if toggle != 0 {
                *active = i;
            }
        }
        bounds.x += bounds.width + cast(f32, GuiGetStyle(TOGGLE, GROUP_PADDING));
    }
    return result;
}
// Toggle Slider control extended
i32 GuiToggleSlider(Rectangle bounds, u8* text, i32* active) {
    i32 result = 0;
    GuiState state = guiState;
    i32 temp = 0;
    if active == null {
        active = &temp;
    }
    i32 itemCount = 0;
    u8** items = null;
    if text != null {
        items = GuiTextSplit(text, 59, &itemCount, null);
    }
    var slider = Rectangle{0.0f, bounds.y + cast(f32, GuiGetStyle(SLIDER, BORDER_WIDTH)) + cast(f32, GuiGetStyle(SLIDER, SLIDER_PADDING)), (bounds.width - cast(f32, 2 * GuiGetStyle(SLIDER, BORDER_WIDTH)) - cast(f32, (itemCount + 1) * GuiGetStyle(SLIDER, SLIDER_PADDING))) / cast(f32, itemCount), bounds.height - cast(f32, 2 * GuiGetStyle(SLIDER, BORDER_WIDTH)) - cast(f32, 2 * GuiGetStyle(SLIDER, SLIDER_PADDING))};
    if state != STATE_DISABLED && !guiLocked {
        Vector2 mousePoint = GetMousePosition();
        if CheckCollisionPointRec(mousePoint, bounds) != 0 {
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else if IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
                (*active)++;
                result = 1;
            } else {
                state = STATE_FOCUSED;
            }
        }
        if *active && state != STATE_FOCUSED {
            state = STATE_PRESSED;
        }
    }
    if *active >= itemCount {
        *active = 0;
    }
    slider.x = bounds.x + cast(f32, GuiGetStyle(SLIDER, BORDER_WIDTH)) + cast(f32, (*active + 1) * GuiGetStyle(SLIDER, SLIDER_PADDING)) + cast(f32, *active) * slider.width;
    GuiDrawRectangle(bounds, GuiGetStyle(SLIDER, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(TOGGLE, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(TOGGLE, BASE_COLOR_NORMAL))));
    if state == STATE_NORMAL {
        GuiDrawRectangle(slider, 0, Color{}, GetColor(cast(u32, GuiGetStyle(SLIDER, BASE_COLOR_PRESSED))));
    } else if state == STATE_FOCUSED {
        GuiDrawRectangle(slider, 0, Color{}, GetColor(cast(u32, GuiGetStyle(SLIDER, BASE_COLOR_FOCUSED))));
    } else if state == STATE_PRESSED {
        GuiDrawRectangle(slider, 0, Color{}, GetColor(cast(u32, GuiGetStyle(SLIDER, BASE_COLOR_PRESSED))));
    }
    if text != null {
        Rectangle textBounds;
        textBounds.width = cast(f32, GuiGetTextWidth(text));
        textBounds.height = cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE));
        textBounds.x = slider.x + slider.width / 2.0f - textBounds.width / 2.0f;
        textBounds.y = bounds.y + bounds.height / 2.0f - cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE) / 2);
        GuiDrawText(items[*active], textBounds, GuiGetStyle(TOGGLE, TEXT_ALIGNMENT), Fade(GetColor(cast(u32, GuiGetStyle(TOGGLE, TEXT + state * 3))), guiAlpha));
    }
    return result;
}
// Check Box control, returns 1 when state changed
i32 GuiCheckBox(Rectangle bounds, u8* text, bool* checked) {
    i32 result = 0;
    GuiState state = guiState;
    bool temp = false;
    if checked == null {
        checked = &temp;
    }
    Rectangle textBounds;
    if text != null {
        textBounds.width = cast(f32, GuiGetTextWidth(text)) + 2.0f;
        textBounds.height = cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE));
        textBounds.x = bounds.x + bounds.width + cast(f32, GuiGetStyle(CHECKBOX, TEXT_PADDING));
        textBounds.y = bounds.y + bounds.height / 2.0f - cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE) / 2);
        if GuiGetStyle(CHECKBOX, TEXT_ALIGNMENT) == TEXT_ALIGN_LEFT {
            textBounds.x = bounds.x - textBounds.width - cast(f32, GuiGetStyle(CHECKBOX, TEXT_PADDING));
        }
    }
    if state != STATE_DISABLED && !guiLocked && !guiControlExclusiveMode {
        Vector2 mousePoint = GetMousePosition();
        var totalBounds = Rectangle{GuiGetStyle(CHECKBOX, TEXT_ALIGNMENT) == TEXT_ALIGN_LEFT ? textBounds.x : bounds.x, bounds.y, bounds.width + textBounds.width + cast(f32, GuiGetStyle(CHECKBOX, TEXT_PADDING)), bounds.height};
        if CheckCollisionPointRec(mousePoint, totalBounds) != 0 {
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else {
                state = STATE_FOCUSED;
            }
            if IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                *checked = !*checked;
                result = 1;
            }
        }
    }
    GuiDrawRectangle(bounds, GuiGetStyle(CHECKBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(CHECKBOX, BORDER + state * 3))), Color{});
    if *checked != 0 {
        var check = Rectangle{bounds.x + cast(f32, GuiGetStyle(CHECKBOX, BORDER_WIDTH)) + cast(f32, GuiGetStyle(CHECKBOX, CHECK_PADDING)), bounds.y + cast(f32, GuiGetStyle(CHECKBOX, BORDER_WIDTH)) + cast(f32, GuiGetStyle(CHECKBOX, CHECK_PADDING)), bounds.width - cast(f32, 2 * (GuiGetStyle(CHECKBOX, BORDER_WIDTH) + GuiGetStyle(CHECKBOX, CHECK_PADDING))), bounds.height - cast(f32, 2 * (GuiGetStyle(CHECKBOX, BORDER_WIDTH) + GuiGetStyle(CHECKBOX, CHECK_PADDING)))};
        GuiDrawRectangle(check, 0, Color{}, GetColor(cast(u32, GuiGetStyle(CHECKBOX, TEXT + state * 3))));
    }
    GuiDrawText(text, textBounds, GuiGetStyle(CHECKBOX, TEXT_ALIGNMENT) == TEXT_ALIGN_RIGHT ? TEXT_ALIGN_LEFT : TEXT_ALIGN_RIGHT, GetColor(cast(u32, GuiGetStyle(LABEL, TEXT + state * 3))));
    return result;
}
// Combo Box control
i32 GuiComboBox(Rectangle bounds, u8* text, i32* active) {
    i32 result = 0;
    GuiState state = guiState;
    i32 temp = 0;
    if active == null {
        active = &temp;
    }
    bounds.width -= cast(f32, GuiGetStyle(COMBOBOX, COMBO_BUTTON_WIDTH) + GuiGetStyle(COMBOBOX, COMBO_BUTTON_SPACING));
    var selector = Rectangle{bounds.x + bounds.width + cast(f32, GuiGetStyle(COMBOBOX, COMBO_BUTTON_SPACING)), bounds.y, cast(f32, GuiGetStyle(COMBOBOX, COMBO_BUTTON_WIDTH)), bounds.height};
    i32 itemCount = 0;
    u8** items = GuiTextSplit(text, 59, &itemCount, null);
    if *active < 0 {
        *active = 0;
    } else if *active > itemCount - 1 {
        *active = itemCount - 1;
    }
    if state != STATE_DISABLED && !guiLocked && itemCount > 1 && !guiControlExclusiveMode {
        Vector2 mousePoint = GetMousePosition();
        if CheckCollisionPointRec(mousePoint, bounds) || CheckCollisionPointRec(mousePoint, selector) {
            if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                *active += 1;
                if *active >= itemCount {
                    *active = 0;
                }
            }
            if IsMouseButtonDown(MOUSE_BUTTON_LEFT) || IsGamepadButtonDown(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                state = STATE_PRESSED;
            } else {
                state = STATE_FOCUSED;
            }
        }
    }
    GuiDrawRectangle(bounds, GuiGetStyle(COMBOBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(COMBOBOX, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(COMBOBOX, BASE + state * 3))));
    GuiDrawText(items[*active], GetTextBounds(COMBOBOX, bounds), GuiGetStyle(COMBOBOX, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(COMBOBOX, TEXT + state * 3))));
    i32 tempBorderWidth = GuiGetStyle(BUTTON, BORDER_WIDTH);
    i32 tempTextAlign = GuiGetStyle(BUTTON, TEXT_ALIGNMENT);
    GuiSetStyle(BUTTON, BORDER_WIDTH, 1);
    GuiSetStyle(BUTTON, TEXT_ALIGNMENT, TEXT_ALIGN_CENTER);
    GuiButton(selector, TextFormat("%i/%i", *active + 1, itemCount));
    GuiSetStyle(BUTTON, TEXT_ALIGNMENT, tempTextAlign);
    GuiSetStyle(BUTTON, BORDER_WIDTH, tempBorderWidth);
    return result;
}
// Dropdown Box control
// NOTE: Returns mouse click
i32 GuiDropdownBox(Rectangle bounds, u8* text, i32* active, bool editMode) {
    i32 result = 0;
    GuiState state = guiState;
    i32 temp = 0;
    if active == null {
        active = &temp;
    }
    i32 itemSelected = *active;
    i32 itemFocused = -1;
    i32 direction = 0;
    if GuiGetStyle(DROPDOWNBOX, DROPDOWN_ROLL_UP) == 1 {
        direction = 1;
    }
    i32 itemCount = 0;
    u8** items = GuiTextSplit(text, 59, &itemCount, null);
    Rectangle boundsOpen = bounds;
    boundsOpen.height = cast(f32, itemCount + 1) * (bounds.height + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING)));
    if direction == 1 {
        boundsOpen.y -= cast(f32, itemCount) * (bounds.height + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING))) + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING));
    }
    Rectangle itemBounds = bounds;
    if state != STATE_DISABLED && (editMode || !guiLocked) && itemCount > 1 && !guiControlExclusiveMode {
        Vector2 mousePoint = GetMousePosition();
        if editMode != 0 {
            state = STATE_PRESSED;
            if CheckCollisionPointRec(mousePoint, boundsOpen) == 0 {
                if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) || (IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN)) {
                    result = 1;
                }
            }
            if CheckCollisionPointRec(mousePoint, bounds) && (IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN)) {
                result = 1;
            }
            for i32 i = 0; i < itemCount; i++ {
                if direction == 0 {
                    itemBounds.y += bounds.height + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING));
                } else {
                    itemBounds.y -= bounds.height + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING));
                }
                if CheckCollisionPointRec(mousePoint, itemBounds) != 0 {
                    itemFocused = i;
                    if IsMouseButtonReleased(MOUSE_BUTTON_LEFT) || IsGamepadButtonReleased(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                        itemSelected = i;
                        result = 1;
                    }
                    break;
                }
            }
            itemBounds = bounds;
        } else {
            if CheckCollisionPointRec(mousePoint, bounds) != 0 {
                if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                    result = 1;
                    state = STATE_PRESSED;
                } else {
                    state = STATE_FOCUSED;
                }
            }
        }
    }
    if editMode != 0 {
        GuiPanel(boundsOpen, null);
    }
    GuiDrawRectangle(bounds, GuiGetStyle(DROPDOWNBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, BASE + state * 3))));
    GuiDrawText(items[itemSelected], GetTextBounds(DROPDOWNBOX, bounds), GuiGetStyle(DROPDOWNBOX, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, TEXT + state * 3))));
    if editMode != 0 {
        for i32 i = 0; i < itemCount; i++ {
            if direction == 0 {
                itemBounds.y += bounds.height + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING));
            } else {
                itemBounds.y -= bounds.height + cast(f32, GuiGetStyle(DROPDOWNBOX, DROPDOWN_ITEMS_SPACING));
            }
            if i == itemSelected {
                GuiDrawRectangle(itemBounds, GuiGetStyle(DROPDOWNBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, BORDER_COLOR_PRESSED))), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, BASE_COLOR_PRESSED))));
                GuiDrawText(items[i], GetTextBounds(DROPDOWNBOX, itemBounds), GuiGetStyle(DROPDOWNBOX, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, TEXT_COLOR_PRESSED))));
            } else if i == itemFocused {
                GuiDrawRectangle(itemBounds, GuiGetStyle(DROPDOWNBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, BORDER_COLOR_FOCUSED))), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, BASE_COLOR_FOCUSED))));
                GuiDrawText(items[i], GetTextBounds(DROPDOWNBOX, itemBounds), GuiGetStyle(DROPDOWNBOX, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, TEXT_COLOR_FOCUSED))));
            } else {
                GuiDrawText(items[i], GetTextBounds(DROPDOWNBOX, itemBounds), GuiGetStyle(DROPDOWNBOX, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, TEXT_COLOR_NORMAL))));
            }
        }
    }
    if GuiGetStyle(DROPDOWNBOX, DROPDOWN_ARROW_HIDDEN) == 0 {
        GuiDrawText(direction != 0 ? GuiIconText(ICON_ARROW_UP_FILL, null) : GuiIconText(ICON_ARROW_DOWN_FILL, null), Rectangle{bounds.x + bounds.width - cast(f32, GuiGetStyle(DROPDOWNBOX, ARROW_PADDING)), bounds.y + bounds.height / 2.0f - 6.0f, 10.0f, 10.0f}, TEXT_ALIGN_CENTER, GetColor(cast(u32, GuiGetStyle(DROPDOWNBOX, TEXT + state * 3))));
    }
    *active = itemSelected;
    return result;
}
// Text Box control
// NOTE: Returns true on ENTER pressed (useful for data validation)
i32 GuiTextBox(Rectangle bounds, u8* text, i32 textSize, bool editMode) {
    i32 result = 0;
    GuiState state = guiState;
    bool multiline = false;
    i32 wrapMode = GuiGetStyle(DEFAULT, TEXT_WRAP_MODE);
    Rectangle textBounds = GetTextBounds(TEXTBOX, bounds);
    i32 textLength = text != null ? cast(i32, strlen(text)) : 0;
    i32 thisCursorIndex = textBoxCursorIndex;
    if thisCursorIndex > textLength {
        thisCursorIndex = textLength;
    }
    i32 textWidth = GuiGetTextWidth(text) - GuiGetTextWidth(text + thisCursorIndex);
    i32 textIndexOffset = 0;
    var cursor = Rectangle{textBounds.x + cast(f32, textWidth) + cast(f32, GuiGetStyle(DEFAULT, TEXT_SPACING)), textBounds.y + textBounds.height / 2.0f - cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE)), 2.0f, cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE)) * 2.0f};
    if cursor.height >= bounds.height {
        cursor.height = bounds.height - cast(f32, GuiGetStyle(TEXTBOX, BORDER_WIDTH) * 2);
    }
    if cursor.y < bounds.y + cast(f32, GuiGetStyle(TEXTBOX, BORDER_WIDTH)) {
        cursor.y = bounds.y + cast(f32, GuiGetStyle(TEXTBOX, BORDER_WIDTH));
    }
    Rectangle mouseCursor = cursor;
    mouseCursor.x = cast(f32, -1);
    mouseCursor.width = 1.0f;
    if state != STATE_DISABLED && !GuiGetStyle(TEXTBOX, TEXT_READONLY) && !guiLocked && !guiControlExclusiveMode && wrapMode == TEXT_WRAP_NONE {
        Vector2 mousePosition = GetMousePosition();
        if editMode != 0 {
            if IsKeyDown(KEY_LEFT) || IsKeyDown(KEY_RIGHT) || IsKeyDown(KEY_UP) || IsKeyDown(KEY_DOWN) || IsKeyDown(KEY_BACKSPACE) || IsKeyDown(KEY_DELETE) {
                autoCursorCounter++;
            } else {
                autoCursorCounter = 0;
            }
            bool autoCursorShouldTrigger = autoCursorCounter > 20 && autoCursorCounter % 1 == 0;
            state = STATE_PRESSED;
            if textBoxCursorIndex > textLength {
                textBoxCursorIndex = textLength;
            }
            while cast(f32, textWidth) >= textBounds.width {
                i32 nextCodepointSize = 0;
                GetCodepointNext(text + textIndexOffset, &nextCodepointSize);
                textIndexOffset += nextCodepointSize;
                textWidth = GuiGetTextWidth(text + textIndexOffset) - GuiGetTextWidth(text + textBoxCursorIndex);
            }
            i32 codepoint = GetCharPressed();
            if multiline && IsKeyPressed(KEY_ENTER) {
                codepoint = 10;
            }
            i32 codepointSize = 0;
            u8* charEncoded = CodepointToUTF8(codepoint, &codepointSize);
            if IsKeyPressed(KEY_V) && (IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL)) {
                u8* pasteText = GetClipboardText();
                if pasteText != null {
                    i32 pasteLength = 0;
                    i32 pasteCodepoint;
                    i32 pasteCodepointSize;
                    while true {
                        pasteCodepoint = GetCodepointNext(pasteText + pasteLength, &pasteCodepointSize);
                        if textLength + pasteLength + pasteCodepointSize >= textSize {
                            break;
                        }
                        if !(multiline && pasteCodepoint == 10) && !(pasteCodepoint >= 32) {
                            break;
                        }
                        pasteLength += pasteCodepointSize;
                    }
                    if pasteLength > 0 {
                        for i32 i = textLength + pasteLength; i > textBoxCursorIndex; i-- {
                            text[i] = text[i - pasteLength];
                        }
                        for i32 i = 0; i < pasteLength; i++ {
                            text[textBoxCursorIndex + i] = pasteText[i];
                        }
                        textBoxCursorIndex += pasteLength;
                        textLength += pasteLength;
                        text[textLength] = 0;
                    }
                }
            } else if (multiline && codepoint == 10 || codepoint >= 32) && textLength + codepointSize < textSize {
                for i32 i = textLength + codepointSize; i > textBoxCursorIndex; i-- {
                    text[i] = text[i - codepointSize];
                }
                for i32 i = 0; i < codepointSize; i++ {
                    text[textBoxCursorIndex + i] = charEncoded[i];
                }
                textBoxCursorIndex += codepointSize;
                textLength += codepointSize;
                text[textLength] = 0;
            }
            if textLength > 0 && IsKeyPressed(KEY_HOME) {
                textBoxCursorIndex = 0;
            }
            if textLength > textBoxCursorIndex && IsKeyPressed(KEY_END) {
                textBoxCursorIndex = textLength;
            }
            if textLength > textBoxCursorIndex && IsKeyPressed(KEY_DELETE) && (IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL)) {
                i32 offset = textBoxCursorIndex;
                i32 accCodepointSize = 0;
                i32 nextCodepointSize;
                i32 nextCodepoint;
                nextCodepoint = GetCodepointNext(text + offset, &nextCodepointSize);
                bool puctuation = ispunct(nextCodepoint & 255) != 0;
                while offset < textLength {
                    if puctuation && !ispunct(nextCodepoint & 255) || !puctuation && (isspace(nextCodepoint & 255) || ispunct(nextCodepoint & 255)) {
                        break;
                    }
                    offset += nextCodepointSize;
                    accCodepointSize += nextCodepointSize;
                    nextCodepoint = GetCodepointNext(text + offset, &nextCodepointSize);
                }
                while offset < textLength {
                    if isspace(nextCodepoint & 255) == 0 {
                        break;
                    }
                    offset += nextCodepointSize;
                    accCodepointSize += nextCodepointSize;
                    nextCodepoint = GetCodepointNext(text + offset, &nextCodepointSize);
                }
                for i32 i = offset; i <= textLength; i++ {
                    text[i - accCodepointSize] = text[i];
                }
                textLength -= accCodepointSize;
            } else if textLength > textBoxCursorIndex && (IsKeyPressed(KEY_DELETE) || IsKeyDown(KEY_DELETE) && autoCursorShouldTrigger) {
                i32 nextCodepointSize = 0;
                GetCodepointNext(text + textBoxCursorIndex, &nextCodepointSize);
                for i32 i = textBoxCursorIndex + nextCodepointSize; i <= textLength; i++ {
                    text[i - nextCodepointSize] = text[i];
                }
                textLength -= nextCodepointSize;
            }
            if textBoxCursorIndex > 0 && IsKeyPressed(KEY_BACKSPACE) && (IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL)) {
                i32 offset = textBoxCursorIndex;
                i32 accCodepointSize = 0;
                i32 prevCodepointSize = 0;
                i32 prevCodepoint = 0;
                while offset > 0 {
                    prevCodepoint = GetCodepointPrevious(text + offset, &prevCodepointSize);
                    if isspace(prevCodepoint & 255) == 0 {
                        break;
                    }
                    offset -= prevCodepointSize;
                    accCodepointSize += prevCodepointSize;
                }
                bool puctuation = ispunct(prevCodepoint & 255) != 0;
                while offset > 0 {
                    prevCodepoint = GetCodepointPrevious(text + offset, &prevCodepointSize);
                    if puctuation && !ispunct(prevCodepoint & 255) || !puctuation && (isspace(prevCodepoint & 255) || ispunct(prevCodepoint & 255)) {
                        break;
                    }
                    offset -= prevCodepointSize;
                    accCodepointSize += prevCodepointSize;
                }
                for i32 i = textBoxCursorIndex; i <= textLength; i++ {
                    text[i - accCodepointSize] = text[i];
                }
                textLength -= accCodepointSize;
                textBoxCursorIndex -= accCodepointSize;
            } else if textBoxCursorIndex > 0 && (IsKeyPressed(KEY_BACKSPACE) || IsKeyDown(KEY_BACKSPACE) && autoCursorShouldTrigger) {
                i32 prevCodepointSize = 0;
                GetCodepointPrevious(text + textBoxCursorIndex, &prevCodepointSize);
                for i32 i = textBoxCursorIndex; i <= textLength; i++ {
                    text[i - prevCodepointSize] = text[i];
                }
                textLength -= prevCodepointSize;
                textBoxCursorIndex -= prevCodepointSize;
            }
            if textBoxCursorIndex > 0 && IsKeyPressed(KEY_LEFT) && (IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL)) {
                i32 offset = textBoxCursorIndex;
                i32 prevCodepointSize = 0;
                i32 prevCodepoint = 0;
                while offset > 0 {
                    prevCodepoint = GetCodepointPrevious(text + offset, &prevCodepointSize);
                    if isspace(prevCodepoint & 255) == 0 {
                        break;
                    }
                    offset -= prevCodepointSize;
                }
                bool puctuation = ispunct(prevCodepoint & 255) != 0;
                while offset > 0 {
                    prevCodepoint = GetCodepointPrevious(text + offset, &prevCodepointSize);
                    if puctuation && !ispunct(prevCodepoint & 255) || !puctuation && (isspace(prevCodepoint & 255) || ispunct(prevCodepoint & 255)) {
                        break;
                    }
                    offset -= prevCodepointSize;
                }
                textBoxCursorIndex = offset;
            } else if textBoxCursorIndex > 0 && (IsKeyPressed(KEY_LEFT) || IsKeyDown(KEY_LEFT) && autoCursorShouldTrigger) {
                i32 prevCodepointSize = 0;
                GetCodepointPrevious(text + textBoxCursorIndex, &prevCodepointSize);
                textBoxCursorIndex -= prevCodepointSize;
            } else if textLength > textBoxCursorIndex && IsKeyPressed(KEY_RIGHT) && (IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL)) {
                i32 offset = textBoxCursorIndex;
                i32 nextCodepointSize;
                i32 nextCodepoint;
                nextCodepoint = GetCodepointNext(text + offset, &nextCodepointSize);
                bool puctuation = ispunct(nextCodepoint & 255) != 0;
                while offset < textLength {
                    if puctuation && !ispunct(nextCodepoint & 255) || !puctuation && (isspace(nextCodepoint & 255) || ispunct(nextCodepoint & 255)) {
                        break;
                    }
                    offset += nextCodepointSize;
                    nextCodepoint = GetCodepointNext(text + offset, &nextCodepointSize);
                }
                while offset < textLength {
                    if isspace(nextCodepoint & 255) == 0 {
                        break;
                    }
                    offset += nextCodepointSize;
                    nextCodepoint = GetCodepointNext(text + offset, &nextCodepointSize);
                }
                textBoxCursorIndex = offset;
            } else if textLength > textBoxCursorIndex && (IsKeyPressed(KEY_RIGHT) || IsKeyDown(KEY_RIGHT) && autoCursorShouldTrigger) {
                i32 nextCodepointSize = 0;
                GetCodepointNext(text + textBoxCursorIndex, &nextCodepointSize);
                textBoxCursorIndex += nextCodepointSize;
            }
            if CheckCollisionPointRec(mousePosition, textBounds) != 0 {
                f32 scaleFactor = cast(f32, GuiGetStyle(DEFAULT, TEXT_SIZE)) / cast(f32, guiFont.baseSize);
                i32 codepointIndex = 0;
                f32 glyphWidth = 0.0f;
                f32 widthToMouseX = 0.0f;
                i32 mouseCursorIndex = 0;
                for i32 i = textIndexOffset; i < textLength; i += codepointSize {
                    codepoint = GetCodepointNext(&text[i], &codepointSize);
                    codepointIndex = GetGlyphIndex(guiFont, codepoint);
                    if guiFont.glyphs[codepointIndex].advanceX == 0 {
                        glyphWidth = guiFont.recs[codepointIndex].width * scaleFactor;
                    } else {
                        glyphWidth = cast(f32, guiFont.glyphs[codepointIndex].advanceX) * scaleFactor;
                    }
                    if mousePosition.x <= textBounds.x + (widthToMouseX + glyphWidth / 2.0f) {
                        mouseCursor.x = textBounds.x + widthToMouseX;
                        mouseCursorIndex = i;
                        break;
                    }
                    widthToMouseX += glyphWidth + cast(f32, GuiGetStyle(DEFAULT, TEXT_SPACING));
                }
                i32 textEndWidth = GuiGetTextWidth(text + textIndexOffset);
                if GetMousePosition().x >= textBounds.x + cast(f32, textEndWidth) - glyphWidth / 2.0f {
                    mouseCursor.x = textBounds.x + cast(f32, textEndWidth);
                    mouseCursorIndex = textLength;
                }
                if mouseCursor.x >= 0.0f && (IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN)) {
                    cursor.x = mouseCursor.x;
                    textBoxCursorIndex = mouseCursorIndex;
                }
            } else {
                mouseCursor.x = cast(f32, -1);
            }
            cursor.x = bounds.x + cast(f32, GuiGetStyle(TEXTBOX, TEXT_PADDING)) + cast(f32, GuiGetTextWidth(text + textIndexOffset)) - cast(f32, GuiGetTextWidth(text + textBoxCursorIndex)) + cast(f32, GuiGetStyle(DEFAULT, TEXT_SPACING));
            if !multiline && IsKeyPressed(KEY_ENTER) || !CheckCollisionPointRec(mousePosition, bounds) && (IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN)) {
                textBoxCursorIndex = 0;
                autoCursorCounter = 0;
                result = 1;
            }
        } else {
            if CheckCollisionPointRec(mousePosition, bounds) != 0 {
                state = STATE_FOCUSED;
                if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) || IsGamepadButtonPressed(0, GAMEPAD_BUTTON_RIGHT_FACE_DOWN) {
                    textBoxCursorIndex = textLength;
                    autoCursorCounter = 0;
                    result = 1;
                }
            }
        }
    }
    if state == STATE_PRESSED {
        GuiDrawRectangle(bounds, GuiGetStyle(TEXTBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(TEXTBOX, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(TEXTBOX, BASE_COLOR_PRESSED))));
    } else if state == STATE_DISABLED {
        GuiDrawRectangle(bounds, GuiGetStyle(TEXTBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(TEXTBOX, BORDER + state * 3))), GetColor(cast(u32, GuiGetStyle(TEXTBOX, BASE_COLOR_DISABLED))));
    } else {
        GuiDrawRectangle(bounds, GuiGetStyle(TEXTBOX, BORDER_WIDTH), GetColor(cast(u32, GuiGetStyle(TEXTBOX, BORDER + state * 3))), Color{});
    }
    GuiDrawText(text + textIndexOffset, textBounds, GuiGetStyle(TEXTBOX, TEXT_ALIGNMENT), GetColor(cast(u32, GuiGetStyle(TEXTBOX, TEXT + state * 3))));
    if editMode && !GuiGetStyle(TEXTBOX, TEXT_READONLY) {
        GuiDrawRectangle(cursor, 0, Color{}, GetColor(cast(u32, GuiGetStyle(TEXTBOX, BORDER_COLOR_PRESSED))));
        if mouseCursor.x >= 0.0f {
            GuiDrawRectangle(mouseCursor, 0, Color{}, GetColor(cast(u32, GuiGetStyle(TEXTBOX, BORDER_COLOR_PRESSED))));
        }
    } else if state == STATE_FOCUSED {
        GuiTooltip(bounds);
    }
    return result;
}
