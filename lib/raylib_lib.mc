DIR* opendir(u8* name) {
        DIR* dir = null;
        if name && name[0] {
            u64 base_length = strlen(name);
            u8* all = strchr("/\\", name[base_length - 1]) != null ? "*" : "/*";
            dir = cast(DIR*, malloc(cast(u64, sizeof(*dir))));
            if dir != null {
                dir.name = cast(u8*, malloc(base_length + strlen(all) + 1));
                if dir.name != null {
                    strcat(strcpy(dir.name, name), all);
                    dir.handle = cast(handle_type, _findfirst(dir.name, &dir.info));
                    if dir.handle != -1 {
                        dir.result.d_name = null;
                    } else {
                        free(dir.name);
                        free(dir);
                        dir = null;
                    }
                } else {
                    free(dir);
                    dir = null;
                    errno = ENOMEM;
                }
            }
        } else {
            errno = EINVAL;
        }
        return dir;
    }
i32 closedir(DIR* dir) {
        i32 result = -1;
        if dir != null {
            if dir.handle != -1 {
                result = _findclose(dir.handle);
            }
            free(dir.name);
            free(dir);
        }
        if result == -1 {
            errno = EBADF;
        }
        return result;
    }
dirent* rl_readdir(DIR* dir) {
        dirent* result = null;
        if dir && dir.handle != -1 {
            if !dir.result.d_name || _findnext(dir.handle, &dir.info) != -1 {
                result = &dir.result;
                result.d_name = dir.info.name;
            }
        } else {
            errno = EBADF;
        }
        return result;
    }
void rewinddir(DIR* dir) {
        if dir && dir.handle != -1 {
            _findclose(dir.handle);
            dir.handle = cast(handle_type, _findfirst(dir.name, &dir.info));
            dir.result.d_name = null;
        } else {
            errno = EBADF;
        }
    }
} else {
}
