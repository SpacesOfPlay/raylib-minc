//----------------------------------------------------------------------------------
// Global Variables Definition
//----------------------------------------------------------------------------------
// Global CORE state context
private { PlatformData platform; }
// GLFW3 GLFWdeallocatefun, wraps around RL_FREE macro
//----------------------------------------------------------------------------------
// Module Functions Declaration
//----------------------------------------------------------------------------------
// NOTE: Functions declaration is provided by raylib.h
//----------------------------------------------------------------------------------
// Module Functions Definition: Window and Graphics Device
//----------------------------------------------------------------------------------
// Check if application should close
// NOTE: By default, if KEY_ESCAPE pressed or window close icon clicked
bool WindowShouldClose() {
    if CORE.Window.ready != 0 {
        return CORE.Window.shouldClose;
    } else {
        return true;
    }
}
// Toggle fullscreen mode
void ToggleFullscreen() {
    if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) == 0 {
        CORE.Window.previousPosition = CORE.Window.position;
        CORE.Window.previousScreen = CORE.Window.screen;
        i32 monitorCount = 0;
        i32 monitorIndex = GetCurrentMonitor();
        GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
        GLFWmonitor* monitor = monitorIndex < monitorCount ? monitors[monitorIndex] : null;
        if monitor != null {
            GLFWvidmode* mode = glfwGetVideoMode(monitors[monitorIndex]);
            CORE.Window.display.width = cast(u32, mode.width);
            CORE.Window.display.height = cast(u32, mode.height);
            CORE.Window.position = Point{};
            CORE.Window.screen = CORE.Window.display;
            CORE.Window.flags |= cast(u32, FLAG_FULLSCREEN_MODE);
            glfwSetWindowMonitor(platform.handle, monitor, 0, 0, cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height), -1);
        } else {
                    }
    } else {
        CORE.Window.position = CORE.Window.previousPosition;
        CORE.Window.screen = CORE.Window.previousScreen;
        CORE.Window.flags &= cast(u32, ~FLAG_FULLSCREEN_MODE);
        if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
            Vector2 scaleDpi = GetWindowScaleDPI();
            CORE.Window.screen.width = cast(u32, cast(f32, CORE.Window.screen.width) * scaleDpi.x);
            CORE.Window.screen.height = cast(u32, cast(f32, CORE.Window.screen.height) * scaleDpi.y);
        }
        glfwSetWindowMonitor(platform.handle, null, CORE.Window.position.x, CORE.Window.position.y, cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height), -1);
    }
    if (CORE.Window.flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT) {
        glfwSwapInterval(1);
    }
}
// Toggle borderless windowed mode
void ToggleBorderlessWindowed() {
    if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) {
        ToggleFullscreen();
    }
    i32 monitorCount = 0;
    GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
    i32 monitor = GetCurrentMonitor();
    if monitor >= 0 && monitor < monitorCount {
        GLFWvidmode* mode = glfwGetVideoMode(monitors[monitor]);
        if mode != null {
            if (CORE.Window.flags & cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) == cast(u32, FLAG_BORDERLESS_WINDOWED_MODE) == 0 {
                CORE.Window.previousPosition = CORE.Window.position;
                CORE.Window.previousScreen = CORE.Window.screen;
                glfwSetWindowAttrib(platform.handle, 131077, 0);
                CORE.Window.flags |= cast(u32, FLAG_WINDOW_UNDECORATED);
                glfwGetMonitorPos(monitors[monitor], &CORE.Window.position.x, &CORE.Window.position.y);
                CORE.Window.screen.width = cast(u32, mode.width);
                CORE.Window.screen.height = cast(u32, mode.height);
                glfwSetWindowMonitor(platform.handle, monitors[monitor], CORE.Window.position.x, CORE.Window.position.y, cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height), mode.refreshRate);
                glfwFocusWindow(platform.handle);
                CORE.Window.flags |= cast(u32, FLAG_BORDERLESS_WINDOWED_MODE);
            } else {
                CORE.Window.position = CORE.Window.previousPosition;
                CORE.Window.screen = CORE.Window.previousScreen;
                glfwSetWindowAttrib(platform.handle, 131077, 1);
                CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_UNDECORATED);
                if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
                    Vector2 scaleDpi = GetWindowScaleDPI();
                    CORE.Window.screen.width = cast(u32, cast(f32, CORE.Window.screen.width) * scaleDpi.x);
                    CORE.Window.screen.height = cast(u32, cast(f32, CORE.Window.screen.height) * scaleDpi.y);
                }
                glfwSetWindowMonitor(platform.handle, null, CORE.Window.position.x, CORE.Window.position.y, cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height), mode.refreshRate);
                glfwFocusWindow(platform.handle);
                CORE.Window.flags &= cast(u32, ~FLAG_BORDERLESS_WINDOWED_MODE);
            }
        } else {
                    }
    } else {
            }
}
// Set window state: maximized, if resizable
void MaximizeWindow() {
    if glfwGetWindowAttrib(platform.handle, 131075) == 1 {
        glfwMaximizeWindow(platform.handle);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_MAXIMIZED);
    }
}
// Set window state: minimized
void MinimizeWindow() {
    glfwIconifyWindow(platform.handle);
}
// Restore window from being minimized/maximized
void RestoreWindow() {
    if glfwGetWindowAttrib(platform.handle, 131075) == 1 {
        glfwRestoreWindow(platform.handle);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MINIMIZED);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MAXIMIZED);
    }
}
// Set window configuration state using flags
void SetWindowState(u32 flags) {
    if CORE.Window.ready == 0 {
            }
    if (CORE.Window.flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT) != ((flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT)) && (flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT) {
        glfwSwapInterval(1);
        CORE.Window.flags |= cast(u32, FLAG_VSYNC_HINT);
    }
    if (CORE.Window.flags & cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) == cast(u32, FLAG_BORDERLESS_WINDOWED_MODE) != ((flags & cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) == cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) && (flags & cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) == cast(u32, FLAG_BORDERLESS_WINDOWED_MODE) {
        ToggleBorderlessWindowed();
    }
    if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) != ((flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE)) && (flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) {
        ToggleFullscreen();
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_RESIZABLE)) == cast(u32, FLAG_WINDOW_RESIZABLE) != ((flags & cast(u32, FLAG_WINDOW_RESIZABLE)) == cast(u32, FLAG_WINDOW_RESIZABLE)) && (flags & cast(u32, FLAG_WINDOW_RESIZABLE)) == cast(u32, FLAG_WINDOW_RESIZABLE) {
        glfwSetWindowAttrib(platform.handle, 131075, 1);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_RESIZABLE);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_UNDECORATED)) == cast(u32, FLAG_WINDOW_UNDECORATED) != ((flags & cast(u32, FLAG_WINDOW_UNDECORATED)) == cast(u32, FLAG_WINDOW_UNDECORATED)) && (flags & cast(u32, FLAG_WINDOW_UNDECORATED)) == cast(u32, FLAG_WINDOW_UNDECORATED) {
        glfwSetWindowAttrib(platform.handle, 131077, 0);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_UNDECORATED);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIDDEN)) == cast(u32, FLAG_WINDOW_HIDDEN) != ((flags & cast(u32, FLAG_WINDOW_HIDDEN)) == cast(u32, FLAG_WINDOW_HIDDEN)) && (flags & cast(u32, FLAG_WINDOW_HIDDEN)) == cast(u32, FLAG_WINDOW_HIDDEN) {
        glfwHideWindow(platform.handle);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_HIDDEN);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) != ((flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED)) && (flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) {
        MinimizeWindow();
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MAXIMIZED)) == cast(u32, FLAG_WINDOW_MAXIMIZED) != ((flags & cast(u32, FLAG_WINDOW_MAXIMIZED)) == cast(u32, FLAG_WINDOW_MAXIMIZED)) && (flags & cast(u32, FLAG_WINDOW_MAXIMIZED)) == cast(u32, FLAG_WINDOW_MAXIMIZED) {
        MaximizeWindow();
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_UNFOCUSED)) == cast(u32, FLAG_WINDOW_UNFOCUSED) != ((flags & cast(u32, FLAG_WINDOW_UNFOCUSED)) == cast(u32, FLAG_WINDOW_UNFOCUSED)) && (flags & cast(u32, FLAG_WINDOW_UNFOCUSED)) == cast(u32, FLAG_WINDOW_UNFOCUSED) {
        glfwSetWindowAttrib(platform.handle, 131084, 0);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_UNFOCUSED);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_TOPMOST)) == cast(u32, FLAG_WINDOW_TOPMOST) != ((flags & cast(u32, FLAG_WINDOW_TOPMOST)) == cast(u32, FLAG_WINDOW_TOPMOST)) && (flags & cast(u32, FLAG_WINDOW_TOPMOST)) == cast(u32, FLAG_WINDOW_TOPMOST) {
        glfwSetWindowAttrib(platform.handle, 131079, 1);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_TOPMOST);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_ALWAYS_RUN)) == cast(u32, FLAG_WINDOW_ALWAYS_RUN) != ((flags & cast(u32, FLAG_WINDOW_ALWAYS_RUN)) == cast(u32, FLAG_WINDOW_ALWAYS_RUN)) && (flags & cast(u32, FLAG_WINDOW_ALWAYS_RUN)) == cast(u32, FLAG_WINDOW_ALWAYS_RUN) {
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_ALWAYS_RUN);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_TRANSPARENT)) == cast(u32, FLAG_WINDOW_TRANSPARENT) != ((flags & cast(u32, FLAG_WINDOW_TRANSPARENT)) == cast(u32, FLAG_WINDOW_TRANSPARENT)) && (flags & cast(u32, FLAG_WINDOW_TRANSPARENT)) == cast(u32, FLAG_WINDOW_TRANSPARENT) {
            }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) != ((flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI)) && (flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
            }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) == cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH) != ((flags & cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) == cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) && (flags & cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) == cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH) {
        glfwSetWindowAttrib(platform.handle, 131085, 1);
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH);
    }
    if (CORE.Window.flags & cast(u32, FLAG_MSAA_4X_HINT)) == cast(u32, FLAG_MSAA_4X_HINT) != ((flags & cast(u32, FLAG_MSAA_4X_HINT)) == cast(u32, FLAG_MSAA_4X_HINT)) && (flags & cast(u32, FLAG_MSAA_4X_HINT)) == cast(u32, FLAG_MSAA_4X_HINT) {
            }
    if (CORE.Window.flags & cast(u32, FLAG_INTERLACED_HINT)) == cast(u32, FLAG_INTERLACED_HINT) != ((flags & cast(u32, FLAG_INTERLACED_HINT)) == cast(u32, FLAG_INTERLACED_HINT)) && (flags & cast(u32, FLAG_INTERLACED_HINT)) == cast(u32, FLAG_INTERLACED_HINT) {
            }
}
// Clear window configuration state flags
void ClearWindowState(u32 flags) {
    if (CORE.Window.flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT) && (flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT) {
        glfwSwapInterval(0);
        CORE.Window.flags &= cast(u32, ~FLAG_VSYNC_HINT);
    }
    if (CORE.Window.flags & cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) == cast(u32, FLAG_BORDERLESS_WINDOWED_MODE) && (flags & cast(u32, FLAG_BORDERLESS_WINDOWED_MODE)) == cast(u32, FLAG_BORDERLESS_WINDOWED_MODE) {
        ToggleBorderlessWindowed();
    }
    if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) && (flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) {
        ToggleFullscreen();
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_RESIZABLE)) == cast(u32, FLAG_WINDOW_RESIZABLE) && (flags & cast(u32, FLAG_WINDOW_RESIZABLE)) == cast(u32, FLAG_WINDOW_RESIZABLE) {
        glfwSetWindowAttrib(platform.handle, 131075, 0);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_RESIZABLE);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIDDEN)) == cast(u32, FLAG_WINDOW_HIDDEN) && (flags & cast(u32, FLAG_WINDOW_HIDDEN)) == cast(u32, FLAG_WINDOW_HIDDEN) {
        glfwShowWindow(platform.handle);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_HIDDEN);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) && (flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) {
        RestoreWindow();
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MAXIMIZED)) == cast(u32, FLAG_WINDOW_MAXIMIZED) && (flags & cast(u32, FLAG_WINDOW_MAXIMIZED)) == cast(u32, FLAG_WINDOW_MAXIMIZED) {
        RestoreWindow();
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_UNDECORATED)) == cast(u32, FLAG_WINDOW_UNDECORATED) && (flags & cast(u32, FLAG_WINDOW_UNDECORATED)) == cast(u32, FLAG_WINDOW_UNDECORATED) {
        glfwSetWindowAttrib(platform.handle, 131077, 1);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_UNDECORATED);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_UNFOCUSED)) == cast(u32, FLAG_WINDOW_UNFOCUSED) && (flags & cast(u32, FLAG_WINDOW_UNFOCUSED)) == cast(u32, FLAG_WINDOW_UNFOCUSED) {
        glfwSetWindowAttrib(platform.handle, 131084, 1);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_UNFOCUSED);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_TOPMOST)) == cast(u32, FLAG_WINDOW_TOPMOST) && (flags & cast(u32, FLAG_WINDOW_TOPMOST)) == cast(u32, FLAG_WINDOW_TOPMOST) {
        glfwSetWindowAttrib(platform.handle, 131079, 0);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_TOPMOST);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_ALWAYS_RUN)) == cast(u32, FLAG_WINDOW_ALWAYS_RUN) && (flags & cast(u32, FLAG_WINDOW_ALWAYS_RUN)) == cast(u32, FLAG_WINDOW_ALWAYS_RUN) {
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_ALWAYS_RUN);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_TRANSPARENT)) == cast(u32, FLAG_WINDOW_TRANSPARENT) && (flags & cast(u32, FLAG_WINDOW_TRANSPARENT)) == cast(u32, FLAG_WINDOW_TRANSPARENT) {
            }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) && (flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
            }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) == cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH) && (flags & cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) == cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH) {
        glfwSetWindowAttrib(platform.handle, 131085, 0);
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MOUSE_PASSTHROUGH);
    }
    if (CORE.Window.flags & cast(u32, FLAG_MSAA_4X_HINT)) == cast(u32, FLAG_MSAA_4X_HINT) && (flags & cast(u32, FLAG_MSAA_4X_HINT)) == cast(u32, FLAG_MSAA_4X_HINT) {
            }
    if (CORE.Window.flags & cast(u32, FLAG_INTERLACED_HINT)) == cast(u32, FLAG_INTERLACED_HINT) && (flags & cast(u32, FLAG_INTERLACED_HINT)) == cast(u32, FLAG_INTERLACED_HINT) {
            }
}
// Set icon for window
// NOTE 1: Image must be in RGBA format, 8bit per channel
// NOTE 2: Image is scaled by the OS for all required sizes
void SetWindowIcon(Image image) {
    if image.data == null {
        glfwSetWindowIcon(platform.handle, 0, null);
    } else {
        if image.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8A8 {
            GLFWimage[1] icon;
            icon[0].width = image.width;
            icon[0].height = image.height;
            icon[0].pixels = cast(u8*, image.data);
            glfwSetWindowIcon(platform.handle, 1, icon);
        } else {
                    }
    }
}
// Set icon for window, multiple images
// NOTE 1: Images must be in RGBA format, 8bit per channel
// NOTE 2: The multiple images are used depending on provided sizes
// Standard Windows icon sizes: 256, 128, 96, 64, 48, 32, 24, 16
void SetWindowIcons(Image* images, i32 count) {
    if images == null || count <= 0 {
        glfwSetWindowIcon(platform.handle, 0, null);
    } else {
        i32 valid = 0;
        var icons = new(GLFWimage[count]);
        for i32 i = 0; i < count; i++ {
            if images[i].format == PIXELFORMAT_UNCOMPRESSED_R8G8B8A8 {
                icons[valid].width = images[i].width;
                icons[valid].height = images[i].height;
                icons[valid].pixels = cast(u8*, images[i].data);
                valid++;
            } else {
                            }
        }
        glfwSetWindowIcon(platform.handle, valid, icons);
        free(icons);
    }
}
// Set title for window
void SetWindowTitle(u8* title) {
    CORE.Window.title = title;
    glfwSetWindowTitle(platform.handle, title);
}
// Set window position on screen (windowed mode)
void SetWindowPosition(i32 x, i32 y) {
    CORE.Window.position.x = x;
    CORE.Window.position.y = y;
    glfwSetWindowPos(platform.handle, x, y);
}
// Set monitor for the current window
void SetWindowMonitor(i32 monitor) {
    i32 monitorCount = 0;
    GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
    if monitor >= 0 && monitor < monitorCount {
        if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) {
                        GLFWvidmode* mode = glfwGetVideoMode(monitors[monitor]);
            glfwSetWindowMonitor(platform.handle, monitors[monitor], 0, 0, mode.width, mode.height, mode.refreshRate);
        } else {
                        var screenWidth = cast(i32, CORE.Window.render.width);
            var screenHeight = cast(i32, CORE.Window.render.height);
            i32 monitorWorkareaX = 0;
            i32 monitorWorkareaY = 0;
            i32 monitorWorkareaWidth = 0;
            i32 monitorWorkareaHeight = 0;
            glfwGetMonitorWorkarea(monitors[monitor], &monitorWorkareaX, &monitorWorkareaY, &monitorWorkareaWidth, &monitorWorkareaHeight);
            if screenWidth >= monitorWorkareaWidth || screenHeight >= monitorWorkareaHeight {
                glfwSetWindowPos(platform.handle, monitorWorkareaX, monitorWorkareaY);
            } else {
                i32 x = monitorWorkareaX + monitorWorkareaWidth / 2 - screenWidth / 2;
                i32 y = monitorWorkareaY + monitorWorkareaHeight / 2 - screenHeight / 2;
                glfwSetWindowPos(platform.handle, x, y);
            }
        }
    } else {
            }
}
// Set window minimum dimensions (FLAG_WINDOW_RESIZABLE)
void SetWindowMinSize(i32 width, i32 height) {
    CORE.Window.screenMin.width = cast(u32, width);
    CORE.Window.screenMin.height = cast(u32, height);
    i32 minWidth = CORE.Window.screenMin.width == 0 ? -1 : cast(i32, CORE.Window.screenMin.width);
    i32 minHeight = CORE.Window.screenMin.height == 0 ? -1 : cast(i32, CORE.Window.screenMin.height);
    i32 maxWidth = CORE.Window.screenMax.width == 0 ? -1 : cast(i32, CORE.Window.screenMax.width);
    i32 maxHeight = CORE.Window.screenMax.height == 0 ? -1 : cast(i32, CORE.Window.screenMax.height);
    glfwSetWindowSizeLimits(platform.handle, minWidth, minHeight, maxWidth, maxHeight);
}
// Set window maximum dimensions (FLAG_WINDOW_RESIZABLE)
void SetWindowMaxSize(i32 width, i32 height) {
    CORE.Window.screenMax.width = cast(u32, width);
    CORE.Window.screenMax.height = cast(u32, height);
    i32 minWidth = CORE.Window.screenMin.width == 0 ? -1 : cast(i32, CORE.Window.screenMin.width);
    i32 minHeight = CORE.Window.screenMin.height == 0 ? -1 : cast(i32, CORE.Window.screenMin.height);
    i32 maxWidth = CORE.Window.screenMax.width == 0 ? -1 : cast(i32, CORE.Window.screenMax.width);
    i32 maxHeight = CORE.Window.screenMax.height == 0 ? -1 : cast(i32, CORE.Window.screenMax.height);
    glfwSetWindowSizeLimits(platform.handle, minWidth, minHeight, maxWidth, maxHeight);
}
