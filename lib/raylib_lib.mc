// Set window opacity, value opacity is between 0.0 and 1.0
void SetWindowOpacity(f32 opacity) {
    if opacity >= 1.0f {
        opacity = 1.0f;
    } else if opacity <= 0.0f {
        opacity = 0.0f;
    }
    glfwSetWindowOpacity(platform.handle, opacity);
}
