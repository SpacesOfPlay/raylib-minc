// Get native window handle
void* GetWindowHandle() {
    when os(windows) {
        return glfwGetWin32Window(platform.handle);
    }
    when os(linux) {
    }
    when os(macos) || os(ios) {
        return glfwGetCocoaWindow(platform.handle);
    }
    return null;
}
// Get number of monitors
i32 GetMonitorCount() {
    i32 monitorCount = 0;
    glfwGetMonitors(&monitorCount);
    return monitorCount;
}
// Get current monitor where window is placed
i32 GetCurrentMonitor() {
    i32 index = 0;
    i32 monitorCount = 0;
    GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
    GLFWmonitor* monitor = null;
    if monitorCount >= 1 {
        if IsWindowFullscreen() != 0 {
            monitor = glfwGetWindowMonitor(platform.handle);
            for i32 i = 0; i < monitorCount; i++ {
                if monitors[i] == monitor {
                    index = i;
                    break;
                }
            }
        } else {
            i32 closestDist = 2147483647;
            i32 wcx = 0;
            i32 wcy = 0;
            glfwGetWindowPos(platform.handle, &wcx, &wcy);
            wcx += cast(i32, CORE.Window.screen.width) / 2;
            wcy += cast(i32, CORE.Window.screen.height) / 2;
            for i32 i = 0; i < monitorCount; i++ {
                i32 mx = 0;
                i32 my = 0;
                monitor = monitors[i];
                glfwGetMonitorPos(monitor, &mx, &my);
                GLFWvidmode* mode = glfwGetVideoMode(monitor);
                if mode != null {
                    i32 right = mx + mode.width - 1;
                    i32 bottom = my + mode.height - 1;
                    if wcx >= mx && wcx <= right && wcy >= my && wcy <= bottom {
                        index = i;
                        break;
                    }
                    i32 xclosest = wcx;
                    if wcx < mx {
                        xclosest = mx;
                    } else if wcx > right {
                        xclosest = right;
                    }
                    i32 yclosest = wcy;
                    if wcy < my {
                        yclosest = my;
                    } else if wcy > bottom {
                        yclosest = bottom;
                    }
                    i32 dx = wcx - xclosest;
                    i32 dy = wcy - yclosest;
                    i32 dist = dx * dx + dy * dy;
                    if dist < closestDist {
                        index = i;
                        closestDist = dist;
                    }
                } else {
                                    }
            }
        }
    }
    return index;
}
// Get selected monitor position
Vector2 GetMonitorPosition(i32 monitor) {
    i32 monitorCount = 0;
    GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
    if monitor >= 0 && monitor < monitorCount {
        i32 x = 0;
        i32 y = 0;
        glfwGetMonitorPos(monitors[monitor], &x, &y);
        return Vector2{cast(f32, x), cast(f32, y)};
    } else {
            }
    return Vector2{0.0f, 0.0f};
}
