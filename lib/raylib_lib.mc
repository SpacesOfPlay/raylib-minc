/* stb_image_resize2.h - STUB for the transminc raylib build.

   rtextures.c includes the real (huge, SIMD-heavy) stb_image_resize2
   unconditionally for ImageResize(). The demo never resizes an image, so
   this stub supplies just the one symbol rtextures references
   (stbir_resize_uint8_linear) as a no-op that returns the output buffer
   unchanged. Swap in the real header to support ImageResize. */
