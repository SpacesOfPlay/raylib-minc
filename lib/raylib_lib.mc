private { i32 stbi__info_main(stbi__context* s, i32* x, i32* y, i32* comp) {
    when !(defined(STBI_NO_PNG)) {
        if stbi__png_info(s, x, y, comp) != 0 {
            return 1;
        }
    }
    return stbi__err("unknown image type");
}}
private { i32 stbi__is_16_main(stbi__context* s) {
    when !(defined(STBI_NO_PNG)) {
        if stbi__png_is16(s) != 0 {
            return 1;
        }
    }
    return 0;
}}
i32 stbi_info_from_memory(stbi_uc* buffer, i32 len, i32* x, i32* y, i32* comp) {
    stbi__context s;
    stbi__start_mem(&s, buffer, len);
    return stbi__info_main(&s, x, y, comp);
}
i32 stbi_info_from_callbacks(stbi_io_callbacks* c, void* user, i32* x, i32* y, i32* comp) {
    stbi__context s;
    stbi__start_callbacks(&s, c, user);
    return stbi__info_main(&s, x, y, comp);
}
i32 stbi_is_16_bit_from_memory(stbi_uc* buffer, i32 len) {
    stbi__context s;
    stbi__start_mem(&s, buffer, len);
    return stbi__is_16_main(&s);
}
i32 stbi_is_16_bit_from_callbacks(stbi_io_callbacks* c, void* user) {
    stbi__context s;
    stbi__start_callbacks(&s, c, user);
    return stbi__is_16_main(&s);
}
private { u8* stbir_resize_uint8_linear(u8* input_pixels, i32 input_w, i32 input_h, i32 input_stride, u8* output_pixels, i32 output_w, i32 output_h, i32 output_stride, stbir_pixel_layout pixel_layout) {
    return output_pixels;
}}
// Load pixel data from image as Vector4 array (float normalized)
//----------------------------------------------------------------------------------
// Module Functions Definition
//----------------------------------------------------------------------------------
// Load image from file into CPU memory (RAM)
Image LoadImage(u8* fileName) {
    Image image;
    i32 dataSize = 0;
    u8* fileData = LoadFileData(fileName, &dataSize);
    if fileData != null {
        image = LoadImageFromMemory(GetFileExtension(fileName), fileData, dataSize);
        UnloadFileData(fileData);
    }
    return image;
}
// Load an image from RAW file data
Image LoadImageRaw(u8* fileName, i32 width, i32 height, i32 format_var, i32 headerSize) {
    Image image;
    i32 dataSize = 0;
    u8* fileData = LoadFileData(fileName, &dataSize);
    if fileData != null {
        u8* dataPtr = fileData;
        i32 size = GetPixelDataSize(width, height, format_var);
        if size <= dataSize {
            if headerSize > 0 && headerSize + size <= dataSize {
                dataPtr += headerSize;
            }
            image.data = malloc(cast(u64, size));
            memcpy(image.data, dataPtr, cast(u64, size));
            image.width = width;
            image.height = height;
            image.mipmaps = 1;
            image.format = format_var;
        }
        UnloadFileData(fileData);
    }
    return image;
}
// Load animated image data
//  - Image.data buffer includes all frames: [image#0][image#1][image#2][...]
//  - Number of frames is returned through 'frames' parameter
//  - All frames are returned in RGBA format
//  - Frames delay data is discarded
Image LoadImageAnim(u8* fileName, i32* frames) {
    Image image;
    i32 frameCount = 0;
    if false {
    } else {
        image = LoadImage(fileName);
        frameCount = 1;
    }
    *frames = frameCount;
    return image;
}
// Load animated image data from memory
//  - Image.data buffer includes all frames: [image#0][image#1][image#2][...]
//  - Number of frames is returned through 'frames' parameter
//  - All frames are returned in RGBA format
//  - Frames delay data is discarded
Image LoadImageAnimFromMemory(u8* fileType, u8* fileData, i32 dataSize, i32* frames) {
    Image image;
    i32 frameCount = 0;
    if fileType == null || fileData == null || dataSize == 0 {
        return image;
    }
    if false {
    } else {
        image = LoadImageFromMemory(fileType, fileData, dataSize);
        frameCount = 1;
    }
    *frames = frameCount;
    return image;
}
// Load image from memory buffer, fileType refers to extension: i.e. ".png"
// WARNING: File extension must be provided in lower-case
Image LoadImageFromMemory(u8* fileType, u8* fileData, i32 dataSize) {
    Image image;
    if fileData == null || dataSize == 0 {
                return image;
    }
    if fileType == null {
                return image;
    }
    if false || strcmp(fileType, ".png") == 0 || strcmp(fileType, ".PNG") == 0 {
        if fileData != null {
            i32 comp = 0;
            image.data = stbi_load_from_memory(fileData, dataSize, &image.width, &image.height, &comp, 0);
            if image.data != null {
                image.mipmaps = 1;
                if comp == 1 {
                    image.format = PIXELFORMAT_UNCOMPRESSED_GRAYSCALE;
                } else if comp == 2 {
                    image.format = PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA;
                } else if comp == 3 {
                    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8;
                } else if comp == 4 {
                    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
                }
            }
        }
    } else {
            }
    if image.data != null {
            } else {
            }
    return image;
}
// Load image from GPU texture data
// NOTE: Compressed texture formats not supported
Image LoadImageFromTexture(Texture2D texture) {
    Image image;
    if texture.format < PIXELFORMAT_COMPRESSED_DXT1_RGB {
        image.data = rlReadTexturePixels(texture.id, texture.width, texture.height, texture.format);
        if image.data != null {
            image.width = texture.width;
            image.height = texture.height;
            image.format = texture.format;
            image.mipmaps = 1;
            when defined(GRAPHICS_API_OPENGL_ES2) {
                image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
            }
                    } else {
                    }
    } else {
            }
    return image;
}
// Load image from screen buffer (screenshot)
Image LoadImageFromScreen() {
    Image image;
    image.width = GetRenderWidth();
    image.height = GetRenderHeight();
    image.mipmaps = 1;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    image.data = rlReadScreenPixels(image.width, image.height);
    return image;
}
// Check if an image is ready
bool IsImageValid(Image image) {
    bool result = false;
    if image.data != null && image.width > 0 && image.height > 0 && image.format > 0 && image.mipmaps > 0 {
        result = true;
    }
    return result;
}
// Unload image from CPU memory (RAM)
void UnloadImage(Image image) {
    free(image.data);
}
// Export image data to file
// NOTE: File format depends on fileName extension
bool ExportImage(Image image, u8* fileName) {
    i32 result = 0;
    if image.width == 0 || image.height == 0 || image.data == null {
        return cast(bool, result);
    }
    if result != 0 {
            } else {
            }
    return cast(bool, result);
}
// Export image to memory buffer
u8* ExportImageToMemory(Image image, u8* fileType, i32* dataSize) {
    u8* fileData = null;
    *dataSize = 0;
    if image.width == 0 || image.height == 0 || image.data == null {
        return fileData;
    }
    i32 channels = 4;
    if image.format == PIXELFORMAT_UNCOMPRESSED_GRAYSCALE {
        channels = 1;
    } else if image.format == PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA {
        channels = 2;
    } else if image.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8 {
        channels = 3;
    } else if image.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8A8 {
        channels = 4;
    }
        return fileData;
}
// Export image as code file (.h) defining an array of bytes
bool ExportImageAsCode(Image image, u8* fileName) {
    bool result = false;
    i32 dataSize = GetPixelDataSize(image.width, image.height, image.format);
    var txtData = new(u8[dataSize * 6 + 2000]);
    i32 byteCount = 0;
    byteCount += sprintf(txtData + byteCount, "////////////////////////////////////////////////////////////////////////////////////////\n");
    byteCount += sprintf(txtData + byteCount, "//                                                                                    //\n");
    byteCount += sprintf(txtData + byteCount, "// ImageAsCode exporter v1.0 - Image pixel data exported as an array of bytes         //\n");
    byteCount += sprintf(txtData + byteCount, "//                                                                                    //\n");
    byteCount += sprintf(txtData + byteCount, "// more info and bugs-report:  github.com/raysan5/raylib                              //\n");
    byteCount += sprintf(txtData + byteCount, "// feedback and support:       ray[at]raylib.com                                      //\n");
    byteCount += sprintf(txtData + byteCount, "//                                                                                    //\n");
    byteCount += sprintf(txtData + byteCount, "// Copyright (c) 2018-2026 Ramon Santamaria (@raysan5)                                //\n");
    byteCount += sprintf(txtData + byteCount, "//                                                                                    //\n");
    byteCount += sprintf(txtData + byteCount, "////////////////////////////////////////////////////////////////////////////////////////\n\n");
    u8[256] varFileName;
    strncpy(varFileName, GetFileNameWithoutExt(fileName), cast(u64, 256 - 1));
    for i32 i = 0; varFileName[i] != 0; i++ {
        if varFileName[i] >= 97 && varFileName[i] <= 122 {
            varFileName[i] = cast(u8, varFileName[i] - 32);
        }
    }
    byteCount += sprintf(txtData + byteCount, "// Image data information\n");
    byteCount += sprintf(txtData + byteCount, "#define %s_WIDTH    %i\n", varFileName, image.width);
    byteCount += sprintf(txtData + byteCount, "#define %s_HEIGHT   %i\n", varFileName, image.height);
    byteCount += sprintf(txtData + byteCount, "#define %s_FORMAT   %i          // raylib internal pixel format\n\n", varFileName, image.format);
    byteCount += sprintf(txtData + byteCount, "static unsigned char %s_DATA[%i] = { ", varFileName, dataSize);
    for i32 i = 0; i < dataSize - 1; i++ {
        byteCount += sprintf(txtData + byteCount, i % 20 == 0 ? "0x%x,\n" : "0x%x, ", cast(u8*, image.data)[i]);
    }
    byteCount += sprintf(txtData + byteCount, "0x%x };\n", cast(u8*, image.data)[dataSize - 1]);
    result = SaveFileText(fileName, txtData);
    free(txtData);
    if result != 0 {
            } else {
            }
    return result;
}
//------------------------------------------------------------------------------------
// Image generation functions
//------------------------------------------------------------------------------------
// Generate image: plain color
Image GenImageColor(i32 width, i32 height, Color color) {
    var pixels = new(Color[width * height]);
    for i32 i = 0; i < width * height; i++ {
        pixels[i] = color;
    }
    var image = Image{.data = pixels, .width = width, .height = height, .mipmaps = 1, .format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8};
    return image;
}
//------------------------------------------------------------------------------------
// Image manipulation functions
//------------------------------------------------------------------------------------
// Copy an image to a new image
Image ImageCopy(Image image) {
    Image newImage;
    i32 width = image.width;
    i32 height = image.height;
    i32 size = 0;
    for i32 i = 0; i < image.mipmaps; i++ {
        size += GetPixelDataSize(width, height, image.format);
        width /= 2;
        height /= 2;
        if width < 1 {
            width = 1;
        }
        if height < 1 {
            height = 1;
        }
    }
    newImage.data = calloc(cast(u64, size), cast(u64, 1));
    if newImage.data != null {
        memcpy(newImage.data, image.data, cast(u64, size));
        newImage.width = image.width;
        newImage.height = image.height;
        newImage.mipmaps = image.mipmaps;
        newImage.format = image.format;
    }
    return newImage;
}
// Create an image from another image piece
Image ImageFromImage(Image image, Rectangle rec) {
    Image result;
    i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
    result.width = cast(i32, rec.width);
    result.height = cast(i32, rec.height);
    result.data = calloc(cast(u64, cast(i32, rec.width) * cast(i32, rec.height) * bytesPerPixel), cast(u64, 1));
    result.format = image.format;
    result.mipmaps = 1;
    for i32 y = 0; y < cast(i32, rec.height); y++ {
        memcpy(cast(u8*, result.data) + y * cast(i32, rec.width) * bytesPerPixel, cast(u8*, image.data) + ((y + cast(i32, rec.y)) * image.width + cast(i32, rec.x)) * bytesPerPixel, cast(u64, cast(i32, rec.width) * bytesPerPixel));
    }
    return result;
}
// Crop an image to area defined by a rectangle
// NOTE: Security checks are performed in case rectangle goes out of bounds
void ImageCrop(Image* image, Rectangle crop) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if crop.x < 0.0f {
        crop.width += crop.x;
        crop.x = 0.0f;
    }
    if crop.y < 0.0f {
        crop.height += crop.y;
        crop.y = 0.0f;
    }
    if crop.x + crop.width > cast(f32, image.width) {
        crop.width = cast(f32, image.width) - crop.x;
    }
    if crop.y + crop.height > cast(f32, image.height) {
        crop.height = cast(f32, image.height) - crop.y;
    }
    if crop.x > cast(f32, image.width) || crop.y > cast(f32, image.height) {
                return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var croppedData = cast(u8*, malloc(cast(u64, cast(i32, crop.width * crop.height) * bytesPerPixel)));
        {
            var y = cast(i32, crop.y);
            i32 offsetSize = 0;
            for ; y < cast(i32, crop.y + crop.height); y++ {
                memcpy(croppedData + offsetSize, cast(u8*, image.data) + (y * image.width + cast(i32, crop.x)) * bytesPerPixel, cast(u64, cast(i32, crop.width) * bytesPerPixel));
                offsetSize += cast(i32, crop.width) * bytesPerPixel;
            }
        }
        free(image.data);
        image.data = croppedData;
        image.width = cast(i32, crop.width);
        image.height = cast(i32, crop.height);
    }
}
// Convert image data to desired format
void ImageFormat(Image* image, i32 newFormat) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if newFormat != 0 && image.format != newFormat {
        if image.format < PIXELFORMAT_COMPRESSED_DXT1_RGB && newFormat < PIXELFORMAT_COMPRESSED_DXT1_RGB {
            Vector4* pixels = LoadImageDataNormalized(*image);
            free(image.data);
            image.data = null;
            image.format = newFormat;
            switch image.format {
                case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
                    {
                        image.data = new(u8[image.width * image.height]);
                        for i32 i = 0; i < image.width * image.height; i++ {
                            cast(u8*, image.data)[i] = cast(u8, (pixels[i].x * 0.298999f + pixels[i].y * 0.586999f + pixels[i].z * 0.114000f) * 255.0f);
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                    {
                        image.data = new(u8[image.width * image.height * 2]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 2; i += 2 {
                                cast(u8*, image.data)[i] = cast(u8, (pixels[k].x * 0.298999f + pixels[k].y * 0.586999f + pixels[k].z * 0.114000f) * 255.0f);
                                cast(u8*, image.data)[i + 1] = cast(u8, pixels[k].w * 255.0f);
                                k++;
                            }
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
                    {
                        image.data = new(u16[image.width * image.height]);
                        u8 r = 0;
                        u8 g = 0;
                        u8 b = 0;
                        for i32 i = 0; i < image.width * image.height; i++ {
                            r = cast(u8, round(pixels[i].x * 31.0f));
                            g = cast(u8, round(pixels[i].y * 63.0f));
                            b = cast(u8, round(pixels[i].z * 31.0f));
                            cast(u16*, image.data)[i] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 5 | cast(u16, b));
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
                    {
                        image.data = new(u8[image.width * image.height * 3]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 3; i += 3 {
                                cast(u8*, image.data)[i] = cast(u8, pixels[k].x * 255.0f);
                                cast(u8*, image.data)[i + 1] = cast(u8, pixels[k].y * 255.0f);
                                cast(u8*, image.data)[i + 2] = cast(u8, pixels[k].z * 255.0f);
                                k++;
                            }
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
                    {
                        image.data = new(u16[image.width * image.height]);
                        u8 r = 0;
                        u8 g = 0;
                        u8 b = 0;
                        u8 a = 0;
                        for i32 i = 0; i < image.width * image.height; i++ {
                            r = cast(u8, round(pixels[i].x * 31.0f));
                            g = cast(u8, round(pixels[i].y * 31.0f));
                            b = cast(u8, round(pixels[i].z * 31.0f));
                            a = cast(u8, pixels[i].w > cast(f32, 50) / 255.0f ? 1 : 0);
                            cast(u16*, image.data)[i] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 6 | cast(u16, b) << 1 | cast(u16, a));
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
                    {
                        image.data = new(u16[image.width * image.height]);
                        u8 r = 0;
                        u8 g = 0;
                        u8 b = 0;
                        u8 a = 0;
                        for i32 i = 0; i < image.width * image.height; i++ {
                            r = cast(u8, round(pixels[i].x * 15.0f));
                            g = cast(u8, round(pixels[i].y * 15.0f));
                            b = cast(u8, round(pixels[i].z * 15.0f));
                            a = cast(u8, round(pixels[i].w * 15.0f));
                            cast(u16*, image.data)[i] = cast(u16, cast(u16, r) << 12 | cast(u16, g) << 8 | cast(u16, b) << 4 | cast(u16, a));
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                    {
                        image.data = new(u8[image.width * image.height * 4]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 4; i += 4 {
                                cast(u8*, image.data)[i] = cast(u8, pixels[k].x * 255.0f);
                                cast(u8*, image.data)[i + 1] = cast(u8, pixels[k].y * 255.0f);
                                cast(u8*, image.data)[i + 2] = cast(u8, pixels[k].z * 255.0f);
                                cast(u8*, image.data)[i + 3] = cast(u8, pixels[k].w * 255.0f);
                                k++;
                            }
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R32: {
                    {
                        image.data = new(f32[image.width * image.height]);
                        for i32 i = 0; i < image.width * image.height; i++ {
                            cast(f32*, image.data)[i] = pixels[i].x * 0.298999f + pixels[i].y * 0.586999f + pixels[i].z * 0.114000f;
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
                    {
                        image.data = new(f32[image.width * image.height * 3]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 3; i += 3 {
                                cast(f32*, image.data)[i] = pixels[k].x;
                                cast(f32*, image.data)[i + 1] = pixels[k].y;
                                cast(f32*, image.data)[i + 2] = pixels[k].z;
                                k++;
                            }
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
                    {
                        image.data = new(f32[image.width * image.height * 4]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 4; i += 4 {
                                cast(f32*, image.data)[i] = pixels[k].x;
                                cast(f32*, image.data)[i + 1] = pixels[k].y;
                                cast(f32*, image.data)[i + 2] = pixels[k].z;
                                cast(f32*, image.data)[i + 3] = pixels[k].w;
                                k++;
                            }
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R16: {
                    {
                        image.data = new(u16[image.width * image.height]);
                        for i32 i = 0; i < image.width * image.height; i++ {
                            cast(u16*, image.data)[i] = FloatToHalf(pixels[i].x * 0.298999f + pixels[i].y * 0.586999f + pixels[i].z * 0.114000f);
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
                    {
                        image.data = new(u16[image.width * image.height * 3]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 3; i += 3 {
                                cast(u16*, image.data)[i] = FloatToHalf(pixels[k].x);
                                cast(u16*, image.data)[i + 1] = FloatToHalf(pixels[k].y);
                                cast(u16*, image.data)[i + 2] = FloatToHalf(pixels[k].z);
                                k++;
                            }
                        }
                    }
                }
                case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
                    {
                        image.data = new(u16[image.width * image.height * 4]);
                        {
                            i32 i = 0;
                            i32 k = 0;
                            for ; i < image.width * image.height * 4; i += 4 {
                                cast(u16*, image.data)[i] = FloatToHalf(pixels[k].x);
                                cast(u16*, image.data)[i + 1] = FloatToHalf(pixels[k].y);
                                cast(u16*, image.data)[i + 2] = FloatToHalf(pixels[k].z);
                                cast(u16*, image.data)[i + 3] = FloatToHalf(pixels[k].w);
                                k++;
                            }
                        }
                    }
                }
                default: {
                }
            }
            free(pixels);
            pixels = null;
            if image.mipmaps > 1 {
                image.mipmaps = 1;
                if image.data != null {
                    ImageMipmaps(image);
                }
            }
        } else {
                    }
    }
}
// Create an image from text (default font)
Image ImageText(u8* text, i32 fontSize, Color color) {
    Image imText;
    i32 defaultFontSize = 10;
    if fontSize < defaultFontSize {
        fontSize = defaultFontSize;
    }
    i32 spacing = fontSize / defaultFontSize;
    imText = ImageTextEx(GetFontDefault(), text, cast(f32, fontSize), cast(f32, spacing), color);
    return imText;
}
// Create an image from text (custom sprite font)
// WARNING: Module required: rtext
Image ImageTextEx(Font font, u8* text, f32 fontSize, f32 spacing, Color tint) {
    Image imText;
    if text == null {
        return imText;
    }
    var textLength = cast(i32, strlen(text));
    i32 textOffsetX = 0;
    i32 textOffsetY = 0;
    Vector2 imSize = MeasureTextEx(font, text, cast(f32, font.baseSize), spacing);
    Vector2 textSize = MeasureTextEx(font, text, fontSize, spacing);
    imText = GenImageColor(cast(i32, imSize.x), cast(i32, imSize.y), Color{});
    i32 i = 0;
    while i < textLength {
        i32 codepointByteCount = 0;
        i32 codepoint = GetCodepointNext(&text[i], &codepointByteCount);
        i32 index = GetGlyphIndex(font, codepoint);
        if codepoint == 10 {
            textOffsetY += font.baseSize + font.baseSize / 2;
            textOffsetX = 0;
        } else {
            if codepoint != 32 && codepoint != 9 {
                var rec = Rectangle{cast(f32, textOffsetX + font.glyphs[index].offsetX), cast(f32, textOffsetY + font.glyphs[index].offsetY), font.recs[index].width, font.recs[index].height};
                ImageDraw(&imText, font.glyphs[index].image, Rectangle{0.0f, 0.0f, cast(f32, font.glyphs[index].image.width), cast(f32, font.glyphs[index].image.height)}, rec, tint);
            }
            if font.glyphs[index].advanceX == 0 {
                textOffsetX += cast(i32, font.recs[index].width + spacing);
            } else {
                textOffsetX += font.glyphs[index].advanceX + cast(i32, spacing);
            }
        }
        i += codepointByteCount;
    }
    if textSize.y != imSize.y {
        f32 scaleFactor = textSize.y / imSize.y;
                if font.texture.id == GetFontDefault().texture.id {
            ImageResizeNN(&imText, cast(i32, imSize.x * scaleFactor), cast(i32, imSize.y * scaleFactor));
        } else {
            ImageResize(&imText, cast(i32, imSize.x * scaleFactor), cast(i32, imSize.y * scaleFactor));
        }
    }
    return imText;
}
// Create an image from a selected channel of another image
Image ImageFromChannel(Image image, i32 selectedChannel) {
    Image result;
    if image.data == null || image.width == 0 || image.height == 0 {
        return result;
    }
    if selectedChannel < 0 {
                selectedChannel = 0;
    }
    if image.format == PIXELFORMAT_UNCOMPRESSED_GRAYSCALE || image.format == PIXELFORMAT_UNCOMPRESSED_R32 || image.format == PIXELFORMAT_UNCOMPRESSED_R16 {
        if selectedChannel > 0 {
                        selectedChannel = 0;
        }
    } else if image.format == PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA {
        if selectedChannel > 1 {
                        selectedChannel = 1;
        }
    } else if image.format == PIXELFORMAT_UNCOMPRESSED_R5G6B5 || image.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8 || image.format == PIXELFORMAT_UNCOMPRESSED_R32G32B32 || image.format == PIXELFORMAT_UNCOMPRESSED_R16G16B16 {
        if selectedChannel > 2 {
                        selectedChannel = 0;
        }
    }
    if selectedChannel > 3 {
                selectedChannel = 3;
    }
    result.format = PIXELFORMAT_UNCOMPRESSED_GRAYSCALE;
    result.height = image.height;
    result.width = image.width;
    result.mipmaps = 1;
    var pixels = new(u8[image.width * image.height]);
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        {
            i32 i = 0;
            i32 k = 0;
            for ; i < image.width * image.height; i++ {
                var pixelValue = cast(f32, -1);
                switch image.format {
                    case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
                        {
                            pixelValue = cast(f32, cast(u8*, image.data)[i + selectedChannel]) / 255.0f;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                        {
                            pixelValue = cast(f32, cast(u8*, image.data)[k + selectedChannel]) / 255.0f;
                            k += 2;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            if selectedChannel == 0 {
                                pixelValue = cast(f32, cast(i32, pixel & 63488) >> 11) * (1.0f / 31.0f);
                            } else if selectedChannel == 1 {
                                pixelValue = cast(f32, cast(i32, pixel & 1984) >> 6) * (1.0f / 31.0f);
                            } else if selectedChannel == 2 {
                                pixelValue = cast(f32, cast(i32, pixel & 62) >> 1) * (1.0f / 31.0f);
                            } else if selectedChannel == 3 {
                                pixelValue = (pixel & 1) == 0 ? 0.0f : 1.0f;
                            }
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            if selectedChannel == 0 {
                                pixelValue = cast(f32, cast(i32, pixel & 63488) >> 11) * (1.0f / 31.0f);
                            } else if selectedChannel == 1 {
                                pixelValue = cast(f32, cast(i32, pixel & 2016) >> 5) * (1.0f / 63.0f);
                            } else if selectedChannel == 2 {
                                pixelValue = cast(f32, pixel & 31) * (1.0f / 31.0f);
                            }
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            if selectedChannel == 0 {
                                pixelValue = cast(f32, cast(i32, pixel & 61440) >> 12) * (1.0f / 15.0f);
                            } else if selectedChannel == 1 {
                                pixelValue = cast(f32, cast(i32, pixel & 3840) >> 8) * (1.0f / 15.0f);
                            } else if selectedChannel == 2 {
                                pixelValue = cast(f32, cast(i32, pixel & 240) >> 4) * (1.0f / 15.0f);
                            } else if selectedChannel == 3 {
                                pixelValue = cast(f32, pixel & 15) * (1.0f / 15.0f);
                            }
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                        {
                            pixelValue = cast(f32, cast(u8*, image.data)[k + selectedChannel]) / 255.0f;
                            k += 4;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
                        {
                            pixelValue = cast(f32, cast(u8*, image.data)[k + selectedChannel]) / 255.0f;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32: {
                        {
                            pixelValue = cast(f32*, image.data)[k];
                            k += 1;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
                        {
                            pixelValue = cast(f32*, image.data)[k + selectedChannel];
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
                        {
                            pixelValue = cast(f32*, image.data)[k + selectedChannel];
                            k += 4;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16: {
                        {
                            pixelValue = HalfToFloat(cast(u16*, image.data)[k]);
                            k += 1;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
                        {
                            pixelValue = HalfToFloat(cast(u16*, image.data)[k + selectedChannel]);
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
                        {
                            pixelValue = HalfToFloat(cast(u16*, image.data)[k + selectedChannel]);
                            k += 4;
                        }
                    }
                    default: {
                    }
                }
                pixels[i] = cast(u8, pixelValue * 255.0f);
            }
        }
    }
    result.data = pixels;
    return result;
}
// Resize and image to new size using Nearest-Neighbor scaling algorithm
void ImageResizeNN(Image* image, i32 newWidth, i32 newHeight) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    Color* pixels = LoadImageColors(*image);
    var output = new(Color[newWidth * newHeight]);
    i32 xRatio = (image.width << 16) / newWidth + 1;
    i32 yRatio = (image.height << 16) / newHeight + 1;
    i32 x2 = 0;
    i32 y2 = 0;
    for i32 y = 0; y < newHeight; y++ {
        for i32 x = 0; x < newWidth; x++ {
            x2 = x * xRatio >> 16;
            y2 = y * yRatio >> 16;
            output[y * newWidth + x] = pixels[y2 * image.width + x2];
        }
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    image.data = output;
    image.width = newWidth;
    image.height = newHeight;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
    UnloadImageColors(pixels);
}
// Resize and image to new size
// NOTE: Uses stb default scaling filters (both bicubic):
// STBIR_DEFAULT_FILTER_UPSAMPLE    STBIR_FILTER_CATMULLROM
// STBIR_DEFAULT_FILTER_DOWNSAMPLE  STBIR_FILTER_MITCHELL   (high-quality Catmull-Rom)
void ImageResize(Image* image, i32 newWidth, i32 newHeight) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.format == PIXELFORMAT_UNCOMPRESSED_GRAYSCALE || image.format == PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA || image.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8 || image.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8A8 {
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var output = cast(u8*, malloc(cast(u64, newWidth * newHeight * bytesPerPixel)));
        switch image.format {
            case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
                stbir_resize_uint8_linear(cast(u8*, image.data), image.width, image.height, 0, output, newWidth, newHeight, 0, cast(stbir_pixel_layout, 1));
            }
            case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                stbir_resize_uint8_linear(cast(u8*, image.data), image.width, image.height, 0, output, newWidth, newHeight, 0, cast(stbir_pixel_layout, 2));
            }
            case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
                stbir_resize_uint8_linear(cast(u8*, image.data), image.width, image.height, 0, output, newWidth, newHeight, 0, cast(stbir_pixel_layout, 3));
            }
            case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                stbir_resize_uint8_linear(cast(u8*, image.data), image.width, image.height, 0, output, newWidth, newHeight, 0, cast(stbir_pixel_layout, 4));
            }
            default: {
            }
        }
        free(image.data);
        image.data = output;
        image.width = newWidth;
        image.height = newHeight;
    } else {
        Color* pixels = LoadImageColors(*image);
        var output = new(Color[newWidth * newHeight]);
        stbir_resize_uint8_linear(cast(u8*, pixels), image.width, image.height, 0, cast(u8*, output), newWidth, newHeight, 0, cast(stbir_pixel_layout, 4));
        i32 format_var = image.format;  // renamed from: format
        UnloadImageColors(pixels);
        free(image.data);
        image.data = output;
        image.width = newWidth;
        image.height = newHeight;
        image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
        ImageFormat(image, format_var);
    }
}
// Resize canvas and fill with color
// NOTE: Resize offset is relative to the top-left corner of the original image
void ImageResizeCanvas(Image* image, i32 newWidth, i32 newHeight, i32 offsetX, i32 offsetY, Color fill) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else if newWidth != image.width || newHeight != image.height {
        var srcRec = Rectangle{0.0f, 0.0f, cast(f32, image.width), cast(f32, image.height)};
        var dstPos = Vector2{cast(f32, offsetX), cast(f32, offsetY)};
        if offsetX < 0 {
            srcRec.x = cast(f32, -offsetX);
            srcRec.width += cast(f32, offsetX);
            dstPos.x = 0.0f;
        } else if offsetX + image.width > newWidth {
            srcRec.width = cast(f32, newWidth - offsetX);
        }
        if offsetY < 0 {
            srcRec.y = cast(f32, -offsetY);
            srcRec.height += cast(f32, offsetY);
            dstPos.y = 0.0f;
        } else if offsetY + image.height > newHeight {
            srcRec.height = cast(f32, newHeight - offsetY);
        }
        if cast(f32, newWidth) < srcRec.width {
            srcRec.width = cast(f32, newWidth);
        }
        if cast(f32, newHeight) < srcRec.height {
            srcRec.height = cast(f32, newHeight);
        }
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var resizedData = cast(u8*, calloc(cast(u64, newWidth * newHeight * bytesPerPixel), cast(u64, 1)));
        SetPixelColor(resizedData, fill, image.format);
        for i32 x = 1; x < newWidth; x++ {
            memcpy(resizedData + x * bytesPerPixel, resizedData, cast(u64, bytesPerPixel));
        }
        for i32 y = 1; y < newHeight; y++ {
            memcpy(resizedData + y * newWidth * bytesPerPixel, resizedData, cast(u64, newWidth * bytesPerPixel));
        }
        i32 dstOffsetSize = (cast(i32, dstPos.y) * newWidth + cast(i32, dstPos.x)) * bytesPerPixel;
        for i32 y = 0; y < cast(i32, srcRec.height); y++ {
            memcpy(resizedData + dstOffsetSize, cast(u8*, image.data) + ((y + cast(i32, srcRec.y)) * image.width + cast(i32, srcRec.x)) * bytesPerPixel, cast(u64, cast(i32, srcRec.width) * bytesPerPixel));
            dstOffsetSize += newWidth * bytesPerPixel;
        }
        free(image.data);
        image.data = resizedData;
        image.width = newWidth;
        image.height = newHeight;
    }
}
// Convert image to POT (power-of-two)
// NOTE: It could be useful on OpenGL ES 2.0 (RPI, HTML5)
void ImageToPOT(Image* image, Color fill) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    var potWidth = cast(i32, powf(2.0f, ceilf(logf(cast(f32, image.width)) / logf(2.0f))));
    var potHeight = cast(i32, powf(2.0f, ceilf(logf(cast(f32, image.height)) / logf(2.0f))));
    if potWidth != image.width || potHeight != image.height {
        ImageResizeCanvas(image, potWidth, potHeight, 0, 0, fill);
    }
}
// Crop image depending on alpha value
// NOTE: Threshold is defined as a percentage: 0.0f -> 1.0f
void ImageAlphaCrop(Image* image, f32 threshold) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    Rectangle crop = GetImageAlphaBorder(*image, threshold);
    if cast(i32, crop.width) != 0 && cast(i32, crop.height) != 0 {
        ImageCrop(image, crop);
    }
}
// Clear alpha channel to desired color
// NOTE: Threshold defines the alpha limit, 0.0f to 1.0f
void ImageAlphaClear(Image* image, Color color, f32 threshold) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        switch image.format {
            case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                {
                    var thresholdValue = cast(u8, threshold * 255.0f);
                    for i32 i = 1; i < image.width * image.height * 2; i += 2 {
                        if cast(u8*, image.data)[i] <= thresholdValue {
                            cast(u8*, image.data)[i - 1] = color.r;
                            cast(u8*, image.data)[i] = color.a;
                        }
                    }
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
                {
                    var thresholdValue = cast(u8, threshold < 0.500000f ? 0 : 1);
                    var r = cast(u8, round(cast(f32, color.r) * 31.0f));
                    var g = cast(u8, round(cast(f32, color.g) * 31.0f));
                    var b = cast(u8, round(cast(f32, color.b) * 31.0f));
                    var a = cast(u8, color.a < 128 ? 0 : 1);
                    for i32 i = 0; i < image.width * image.height; i++ {
                        if (cast(u16*, image.data)[i] & 1) <= thresholdValue {
                            cast(u16*, image.data)[i] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 6 | cast(u16, b) << 1 | cast(u16, a));
                        }
                    }
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
                {
                    var thresholdValue = cast(u8, threshold * 15.0f);
                    var r = cast(u8, round(cast(f32, color.r) * 15.0f));
                    var g = cast(u8, round(cast(f32, color.g) * 15.0f));
                    var b = cast(u8, round(cast(f32, color.b) * 15.0f));
                    var a = cast(u8, round(cast(f32, color.a) * 15.0f));
                    for i32 i = 0; i < image.width * image.height; i++ {
                        if (cast(u16*, image.data)[i] & 15) <= thresholdValue {
                            cast(u16*, image.data)[i] = cast(u16, cast(u16, r) << 12 | cast(u16, g) << 8 | cast(u16, b) << 4 | cast(u16, a));
                        }
                    }
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                {
                    var thresholdValue = cast(u8, threshold * 255.0f);
                    for i32 i = 3; i < image.width * image.height * 4; i += 4 {
                        if cast(u8*, image.data)[i] <= thresholdValue {
                            cast(u8*, image.data)[i - 3] = color.r;
                            cast(u8*, image.data)[i - 2] = color.g;
                            cast(u8*, image.data)[i - 1] = color.b;
                            cast(u8*, image.data)[i] = color.a;
                        }
                    }
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
                {
                    for i32 i = 3; i < image.width * image.height * 4; i += 4 {
                        if cast(f32*, image.data)[i] <= threshold {
                            cast(f32*, image.data)[i - 3] = cast(f32, color.r) / 255.0f;
                            cast(f32*, image.data)[i - 2] = cast(f32, color.g) / 255.0f;
                            cast(f32*, image.data)[i - 1] = cast(f32, color.b) / 255.0f;
                            cast(f32*, image.data)[i] = cast(f32, color.a) / 255.0f;
                        }
                    }
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
                {
                    for i32 i = 3; i < image.width * image.height * 4; i += 4 {
                        if HalfToFloat(cast(u16*, image.data)[i]) <= threshold {
                            cast(u16*, image.data)[i - 3] = FloatToHalf(cast(f32, color.r) / 255.0f);
                            cast(u16*, image.data)[i - 2] = FloatToHalf(cast(f32, color.g) / 255.0f);
                            cast(u16*, image.data)[i - 1] = FloatToHalf(cast(f32, color.b) / 255.0f);
                            cast(u16*, image.data)[i] = FloatToHalf(cast(f32, color.a) / 255.0f);
                        }
                    }
                }
            }
            default: {
            }
        }
    }
}
// Apply alpha mask to image
// NOTE 1: Returned image is GRAY_ALPHA (16bit) or RGBA (32bit)
// NOTE 2: alphaMask should be same size as image
void ImageAlphaMask(Image* image, Image alphaMask) {
    if image.width != alphaMask.width || image.height != alphaMask.height {
            } else if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        Image mask = ImageCopy(alphaMask);
        if mask.format != PIXELFORMAT_UNCOMPRESSED_GRAYSCALE {
            ImageFormat(&mask, PIXELFORMAT_UNCOMPRESSED_GRAYSCALE);
        }
        if image.format == PIXELFORMAT_UNCOMPRESSED_GRAYSCALE {
            var data = cast(u8*, malloc(cast(u64, image.width * image.height * 2)));
            {
                i32 i = 0;
                i32 k = 0;
                for ; i < mask.width * mask.height || i < image.width * image.height; i++ {
                    data[k] = cast(u8*, image.data)[i];
                    data[k + 1] = cast(u8*, mask.data)[i];
                    k += 2;
                }
            }
            free(image.data);
            image.data = data;
            image.format = PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA;
        } else {
            if image.format != PIXELFORMAT_UNCOMPRESSED_R8G8B8A8 {
                ImageFormat(image, PIXELFORMAT_UNCOMPRESSED_R8G8B8A8);
            }
            {
                i32 i = 0;
                i32 k = 3;
                for ; i < mask.width * mask.height || i < image.width * image.height; i++ {
                    cast(u8*, image.data)[k] = cast(u8*, mask.data)[i];
                    k += 4;
                }
            }
        }
        UnloadImage(mask);
    }
}
// Premultiply alpha channel
void ImageAlphaPremultiply(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    f32 alpha = 0.0f;
    Color* pixels = LoadImageColors(*image);
    for i32 i = 0; i < image.width * image.height; i++ {
        if pixels[i].a == 0 {
            pixels[i].r = 0;
            pixels[i].g = 0;
            pixels[i].b = 0;
        } else if pixels[i].a < 255 {
            alpha = cast(f32, pixels[i].a) / 255.0f;
            pixels[i].r = cast(u8, cast(f32, pixels[i].r) * alpha);
            pixels[i].g = cast(u8, cast(f32, pixels[i].g) * alpha);
            pixels[i].b = cast(u8, cast(f32, pixels[i].b) * alpha);
        }
    }
    free(image.data);
    i32 format_var = image.format;  // renamed from: format
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Apply box blur to image
void ImageBlurGaussian(Image* image, i32 blurSize) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    ImageAlphaPremultiply(image);
    Color* pixels = LoadImageColors(*image);
    var pixelsCopy1 = new(Vector4[image.height * image.width]);
    var pixelsCopy2 = new(Vector4[image.height * image.width]);
    for i32 i = 0; i < image.height * image.width; i++ {
        pixelsCopy1[i].x = cast(f32, pixels[i].r);
        pixelsCopy1[i].y = cast(f32, pixels[i].g);
        pixelsCopy1[i].z = cast(f32, pixels[i].b);
        pixelsCopy1[i].w = cast(f32, pixels[i].a);
    }
    for i32 j = 0; j < 4; j++ {
        for i32 row = 0; row < image.height; row++ {
            f32 avgR = 0.0f;
            f32 avgG = 0.0f;
            f32 avgB = 0.0f;
            f32 avgAlpha = 0.0f;
            i32 convolutionSize = blurSize;
            for i32 i = 0; i < blurSize; i++ {
                avgR += pixelsCopy1[row * image.width + i].x;
                avgG += pixelsCopy1[row * image.width + i].y;
                avgB += pixelsCopy1[row * image.width + i].z;
                avgAlpha += pixelsCopy1[row * image.width + i].w;
            }
            for i32 x = 0; x < image.width; x++ {
                if x - blurSize - 1 >= 0 {
                    avgR -= pixelsCopy1[row * image.width + x - blurSize - 1].x;
                    avgG -= pixelsCopy1[row * image.width + x - blurSize - 1].y;
                    avgB -= pixelsCopy1[row * image.width + x - blurSize - 1].z;
                    avgAlpha -= pixelsCopy1[row * image.width + x - blurSize - 1].w;
                    convolutionSize--;
                }
                if x + blurSize < image.width {
                    avgR += pixelsCopy1[row * image.width + x + blurSize].x;
                    avgG += pixelsCopy1[row * image.width + x + blurSize].y;
                    avgB += pixelsCopy1[row * image.width + x + blurSize].z;
                    avgAlpha += pixelsCopy1[row * image.width + x + blurSize].w;
                    convolutionSize++;
                }
                pixelsCopy2[row * image.width + x].x = avgR / cast(f32, convolutionSize);
                pixelsCopy2[row * image.width + x].y = avgG / cast(f32, convolutionSize);
                pixelsCopy2[row * image.width + x].z = avgB / cast(f32, convolutionSize);
                pixelsCopy2[row * image.width + x].w = avgAlpha / cast(f32, convolutionSize);
            }
        }
        for i32 col = 0; col < image.width; col++ {
            f32 avgR = 0.0f;
            f32 avgG = 0.0f;
            f32 avgB = 0.0f;
            f32 avgAlpha = 0.0f;
            i32 convolutionSize = blurSize;
            for i32 i = 0; i < blurSize; i++ {
                avgR += pixelsCopy2[i * image.width + col].x;
                avgG += pixelsCopy2[i * image.width + col].y;
                avgB += pixelsCopy2[i * image.width + col].z;
                avgAlpha += pixelsCopy2[i * image.width + col].w;
            }
            for i32 y = 0; y < image.height; y++ {
                if y - blurSize - 1 >= 0 {
                    avgR -= pixelsCopy2[(y - blurSize - 1) * image.width + col].x;
                    avgG -= pixelsCopy2[(y - blurSize - 1) * image.width + col].y;
                    avgB -= pixelsCopy2[(y - blurSize - 1) * image.width + col].z;
                    avgAlpha -= pixelsCopy2[(y - blurSize - 1) * image.width + col].w;
                    convolutionSize--;
                }
                if y + blurSize < image.height {
                    avgR += pixelsCopy2[(y + blurSize) * image.width + col].x;
                    avgG += pixelsCopy2[(y + blurSize) * image.width + col].y;
                    avgB += pixelsCopy2[(y + blurSize) * image.width + col].z;
                    avgAlpha += pixelsCopy2[(y + blurSize) * image.width + col].w;
                    convolutionSize++;
                }
                pixelsCopy1[y * image.width + col].x = cast(f32, cast(u8, avgR / cast(f32, convolutionSize)));
                pixelsCopy1[y * image.width + col].y = cast(f32, cast(u8, avgG / cast(f32, convolutionSize)));
                pixelsCopy1[y * image.width + col].z = cast(f32, cast(u8, avgB / cast(f32, convolutionSize)));
                pixelsCopy1[y * image.width + col].w = cast(f32, cast(u8, avgAlpha / cast(f32, convolutionSize)));
            }
        }
    }
    for i32 i = 0; i < image.width * image.height; i++ {
        if pixelsCopy1[i].w == 0.0f {
            pixels[i].r = 0;
            pixels[i].g = 0;
            pixels[i].b = 0;
            pixels[i].a = 0;
        } else if pixelsCopy1[i].w <= 255.0f {
            f32 alpha = pixelsCopy1[i].w / 255.0f;
            pixels[i].r = cast(u8, fminf(pixelsCopy1[i].x / alpha, 255.0f));
            pixels[i].g = cast(u8, fminf(pixelsCopy1[i].y / alpha, 255.0f));
            pixels[i].b = cast(u8, fminf(pixelsCopy1[i].z / alpha, 255.0f));
            pixels[i].a = cast(u8, pixelsCopy1[i].w);
        }
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    free(pixelsCopy1);
    free(pixelsCopy2);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Apply custom square convolution kernel to image
// NOTE: The convolution kernel matrix is expected to be square
void ImageKernelConvolution(Image* image, f32* kernel, i32 kernelSize) {
    if image.data == null || image.width == 0 || image.height == 0 || kernel == null {
        return;
    }
    var kernelWidth = cast(i32, sqrtf(cast(f32, kernelSize)));
    if kernelWidth * kernelWidth != kernelSize {
                return;
    }
    Color* pixels = LoadImageColors(*image);
    var imageCopy2 = new(Vector4[image.height * image.width]);
    var temp = new(Vector4[kernelSize]);
    for i32 i = 0; i < kernelSize; i++ {
        temp[i].x = 0.0f;
        temp[i].y = 0.0f;
        temp[i].z = 0.0f;
        temp[i].w = 0.0f;
    }
    f32 rRes = 0.0f;
    f32 gRes = 0.0f;
    f32 bRes = 0.0f;
    f32 aRes = 0.0f;
    i32 startRange = 0;
    i32 endRange = 0;
    if kernelWidth % 2 == 0 {
        startRange = -kernelWidth / 2;
        endRange = kernelWidth / 2;
    } else {
        startRange = -kernelWidth / 2;
        endRange = kernelWidth / 2 + 1;
    }
    for i32 x = 0; x < image.height; x++ {
        for i32 y = 0; y < image.width; y++ {
            for i32 xk = startRange; xk < endRange; xk++ {
                for i32 yk = startRange; yk < endRange; yk++ {
                    i32 xkabs = xk + kernelWidth / 2;
                    i32 ykabs = yk + kernelWidth / 2;
                    var imgindex = cast(u32, image.width * (x + xk) + (y + yk));
                    if imgindex >= cast(u32, image.width * image.height) {
                        temp[kernelWidth * xkabs + ykabs].x = 0.0f;
                        temp[kernelWidth * xkabs + ykabs].y = 0.0f;
                        temp[kernelWidth * xkabs + ykabs].z = 0.0f;
                        temp[kernelWidth * xkabs + ykabs].w = 0.0f;
                    } else {
                        temp[kernelWidth * xkabs + ykabs].x = cast(f32, pixels[imgindex].r) / 255.0f * kernel[kernelWidth * xkabs + ykabs];
                        temp[kernelWidth * xkabs + ykabs].y = cast(f32, pixels[imgindex].g) / 255.0f * kernel[kernelWidth * xkabs + ykabs];
                        temp[kernelWidth * xkabs + ykabs].z = cast(f32, pixels[imgindex].b) / 255.0f * kernel[kernelWidth * xkabs + ykabs];
                        temp[kernelWidth * xkabs + ykabs].w = cast(f32, pixels[imgindex].a) / 255.0f * kernel[kernelWidth * xkabs + ykabs];
                    }
                }
            }
            for i32 i = 0; i < kernelSize; i++ {
                rRes += temp[i].x;
                gRes += temp[i].y;
                bRes += temp[i].z;
                aRes += temp[i].w;
            }
            if rRes < 0.0f {
                rRes = 0.0f;
            }
            if gRes < 0.0f {
                gRes = 0.0f;
            }
            if bRes < 0.0f {
                bRes = 0.0f;
            }
            if rRes > 1.0f {
                rRes = 1.0f;
            }
            if gRes > 1.0f {
                gRes = 1.0f;
            }
            if bRes > 1.0f {
                bRes = 1.0f;
            }
            imageCopy2[image.width * x + y].x = rRes;
            imageCopy2[image.width * x + y].y = gRes;
            imageCopy2[image.width * x + y].z = bRes;
            imageCopy2[image.width * x + y].w = aRes;
            rRes = 0.0f;
            gRes = 0.0f;
            bRes = 0.0f;
            aRes = 0.0f;
            for i32 i = 0; i < kernelSize; i++ {
                temp[i].x = 0.0f;
                temp[i].y = 0.0f;
                temp[i].z = 0.0f;
                temp[i].w = 0.0f;
            }
        }
    }
    for i32 i = 0; i < image.width * image.height; i++ {
        var alpha = imageCopy2[i].w;
        pixels[i].r = cast(u8, imageCopy2[i].x * 255.0f);
        pixels[i].g = cast(u8, imageCopy2[i].y * 255.0f);
        pixels[i].b = cast(u8, imageCopy2[i].z * 255.0f);
        pixels[i].a = cast(u8, alpha * 255.0f);
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    free(imageCopy2);
    free(temp);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Generate all mipmap levels for a provided image
// NOTE 1: Supports POT and NPOT images
// NOTE 2: image.data is scaled to include mipmap levels
// NOTE 3: Mipmaps format is the same as base image
void ImageMipmaps(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    i32 mipCount = 1;
    i32 mipWidth = image.width;
    i32 mipHeight = image.height;
    i32 mipSize = GetPixelDataSize(mipWidth, mipHeight, image.format);
    while mipWidth != 1 || mipHeight != 1 {
        if mipWidth != 1 {
            mipWidth /= 2;
        }
        if mipHeight != 1 {
            mipHeight /= 2;
        }
        if mipWidth < 1 {
            mipWidth = 1;
        }
        if mipHeight < 1 {
            mipHeight = 1;
        }
                mipCount++;
        mipSize += GetPixelDataSize(mipWidth, mipHeight, image.format);
    }
    if image.mipmaps < mipCount {
        void* temp = calloc(cast(u64, mipSize), cast(u64, 1));
        memcpy(temp, image.data, cast(u64, GetPixelDataSize(image.width, image.height, image.format)));
        free(image.data);
        image.data = temp;
        var nextmip = cast(u8*, image.data);
        mipWidth = image.width;
        mipHeight = image.height;
        mipSize = GetPixelDataSize(mipWidth, mipHeight, image.format);
        Image imCopy = ImageCopy(*image);
        for i32 i = 1; i < mipCount; i++ {
            nextmip += mipSize;
            mipWidth /= 2;
            mipHeight /= 2;
            if mipWidth < 1 {
                mipWidth = 1;
            }
            if mipHeight < 1 {
                mipHeight = 1;
            }
            mipSize = GetPixelDataSize(mipWidth, mipHeight, image.format);
            if i < image.mipmaps {
                continue;
            }
                        ImageResize(&imCopy, mipWidth, mipHeight);
            memcpy(nextmip, imCopy.data, cast(u64, mipSize));
        }
        UnloadImage(imCopy);
        image.mipmaps = mipCount;
    } else {
            }
}
// Dither image data to 16bpp or lower (Floyd-Steinberg dithering)
// NOTE: In case selected bpp do not represent a known 16bit format,
// dithered data is stored in the LSB part of the unsigned short
void ImageDither(Image* image, i32 rBpp, i32 gBpp, i32 bBpp, i32 aBpp) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
                return;
    }
    if rBpp + gBpp + bBpp + aBpp > 16 {
            } else {
        Color* pixels = LoadImageColors(*image);
        free(image.data);
        if image.format != PIXELFORMAT_UNCOMPRESSED_R8G8B8 && image.format != PIXELFORMAT_UNCOMPRESSED_R8G8B8A8 {
                    }
        if rBpp == 5 && gBpp == 6 && bBpp == 5 && aBpp == 0 {
            image.format = PIXELFORMAT_UNCOMPRESSED_R5G6B5;
        } else if rBpp == 5 && gBpp == 5 && bBpp == 5 && aBpp == 1 {
            image.format = PIXELFORMAT_UNCOMPRESSED_R5G5B5A1;
        } else if rBpp == 4 && gBpp == 4 && bBpp == 4 && aBpp == 4 {
            image.format = PIXELFORMAT_UNCOMPRESSED_R4G4B4A4;
        } else {
            image.format = 0;
                    }
        image.data = new(u16[image.width * image.height]);
        var oldPixel = Color{255, 255, 255, 255};
        var newPixel = Color{255, 255, 255, 255};
        i32 rError = 0;
        i32 gError = 0;
        i32 bError = 0;
        u16 rPixel = 0;
        u16 gPixel = 0;
        u16 bPixel = 0;
        u16 aPixel = 0;
        for i32 y = 0; y < image.height; y++ {
            for i32 x = 0; x < image.width; x++ {
                oldPixel = pixels[y * image.width + x];
                newPixel.r = cast(u8, cast(i32, oldPixel.r) >> 8 - rBpp);
                newPixel.g = cast(u8, cast(i32, oldPixel.g) >> 8 - gBpp);
                newPixel.b = cast(u8, cast(i32, oldPixel.b) >> 8 - bBpp);
                newPixel.a = cast(u8, cast(i32, oldPixel.a) >> 8 - aBpp);
                rError = cast(i32, oldPixel.r) - (cast(i32, newPixel.r) << 8 - rBpp);
                gError = cast(i32, oldPixel.g) - (cast(i32, newPixel.g) << 8 - gBpp);
                bError = cast(i32, oldPixel.b) - (cast(i32, newPixel.b) << 8 - bBpp);
                pixels[y * image.width + x] = newPixel;
                if x < image.width - 1 {
                    pixels[y * image.width + x + 1].r = cast(u8, cast(i32, pixels[y * image.width + x + 1].r) + cast(i32, cast(f32, rError) * 7.0f / 16.0f) < 255 ? cast(i32, pixels[y * image.width + x + 1].r) + cast(i32, cast(f32, rError) * 7.0f / 16.0f) : 255);
                    pixels[y * image.width + x + 1].g = cast(u8, cast(i32, pixels[y * image.width + x + 1].g) + cast(i32, cast(f32, gError) * 7.0f / 16.0f) < 255 ? cast(i32, pixels[y * image.width + x + 1].g) + cast(i32, cast(f32, gError) * 7.0f / 16.0f) : 255);
                    pixels[y * image.width + x + 1].b = cast(u8, cast(i32, pixels[y * image.width + x + 1].b) + cast(i32, cast(f32, bError) * 7.0f / 16.0f) < 255 ? cast(i32, pixels[y * image.width + x + 1].b) + cast(i32, cast(f32, bError) * 7.0f / 16.0f) : 255);
                }
                if x > 0 && y < image.height - 1 {
                    pixels[(y + 1) * image.width + x - 1].r = cast(u8, cast(i32, pixels[(y + 1) * image.width + x - 1].r) + cast(i32, cast(f32, rError) * 3.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x - 1].r) + cast(i32, cast(f32, rError) * 3.0f / 16.0f) : 255);
                    pixels[(y + 1) * image.width + x - 1].g = cast(u8, cast(i32, pixels[(y + 1) * image.width + x - 1].g) + cast(i32, cast(f32, gError) * 3.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x - 1].g) + cast(i32, cast(f32, gError) * 3.0f / 16.0f) : 255);
                    pixels[(y + 1) * image.width + x - 1].b = cast(u8, cast(i32, pixels[(y + 1) * image.width + x - 1].b) + cast(i32, cast(f32, bError) * 3.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x - 1].b) + cast(i32, cast(f32, bError) * 3.0f / 16.0f) : 255);
                }
                if y < image.height - 1 {
                    pixels[(y + 1) * image.width + x].r = cast(u8, cast(i32, pixels[(y + 1) * image.width + x].r) + cast(i32, cast(f32, rError) * 5.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x].r) + cast(i32, cast(f32, rError) * 5.0f / 16.0f) : 255);
                    pixels[(y + 1) * image.width + x].g = cast(u8, cast(i32, pixels[(y + 1) * image.width + x].g) + cast(i32, cast(f32, gError) * 5.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x].g) + cast(i32, cast(f32, gError) * 5.0f / 16.0f) : 255);
                    pixels[(y + 1) * image.width + x].b = cast(u8, cast(i32, pixels[(y + 1) * image.width + x].b) + cast(i32, cast(f32, bError) * 5.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x].b) + cast(i32, cast(f32, bError) * 5.0f / 16.0f) : 255);
                }
                if x < image.width - 1 && y < image.height - 1 {
                    pixels[(y + 1) * image.width + x + 1].r = cast(u8, cast(i32, pixels[(y + 1) * image.width + x + 1].r) + cast(i32, cast(f32, rError) * 1.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x + 1].r) + cast(i32, cast(f32, rError) * 1.0f / 16.0f) : 255);
                    pixels[(y + 1) * image.width + x + 1].g = cast(u8, cast(i32, pixels[(y + 1) * image.width + x + 1].g) + cast(i32, cast(f32, gError) * 1.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x + 1].g) + cast(i32, cast(f32, gError) * 1.0f / 16.0f) : 255);
                    pixels[(y + 1) * image.width + x + 1].b = cast(u8, cast(i32, pixels[(y + 1) * image.width + x + 1].b) + cast(i32, cast(f32, bError) * 1.0f / 16.0f) < 255 ? cast(i32, pixels[(y + 1) * image.width + x + 1].b) + cast(i32, cast(f32, bError) * 1.0f / 16.0f) : 255);
                }
                rPixel = cast(u16, newPixel.r);
                gPixel = cast(u16, newPixel.g);
                bPixel = cast(u16, newPixel.b);
                aPixel = cast(u16, newPixel.a);
                cast(u16*, image.data)[y * image.width + x] = cast(u16, cast(i32, rPixel) << gBpp + bBpp + aBpp | cast(i32, gPixel) << bBpp + aBpp | cast(i32, bPixel) << aBpp | aPixel);
            }
        }
        UnloadImageColors(pixels);
    }
}
// Flip image vertically
void ImageFlipVertical(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var flippedData = cast(u8*, malloc(cast(u64, image.width * image.height * bytesPerPixel)));
        {
            i32 i = image.height - 1;
            i32 offsetSize = 0;
            for ; i >= 0; i-- {
                memcpy(flippedData + offsetSize, cast(u8*, image.data) + i * image.width * bytesPerPixel, cast(u64, image.width * bytesPerPixel));
                offsetSize += image.width * bytesPerPixel;
            }
        }
        free(image.data);
        image.data = flippedData;
    }
}
// Flip image horizontally
void ImageFlipHorizontal(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var flippedData = cast(u8*, malloc(cast(u64, image.width * image.height * bytesPerPixel)));
        for i32 y = 0; y < image.height; y++ {
            for i32 x = 0; x < image.width; x++ {
                for i32 i = 0; i < bytesPerPixel; i++ {
                    flippedData[(y * image.width + x) * bytesPerPixel + i] = cast(u8*, image.data)[(y * image.width + (image.width - 1 - x)) * bytesPerPixel + i];
                }
            }
        }
        free(image.data);
        image.data = flippedData;
    }
}
// Rotate image in degrees
void ImageRotate(Image* image, i32 degrees) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        f32 rad = cast(f32, degrees) * 3.141592f / 180.0f;
        f32 sinRadius = sinf(rad);
        f32 cosRadius = cosf(rad);
        var width = cast(i32, fabsf(cast(f32, image.width) * cosRadius) + fabsf(cast(f32, image.height) * sinRadius));
        var height = cast(i32, fabsf(cast(f32, image.height) * cosRadius) + fabsf(cast(f32, image.width) * sinRadius));
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var rotatedData = cast(u8*, calloc(cast(u64, width * height), cast(u64, bytesPerPixel)));
        for i32 y = 0; y < height; y++ {
            for i32 x = 0; x < width; x++ {
                f32 oldX = (cast(f32, x) - cast(f32, width) / 2.0f) * cosRadius + (cast(f32, y) - cast(f32, height) / 2.0f) * sinRadius + cast(f32, image.width) / 2.0f;
                f32 oldY = (cast(f32, y) - cast(f32, height) / 2.0f) * cosRadius - (cast(f32, x) - cast(f32, width) / 2.0f) * sinRadius + cast(f32, image.height) / 2.0f;
                if oldX >= 0.0f && oldX < cast(f32, image.width) && oldY >= 0.0f && oldY < cast(f32, image.height) {
                    var x1 = cast(i32, floorf(oldX));
                    var y1 = cast(i32, floorf(oldY));
                    i32 x2 = x1 + 1 < image.width - 1 ? x1 + 1 : image.width - 1;
                    i32 y2 = y1 + 1 < image.height - 1 ? y1 + 1 : image.height - 1;
                    f32 px = oldX - cast(f32, x1);
                    f32 py = oldY - cast(f32, y1);
                    for i32 i = 0; i < bytesPerPixel; i++ {
                        var f1 = cast(f32, cast(u8*, image.data)[(y1 * image.width + x1) * bytesPerPixel + i]);
                        var f2 = cast(f32, cast(u8*, image.data)[(y1 * image.width + x2) * bytesPerPixel + i]);
                        var f3 = cast(f32, cast(u8*, image.data)[(y2 * image.width + x1) * bytesPerPixel + i]);
                        var f4 = cast(f32, cast(u8*, image.data)[(y2 * image.width + x2) * bytesPerPixel + i]);
                        f32 val = f1 * (1.0f - px) * (1.0f - py) + f2 * px * (1.0f - py) + f3 * (1.0f - px) * py + f4 * px * py;
                        rotatedData[(y * width + x) * bytesPerPixel + i] = cast(u8, val);
                    }
                }
            }
        }
        free(image.data);
        image.data = rotatedData;
        image.width = width;
        image.height = height;
    }
}
// Rotate image clockwise 90deg
void ImageRotateCW(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var rotatedData = cast(u8*, malloc(cast(u64, image.width * image.height * bytesPerPixel)));
        for i32 y = 0; y < image.height; y++ {
            for i32 x = 0; x < image.width; x++ {
                for i32 i = 0; i < bytesPerPixel; i++ {
                    rotatedData[(x * image.height + (image.height - y - 1)) * bytesPerPixel + i] = cast(u8*, image.data)[(y * image.width + x) * bytesPerPixel + i];
                }
            }
        }
        free(image.data);
        image.data = rotatedData;
        i32 width = image.width;
        i32 height = image.height;
        image.width = height;
        image.height = width;
    }
}
// Rotate image counter-clockwise 90deg
void ImageRotateCCW(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if image.mipmaps > 1 {
            }
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        i32 bytesPerPixel = GetPixelDataSize(1, 1, image.format);
        var rotatedData = cast(u8*, malloc(cast(u64, image.width * image.height * bytesPerPixel)));
        for i32 y = 0; y < image.height; y++ {
            for i32 x = 0; x < image.width; x++ {
                for i32 i = 0; i < bytesPerPixel; i++ {
                    rotatedData[(x * image.height + y) * bytesPerPixel + i] = cast(u8*, image.data)[(y * image.width + (image.width - x - 1)) * bytesPerPixel + i];
                }
            }
        }
        free(image.data);
        image.data = rotatedData;
        i32 width = image.width;
        i32 height = image.height;
        image.width = height;
        image.height = width;
    }
}
// Modify image color: tint
void ImageColorTint(Image* image, Color color) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    Color* pixels = LoadImageColors(*image);
    for i32 i = 0; i < image.width * image.height; i++ {
        var r = cast(u8, cast(i32, pixels[i].r) * cast(i32, color.r) / 255);
        var g = cast(u8, cast(i32, pixels[i].g) * cast(i32, color.g) / 255);
        var b = cast(u8, cast(i32, pixels[i].b) * cast(i32, color.b) / 255);
        var a = cast(u8, cast(i32, pixels[i].a) * cast(i32, color.a) / 255);
        pixels[i].r = r;
        pixels[i].g = g;
        pixels[i].b = b;
        pixels[i].a = a;
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Modify image color: invert
void ImageColorInvert(Image* image) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    Color* pixels = LoadImageColors(*image);
    for i32 i = 0; i < image.width * image.height; i++ {
        pixels[i].r = cast(u8, 255 - pixels[i].r);
        pixels[i].g = cast(u8, 255 - pixels[i].g);
        pixels[i].b = cast(u8, 255 - pixels[i].b);
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Modify image color: grayscale
void ImageColorGrayscale(Image* image) {
    ImageFormat(image, PIXELFORMAT_UNCOMPRESSED_GRAYSCALE);
}
// Modify image color: contrast
// NOTE: Contrast values between -100 and 100
void ImageColorContrast(Image* image, i32 contrast) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if contrast < -100 {
        contrast = -100;
    }
    if contrast > 100 {
        contrast = 100;
    }
    f32 factor = (100.0f + cast(f32, contrast)) / 100.0f;
    factor *= factor;
    Color* pixels = LoadImageColors(*image);
    for i32 i = 0; i < image.width * image.height; i++ {
        f32 pR = cast(f32, pixels[i].r) / 255.0f;
        pR -= 0.500000f;
        pR *= factor;
        pR += 0.500000f;
        pR *= 255.0f;
        if pR < 0.0f {
            pR = 0.0f;
        }
        if pR > 255.0f {
            pR = 255.0f;
        }
        f32 pG = cast(f32, pixels[i].g) / 255.0f;
        pG -= 0.500000f;
        pG *= factor;
        pG += 0.500000f;
        pG *= 255.0f;
        if pG < 0.0f {
            pG = 0.0f;
        }
        if pG > 255.0f {
            pG = 255.0f;
        }
        f32 pB = cast(f32, pixels[i].b) / 255.0f;
        pB -= 0.500000f;
        pB *= factor;
        pB += 0.500000f;
        pB *= 255.0f;
        if pB < 0.0f {
            pB = 0.0f;
        }
        if pB > 255.0f {
            pB = 255.0f;
        }
        pixels[i].r = cast(u8, pR);
        pixels[i].g = cast(u8, pG);
        pixels[i].b = cast(u8, pB);
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Modify image color: brightness
// NOTE: Brightness values between -255 and 255
void ImageColorBrightness(Image* image, i32 brightness) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    if brightness < -255 {
        brightness = -255;
    }
    if brightness > 255 {
        brightness = 255;
    }
    Color* pixels = LoadImageColors(*image);
    for i32 i = 0; i < image.width * image.height; i++ {
        var cR = cast(i32, pixels[i].r + brightness);
        var cG = cast(i32, pixels[i].g + brightness);
        var cB = cast(i32, pixels[i].b + brightness);
        if cR < 0 {
            cR = 1;
        }
        if cR > 255 {
            cR = 255;
        }
        if cG < 0 {
            cG = 1;
        }
        if cG > 255 {
            cG = 255;
        }
        if cB < 0 {
            cB = 1;
        }
        if cB > 255 {
            cB = 255;
        }
        pixels[i].r = cast(u8, cR);
        pixels[i].g = cast(u8, cG);
        pixels[i].b = cast(u8, cB);
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    ImageFormat(image, format_var);
}
// Modify image color: replace color
void ImageColorReplace(Image* image, Color color, Color replace) {
    if image.data == null || image.width == 0 || image.height == 0 {
        return;
    }
    Color* pixels = LoadImageColors(*image);
    for i32 i = 0; i < image.width * image.height; i++ {
        if pixels[i].r == color.r && pixels[i].g == color.g && pixels[i].b == color.b && pixels[i].a == color.a {
            pixels[i].r = replace.r;
            pixels[i].g = replace.g;
            pixels[i].b = replace.b;
            pixels[i].a = replace.a;
        }
    }
    i32 format_var = image.format;  // renamed from: format
    free(image.data);
    image.data = pixels;
    image.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
    if format_var == PIXELFORMAT_UNCOMPRESSED_R8G8B8 || format_var == PIXELFORMAT_UNCOMPRESSED_R5G6B5 || format_var == PIXELFORMAT_UNCOMPRESSED_GRAYSCALE || format_var == PIXELFORMAT_UNCOMPRESSED_R32G32B32 || format_var == PIXELFORMAT_UNCOMPRESSED_R16G16B16 || format_var == PIXELFORMAT_COMPRESSED_DXT1_RGB || format_var == PIXELFORMAT_COMPRESSED_ETC1_RGB || format_var == PIXELFORMAT_COMPRESSED_ETC2_RGB || format_var == PIXELFORMAT_COMPRESSED_PVRT_RGB {
        ImageFormat(image, format_var);
    }
}
// Load color data from image as a Color array (RGBA - 32bit)
// NOTE: Memory allocated should be freed using UnloadImageColors();
Color* LoadImageColors(Image image) {
    if image.width == 0 || image.height == 0 {
        return null;
    }
    var pixels = new(Color[image.width * image.height]);
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        if image.format == PIXELFORMAT_UNCOMPRESSED_R32 || image.format == PIXELFORMAT_UNCOMPRESSED_R32G32B32 || image.format == PIXELFORMAT_UNCOMPRESSED_R32G32B32A32 {
                    }
        if image.format == PIXELFORMAT_UNCOMPRESSED_R16 || image.format == PIXELFORMAT_UNCOMPRESSED_R16G16B16 || image.format == PIXELFORMAT_UNCOMPRESSED_R16G16B16A16 {
                    }
        {
            i32 i = 0;
            i32 k = 0;
            for ; i < image.width * image.height; i++ {
                switch image.format {
                    case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
                        {
                            pixels[i].r = cast(u8*, image.data)[i];
                            pixels[i].g = cast(u8*, image.data)[i];
                            pixels[i].b = cast(u8*, image.data)[i];
                            pixels[i].a = 255;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                        {
                            pixels[i].r = cast(u8*, image.data)[k];
                            pixels[i].g = cast(u8*, image.data)[k];
                            pixels[i].b = cast(u8*, image.data)[k];
                            pixels[i].a = cast(u8*, image.data)[k + 1];
                            k += 2;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            pixels[i].r = cast(u8, cast(f32, cast(i32, pixel & 63488) >> 11) * cast(f32, 255 / 31));
                            pixels[i].g = cast(u8, cast(f32, cast(i32, pixel & 1984) >> 6) * cast(f32, 255 / 31));
                            pixels[i].b = cast(u8, cast(f32, cast(i32, pixel & 62) >> 1) * cast(f32, 255 / 31));
                            pixels[i].a = cast(u8, (pixel & 1) * 255);
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            pixels[i].r = cast(u8, cast(f32, cast(i32, pixel & 63488) >> 11) * cast(f32, 255 / 31));
                            pixels[i].g = cast(u8, cast(f32, cast(i32, pixel & 2016) >> 5) * cast(f32, 255 / 63));
                            pixels[i].b = cast(u8, cast(f32, pixel & 31) * cast(f32, 255 / 31));
                            pixels[i].a = 255;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            pixels[i].r = cast(u8, cast(f32, cast(i32, pixel & 61440) >> 12) * cast(f32, 255 / 15));
                            pixels[i].g = cast(u8, cast(f32, cast(i32, pixel & 3840) >> 8) * cast(f32, 255 / 15));
                            pixels[i].b = cast(u8, cast(f32, cast(i32, pixel & 240) >> 4) * cast(f32, 255 / 15));
                            pixels[i].a = cast(u8, cast(f32, pixel & 15) * cast(f32, 255 / 15));
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                        {
                            pixels[i].r = cast(u8*, image.data)[k];
                            pixels[i].g = cast(u8*, image.data)[k + 1];
                            pixels[i].b = cast(u8*, image.data)[k + 2];
                            pixels[i].a = cast(u8*, image.data)[k + 3];
                            k += 4;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
                        {
                            pixels[i].r = cast(u8*, image.data)[k];
                            pixels[i].g = cast(u8*, image.data)[k + 1];
                            pixels[i].b = cast(u8*, image.data)[k + 2];
                            pixels[i].a = 255;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32: {
                        {
                            pixels[i].r = cast(u8, cast(f32*, image.data)[k] * 255.0f);
                            pixels[i].g = 0;
                            pixels[i].b = 0;
                            pixels[i].a = 255;
                            k += 1;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
                        {
                            pixels[i].r = cast(u8, cast(f32*, image.data)[k] * 255.0f);
                            pixels[i].g = cast(u8, cast(f32*, image.data)[k + 1] * 255.0f);
                            pixels[i].b = cast(u8, cast(f32*, image.data)[k + 2] * 255.0f);
                            pixels[i].a = 255;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
                        {
                            pixels[i].r = cast(u8, cast(f32*, image.data)[k] * 255.0f);
                            pixels[i].g = cast(u8, cast(f32*, image.data)[k + 1] * 255.0f);
                            pixels[i].b = cast(u8, cast(f32*, image.data)[k + 2] * 255.0f);
                            pixels[i].a = cast(u8, cast(f32*, image.data)[k + 3] * 255.0f);
                            k += 4;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16: {
                        {
                            pixels[i].r = cast(u8, HalfToFloat(cast(u16*, image.data)[k]) * 255.0f);
                            pixels[i].g = 0;
                            pixels[i].b = 0;
                            pixels[i].a = 255;
                            k += 1;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
                        {
                            pixels[i].r = cast(u8, HalfToFloat(cast(u16*, image.data)[k]) * 255.0f);
                            pixels[i].g = cast(u8, HalfToFloat(cast(u16*, image.data)[k + 1]) * 255.0f);
                            pixels[i].b = cast(u8, HalfToFloat(cast(u16*, image.data)[k + 2]) * 255.0f);
                            pixels[i].a = 255;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
                        {
                            pixels[i].r = cast(u8, HalfToFloat(cast(u16*, image.data)[k]) * 255.0f);
                            pixels[i].g = cast(u8, HalfToFloat(cast(u16*, image.data)[k + 1]) * 255.0f);
                            pixels[i].b = cast(u8, HalfToFloat(cast(u16*, image.data)[k + 2]) * 255.0f);
                            pixels[i].a = cast(u8, HalfToFloat(cast(u16*, image.data)[k + 3]) * 255.0f);
                            k += 4;
                        }
                    }
                    default: {
                    }
                }
            }
        }
    }
    return pixels;
}
// Load colors palette from image as a Color array (RGBA - 32bit)
// NOTE: Memory allocated should be freed using UnloadImagePalette()
Color* LoadImagePalette(Image image, i32 maxPaletteSize, i32* colorCount) {
    i32 palCount = 0;
    Color* palette = null;
    Color* pixels = LoadImageColors(image);
    if pixels != null {
        palette = new(Color[maxPaletteSize]);
        for i32 i = 0; i < maxPaletteSize; i++ {
            palette[i] = Color{};
        }
        for i32 i = 0; i < image.width * image.height; i++ {
            if pixels[i].a > 0 {
                bool colorInPalette = false;
                for i32 j = 0; j < maxPaletteSize; j++ {
                    if pixels[i].r == palette[j].r && pixels[i].g == palette[j].g && pixels[i].b == palette[j].b && pixels[i].a == palette[j].a {
                        colorInPalette = true;
                        break;
                    }
                }
                if colorInPalette == 0 {
                    palette[palCount] = pixels[i];
                    palCount++;
                    if palCount >= maxPaletteSize {
                        i = image.width * image.height;
                                            }
                }
            }
        }
        UnloadImageColors(pixels);
    }
    *colorCount = palCount;
    return palette;
}
// Unload color data loaded with LoadImageColors()
void UnloadImageColors(Color* colors) {
    free(colors);
}
// Unload colors palette loaded with LoadImagePalette()
void UnloadImagePalette(Color* colors) {
    free(colors);
}
// Get image alpha border rectangle
// NOTE: Threshold is defined as a percentage: 0.0f -> 1.0f
Rectangle GetImageAlphaBorder(Image image, f32 threshold) {
    Rectangle crop;
    Color* pixels = LoadImageColors(image);
    if pixels != null {
        i32 xMin = 65536;
        i32 xMax = 0;
        i32 yMin = 65536;
        i32 yMax = 0;
        for i32 y = 0; y < image.height; y++ {
            for i32 x = 0; x < image.width; x++ {
                if pixels[y * image.width + x].a > cast(u8, threshold * 255.0f) {
                    if x < xMin {
                        xMin = x;
                    }
                    if x > xMax {
                        xMax = x;
                    }
                    if y < yMin {
                        yMin = y;
                    }
                    if y > yMax {
                        yMax = y;
                    }
                }
            }
        }
        if xMin != 65536 && xMax != 65536 {
            crop = Rectangle{cast(f32, xMin), cast(f32, yMin), cast(f32, xMax + 1 - xMin), cast(f32, yMax + 1 - yMin)};
        }
        UnloadImageColors(pixels);
    }
    return crop;
}
// Get image pixel color at (x, y) position
Color GetImageColor(Image image, i32 x, i32 y) {
    Color color;
    if x >= 0 && x < image.width && y >= 0 && y < image.height {
        switch image.format {
            case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
                {
                    color.r = cast(u8*, image.data)[y * image.width + x];
                    color.g = cast(u8*, image.data)[y * image.width + x];
                    color.b = cast(u8*, image.data)[y * image.width + x];
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                {
                    color.r = cast(u8*, image.data)[(y * image.width + x) * 2];
                    color.g = cast(u8*, image.data)[(y * image.width + x) * 2];
                    color.b = cast(u8*, image.data)[(y * image.width + x) * 2];
                    color.a = cast(u8*, image.data)[(y * image.width + x) * 2 + 1];
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
                {
                    u16 pixel = cast(u16*, image.data)[y * image.width + x];
                    color.r = cast(u8, cast(f32, cast(i32, pixel & 63488) >> 11) * cast(f32, 255 / 31));
                    color.g = cast(u8, cast(f32, cast(i32, pixel & 1984) >> 6) * cast(f32, 255 / 31));
                    color.b = cast(u8, cast(f32, cast(i32, pixel & 62) >> 1) * cast(f32, 255 / 31));
                    color.a = cast(u8, (pixel & 1) * 255);
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
                {
                    u16 pixel = cast(u16*, image.data)[y * image.width + x];
                    color.r = cast(u8, cast(f32, cast(i32, pixel & 63488) >> 11) * cast(f32, 255 / 31));
                    color.g = cast(u8, cast(f32, cast(i32, pixel & 2016) >> 5) * cast(f32, 255 / 63));
                    color.b = cast(u8, cast(f32, pixel & 31) * cast(f32, 255 / 31));
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
                {
                    u16 pixel = cast(u16*, image.data)[y * image.width + x];
                    color.r = cast(u8, cast(f32, cast(i32, pixel & 61440) >> 12) * cast(f32, 255 / 15));
                    color.g = cast(u8, cast(f32, cast(i32, pixel & 3840) >> 8) * cast(f32, 255 / 15));
                    color.b = cast(u8, cast(f32, cast(i32, pixel & 240) >> 4) * cast(f32, 255 / 15));
                    color.a = cast(u8, cast(f32, pixel & 15) * cast(f32, 255 / 15));
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                {
                    color.r = cast(u8*, image.data)[(y * image.width + x) * 4];
                    color.g = cast(u8*, image.data)[(y * image.width + x) * 4 + 1];
                    color.b = cast(u8*, image.data)[(y * image.width + x) * 4 + 2];
                    color.a = cast(u8*, image.data)[(y * image.width + x) * 4 + 3];
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
                {
                    color.r = cast(u8*, image.data)[(y * image.width + x) * 3];
                    color.g = cast(u8*, image.data)[(y * image.width + x) * 3 + 1];
                    color.b = cast(u8*, image.data)[(y * image.width + x) * 3 + 2];
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R32: {
                {
                    color.r = cast(u8, cast(f32*, image.data)[y * image.width + x] * 255.0f);
                    color.g = 0;
                    color.b = 0;
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
                {
                    color.r = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 3] * 255.0f);
                    color.g = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 3 + 1] * 255.0f);
                    color.b = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 3 + 2] * 255.0f);
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
                {
                    color.r = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 4] * 255.0f);
                    color.g = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 4 + 1] * 255.0f);
                    color.b = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 4 + 2] * 255.0f);
                    color.a = cast(u8, cast(f32*, image.data)[(y * image.width + x) * 4 + 3] * 255.0f);
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R16: {
                {
                    color.r = cast(u8, HalfToFloat(cast(u16*, image.data)[y * image.width + x]) * 255.0f);
                    color.g = 0;
                    color.b = 0;
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
                {
                    color.r = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 3]) * 255.0f);
                    color.g = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 3 + 1]) * 255.0f);
                    color.b = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 3 + 2]) * 255.0f);
                    color.a = 255;
                }
            }
            case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
                {
                    color.r = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 4]) * 255.0f);
                    color.g = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 4 + 1]) * 255.0f);
                    color.b = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 4 + 2]) * 255.0f);
                    color.a = cast(u8, HalfToFloat(cast(u16*, image.data)[(y * image.width + x) * 4 + 3]) * 255.0f);
                }
            }
            default: {
                            }
        }
    } else {
            }
    return color;
}
//------------------------------------------------------------------------------------
// Image drawing functions
//------------------------------------------------------------------------------------
// Clear image background with given color
void ImageClearBackground(Image* dst, Color color) {
    if dst.data == null || dst.width == 0 || dst.height == 0 {
        return;
    }
    ImageDrawPixel(dst, 0, 0, color);
    var pSrcPixel = cast(u8*, dst.data);
    i32 bytesPerPixel = GetPixelDataSize(1, 1, dst.format);
    i32 totalPixels = dst.width * dst.height;
    for i32 i = 1; i < totalPixels; i *= 2 {
        i32 pixelsToCopy = i < totalPixels - i ? i : totalPixels - i;
        memcpy(pSrcPixel + i * bytesPerPixel, pSrcPixel, cast(u64, pixelsToCopy * bytesPerPixel));
    }
}
// Draw pixel within an image
// NOTE: Compressed image formats not supported
void ImageDrawPixel(Image* dst, i32 x, i32 y, Color color) {
    if dst.data == null || x < 0 || x >= dst.width || y < 0 || y >= dst.height {
        return;
    }
    switch dst.format {
        case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                var gray = cast(u8, (coln.x * 0.298999f + coln.y * 0.586999f + coln.z * 0.114000f) * 255.0f);
                cast(u8*, dst.data)[y * dst.width + x] = gray;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                var gray = cast(u8, (coln.x * 0.298999f + coln.y * 0.586999f + coln.z * 0.114000f) * 255.0f);
                cast(u8*, dst.data)[(y * dst.width + x) * 2] = gray;
                cast(u8*, dst.data)[(y * dst.width + x) * 2 + 1] = color.a;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                var r = cast(u8, round(coln.x * 31.0f));
                var g = cast(u8, round(coln.y * 63.0f));
                var b = cast(u8, round(coln.z * 31.0f));
                cast(u16*, dst.data)[y * dst.width + x] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 5 | cast(u16, b));
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
            {
                var coln = Vector4{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f, cast(f32, color.a) / 255.0f};
                var r = cast(u8, round(coln.x * 31.0f));
                var g = cast(u8, round(coln.y * 31.0f));
                var b = cast(u8, round(coln.z * 31.0f));
                var a = cast(u8, coln.w > cast(f32, 50) / 255.0f ? 1 : 0);
                cast(u16*, dst.data)[y * dst.width + x] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 6 | cast(u16, b) << 1 | cast(u16, a));
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
            {
                var coln = Vector4{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f, cast(f32, color.a) / 255.0f};
                var r = cast(u8, round(coln.x * 15.0f));
                var g = cast(u8, round(coln.y * 15.0f));
                var b = cast(u8, round(coln.z * 15.0f));
                var a = cast(u8, round(coln.w * 15.0f));
                cast(u16*, dst.data)[y * dst.width + x] = cast(u16, cast(u16, r) << 12 | cast(u16, g) << 8 | cast(u16, b) << 4 | cast(u16, a));
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
            {
                cast(u8*, dst.data)[(y * dst.width + x) * 3] = color.r;
                cast(u8*, dst.data)[(y * dst.width + x) * 3 + 1] = color.g;
                cast(u8*, dst.data)[(y * dst.width + x) * 3 + 2] = color.b;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
            {
                cast(u8*, dst.data)[(y * dst.width + x) * 4] = color.r;
                cast(u8*, dst.data)[(y * dst.width + x) * 4 + 1] = color.g;
                cast(u8*, dst.data)[(y * dst.width + x) * 4 + 2] = color.b;
                cast(u8*, dst.data)[(y * dst.width + x) * 4 + 3] = color.a;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R32: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                cast(f32*, dst.data)[y * dst.width + x] = coln.x * 0.298999f + coln.y * 0.586999f + coln.z * 0.114000f;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                cast(f32*, dst.data)[(y * dst.width + x) * 3] = coln.x;
                cast(f32*, dst.data)[(y * dst.width + x) * 3 + 1] = coln.y;
                cast(f32*, dst.data)[(y * dst.width + x) * 3 + 2] = coln.z;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
            {
                var coln = Vector4{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f, cast(f32, color.a) / 255.0f};
                cast(f32*, dst.data)[(y * dst.width + x) * 4] = coln.x;
                cast(f32*, dst.data)[(y * dst.width + x) * 4 + 1] = coln.y;
                cast(f32*, dst.data)[(y * dst.width + x) * 4 + 2] = coln.z;
                cast(f32*, dst.data)[(y * dst.width + x) * 4 + 3] = coln.w;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R16: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                cast(u16*, dst.data)[y * dst.width + x] = FloatToHalf(coln.x * 0.298999f + coln.y * 0.586999f + coln.z * 0.114000f);
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                cast(u16*, dst.data)[(y * dst.width + x) * 3] = FloatToHalf(coln.x);
                cast(u16*, dst.data)[(y * dst.width + x) * 3 + 1] = FloatToHalf(coln.y);
                cast(u16*, dst.data)[(y * dst.width + x) * 3 + 2] = FloatToHalf(coln.z);
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
            {
                var coln = Vector4{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f, cast(f32, color.a) / 255.0f};
                cast(u16*, dst.data)[(y * dst.width + x) * 4] = FloatToHalf(coln.x);
                cast(u16*, dst.data)[(y * dst.width + x) * 4 + 1] = FloatToHalf(coln.y);
                cast(u16*, dst.data)[(y * dst.width + x) * 4 + 2] = FloatToHalf(coln.z);
                cast(u16*, dst.data)[(y * dst.width + x) * 4 + 3] = FloatToHalf(coln.w);
            }
        }
        default: {
        }
    }
}
// Draw pixel within an image (Vector version)
void ImageDrawPixelV(Image* dst, Vector2 position, Color color) {
    ImageDrawPixel(dst, cast(i32, position.x), cast(i32, position.y), color);
}
// Draw line within an image
void ImageDrawLine(Image* dst, i32 startPosX, i32 startPosY, i32 endPosX, i32 endPosY, Color color) {
    i32 shortLen = endPosY - startPosY;
    i32 longLen = endPosX - startPosX;
    bool yLonger = false;
    if abs(shortLen) > abs(longLen) {
        i32 temp = shortLen;
        shortLen = longLen;
        longLen = temp;
        yLonger = true;
    }
    i32 endVal = longLen;
    i32 sgnInc = 1;
    if longLen < 0 {
        longLen = -longLen;
        sgnInc = -1;
    }
    i32 decInc = longLen == 0 ? 0 : (shortLen << 16) / longLen;
    if yLonger != 0 {
        {
            i32 i = 0;
            i32 j = 0;
            for ; i != endVal; i += sgnInc {
                ImageDrawPixel(dst, startPosX + (j >> 16), startPosY + i, color);
                j += decInc;
            }
        }
    } else {
        {
            i32 i = 0;
            i32 j = 0;
            for ; i != endVal; i += sgnInc {
                ImageDrawPixel(dst, startPosX + i, startPosY + (j >> 16), color);
                j += decInc;
            }
        }
    }
}
// Draw line within an image (Vector version)
void ImageDrawLineV(Image* dst, Vector2 start, Vector2 end, Color color) {
    var x1 = cast(i32, start.x + 0.500000f);
    var y1 = cast(i32, start.y + 0.500000f);
    var x2 = cast(i32, end.x + 0.500000f);
    var y2 = cast(i32, end.y + 0.500000f);
    ImageDrawLine(dst, x1, y1, x2, y2, color);
}
// Draw a line defining thickness within an image
void ImageDrawLineEx(Image* dst, Vector2 start, Vector2 end, i32 thick, Color color) {
    var x1 = cast(i32, start.x + 0.500000f);
    var y1 = cast(i32, start.y + 0.500000f);
    var x2 = cast(i32, end.x + 0.500000f);
    var y2 = cast(i32, end.y + 0.500000f);
    i32 dx = x2 - x1;
    i32 dy = y2 - y1;
    if dx != 0 && abs(dy / dx) < 1 {
        i32 wy = thick - 1;
        for i32 i = 0; i <= (wy + 1) / 2; i++ {
            ImageDrawLine(dst, x1, y1 + i, x2, y2 + i, color);
        }
        for i32 i = 1; i <= wy / 2; i++ {
            ImageDrawLine(dst, x1, y1 - i, x2, y2 - i, color);
        }
    } else if dy != 0 {
        i32 wx = thick - 1;
        for i32 i = 0; i <= (wx + 1) / 2; i++ {
            ImageDrawLine(dst, x1 + i, y1, x2 + i, y2, color);
        }
        for i32 i = 1; i <= wx / 2; i++ {
            ImageDrawLine(dst, x1 - i, y1, x2 - i, y2, color);
        }
    }
}
// Draw circle within an image
void ImageDrawCircle(Image* dst, i32 centerX, i32 centerY, i32 radius, Color color) {
    i32 x = 0;
    i32 y = radius;
    i32 decesionParameter = 3 - 2 * radius;
    while y >= x {
        ImageDrawRectangle(dst, centerX - x, centerY + y, x * 2, 1, color);
        ImageDrawRectangle(dst, centerX - x, centerY - y, x * 2, 1, color);
        ImageDrawRectangle(dst, centerX - y, centerY + x, y * 2, 1, color);
        ImageDrawRectangle(dst, centerX - y, centerY - x, y * 2, 1, color);
        x++;
        if decesionParameter > 0 {
            y--;
            decesionParameter = decesionParameter + 4 * (x - y) + 10;
        } else {
            decesionParameter = decesionParameter + 4 * x + 6;
        }
    }
}
// Draw circle within an image (Vector version)
void ImageDrawCircleV(Image* dst, Vector2 center, i32 radius, Color color) {
    ImageDrawCircle(dst, cast(i32, center.x), cast(i32, center.y), radius, color);
}
// Draw circle outline within an image
void ImageDrawCircleLines(Image* dst, i32 centerX, i32 centerY, i32 radius, Color color) {
    i32 x = 0;
    i32 y = radius;
    i32 decesionParameter = 3 - 2 * radius;
    while y >= x {
        ImageDrawPixel(dst, centerX + x, centerY + y, color);
        ImageDrawPixel(dst, centerX - x, centerY + y, color);
        ImageDrawPixel(dst, centerX + x, centerY - y, color);
        ImageDrawPixel(dst, centerX - x, centerY - y, color);
        ImageDrawPixel(dst, centerX + y, centerY + x, color);
        ImageDrawPixel(dst, centerX - y, centerY + x, color);
        ImageDrawPixel(dst, centerX + y, centerY - x, color);
        ImageDrawPixel(dst, centerX - y, centerY - x, color);
        x++;
        if decesionParameter > 0 {
            y--;
            decesionParameter = decesionParameter + 4 * (x - y) + 10;
        } else {
            decesionParameter = decesionParameter + 4 * x + 6;
        }
    }
}
// Draw circle outline within an image (Vector version)
void ImageDrawCircleLinesV(Image* dst, Vector2 center, i32 radius, Color color) {
    ImageDrawCircleLines(dst, cast(i32, center.x), cast(i32, center.y), radius, color);
}
// Draw rectangle within an image
void ImageDrawRectangle(Image* dst, i32 posX, i32 posY, i32 width, i32 height, Color color) {
    ImageDrawRectangleRec(dst, Rectangle{cast(f32, posX), cast(f32, posY), cast(f32, width), cast(f32, height)}, color);
}
// Draw rectangle within an image (Vector version)
void ImageDrawRectangleV(Image* dst, Vector2 position, Vector2 size, Color color) {
    ImageDrawRectangle(dst, cast(i32, position.x), cast(i32, position.y), cast(i32, size.x), cast(i32, size.y), color);
}
// Draw rectangle within an image
void ImageDrawRectangleRec(Image* dst, Rectangle rec, Color color) {
    if dst.data == null || dst.width == 0 || dst.height == 0 {
        return;
    }
    if rec.x < 0.0f {
        rec.width += rec.x;
        rec.x = 0.0f;
    }
    if rec.y < 0.0f {
        rec.height += rec.y;
        rec.y = 0.0f;
    }
    if rec.width < 0.0f {
        rec.width = 0.0f;
    }
    if rec.height < 0.0f {
        rec.height = 0.0f;
    }
    if rec.x + rec.width >= cast(f32, dst.width) {
        rec.width = cast(f32, dst.width) - rec.x;
    }
    if rec.y + rec.height >= cast(f32, dst.height) {
        rec.height = cast(f32, dst.height) - rec.y;
    }
    if rec.x >= cast(f32, dst.width) || rec.y >= cast(f32, dst.height) {
        return;
    }
    if rec.x + rec.width <= 0.0f || rec.y + rec.height <= 0.0f {
        return;
    }
    var sy = cast(i32, rec.y);
    var sx = cast(i32, rec.x);
    i32 bytesPerPixel = GetPixelDataSize(1, 1, dst.format);
    ImageDrawPixel(dst, sx, sy, color);
    i32 bytesOffset = (sy * dst.width + sx) * bytesPerPixel;
    u8* pSrcPixel = cast(u8*, dst.data) + bytesOffset;
    for i32 x = 1; x < cast(i32, rec.width); x *= 2 {
        i32 pixelsToCopy = x < cast(i32, rec.width) - x ? x : cast(i32, rec.width) - x;
        memcpy(pSrcPixel + x * bytesPerPixel, pSrcPixel, cast(u64, pixelsToCopy * bytesPerPixel));
    }
    i32 bytesPerRow = bytesPerPixel * cast(i32, rec.width);
    for i32 y = 1; y < cast(i32, rec.height); y++ {
        memcpy(pSrcPixel + y * dst.width * bytesPerPixel, pSrcPixel, cast(u64, bytesPerRow));
    }
}
// Draw rectangle lines within an image
void ImageDrawRectangleLines(Image* dst, i32 posX, i32 posY, i32 width, i32 height, Color color) {
    var rec = Rectangle{cast(f32, posX), cast(f32, posY), cast(f32, width), cast(f32, height)};
    ImageDrawRectangleLinesEx(dst, rec, 1, color);
}
// Draw rectangle lines within an image with extended parameters
void ImageDrawRectangleLinesEx(Image* dst, Rectangle rec, i32 thick, Color color) {
    ImageDrawRectangle(dst, cast(i32, rec.x), cast(i32, rec.y), cast(i32, rec.width), thick, color);
    ImageDrawRectangle(dst, cast(i32, rec.x), cast(i32, rec.y + cast(f32, thick)), thick, cast(i32, rec.height - cast(f32, thick * 2)), color);
    ImageDrawRectangle(dst, cast(i32, rec.x + rec.width - cast(f32, thick)), cast(i32, rec.y + cast(f32, thick)), thick, cast(i32, rec.height - cast(f32, thick * 2)), color);
    ImageDrawRectangle(dst, cast(i32, rec.x), cast(i32, rec.y + rec.height - cast(f32, thick)), cast(i32, rec.width), thick, color);
}
// Draw triangle within an image
void ImageDrawTriangle(Image* dst, Vector2 v1, Vector2 v2, Vector2 v3, Color color) {
    var xMin = cast(i32, v1.x < v2.x ? v1.x < v3.x ? v1.x : v3.x : v2.x < v3.x ? v2.x : v3.x);
    var yMin = cast(i32, v1.y < v2.y ? v1.y < v3.y ? v1.y : v3.y : v2.y < v3.y ? v2.y : v3.y);
    var xMax = cast(i32, v1.x > v2.x ? v1.x > v3.x ? v1.x : v3.x : v2.x > v3.x ? v2.x : v3.x);
    var yMax = cast(i32, v1.y > v2.y ? v1.y > v3.y ? v1.y : v3.y : v2.y > v3.y ? v2.y : v3.y);
    if xMin < 0 {
        xMin = 0;
    }
    if yMin < 0 {
        yMin = 0;
    }
    if xMax > dst.width {
        xMax = dst.width;
    }
    if yMax > dst.height {
        yMax = dst.height;
    }
    f32 signedArea = (v2.x - v1.x) * (v3.y - v1.y) - (v3.x - v1.x) * (v2.y - v1.y);
    bool isBackFace = signedArea > 0.0f;
    var w1XStep = cast(i32, v3.y - v2.y);
    var w1YStep = cast(i32, v2.x - v3.x);
    var w2XStep = cast(i32, v1.y - v3.y);
    var w2YStep = cast(i32, v3.x - v1.x);
    var w3XStep = cast(i32, v2.y - v1.y);
    var w3YStep = cast(i32, v1.x - v2.x);
    if isBackFace != 0 {
        w1XStep = -w1XStep;
        w1YStep = -w1YStep;
        w2XStep = -w2XStep;
        w2YStep = -w2YStep;
        w3XStep = -w3XStep;
        w3YStep = -w3YStep;
    }
    var w1Row = cast(i32, (cast(f32, xMin) - v2.x) * cast(f32, w1XStep) + cast(f32, w1YStep) * (cast(f32, yMin) - v2.y));
    var w2Row = cast(i32, (cast(f32, xMin) - v3.x) * cast(f32, w2XStep) + cast(f32, w2YStep) * (cast(f32, yMin) - v3.y));
    var w3Row = cast(i32, (cast(f32, xMin) - v1.x) * cast(f32, w3XStep) + cast(f32, w3YStep) * (cast(f32, yMin) - v1.y));
    for i32 y = yMin; y <= yMax; y++ {
        i32 w1 = w1Row;
        i32 w2 = w2Row;
        i32 w3 = w3Row;
        for i32 x = xMin; x <= xMax; x++ {
            if (w1 | w2 | w3) >= 0 {
                ImageDrawPixel(dst, x, y, color);
            }
            w1 += w1XStep;
            w2 += w2XStep;
            w3 += w3XStep;
        }
        w1Row += w1YStep;
        w2Row += w2YStep;
        w3Row += w3YStep;
    }
}
// Draw triangle with interpolated colors within an image
void ImageDrawTriangleGradient(Image* dst, Vector2 v1, Vector2 v2, Vector2 v3, Color c1, Color c2, Color c3) {
    var xMin = cast(i32, v1.x < v2.x ? v1.x < v3.x ? v1.x : v3.x : v2.x < v3.x ? v2.x : v3.x);
    var yMin = cast(i32, v1.y < v2.y ? v1.y < v3.y ? v1.y : v3.y : v2.y < v3.y ? v2.y : v3.y);
    var xMax = cast(i32, v1.x > v2.x ? v1.x > v3.x ? v1.x : v3.x : v2.x > v3.x ? v2.x : v3.x);
    var yMax = cast(i32, v1.y > v2.y ? v1.y > v3.y ? v1.y : v3.y : v2.y > v3.y ? v2.y : v3.y);
    if xMin < 0 {
        xMin = 0;
    }
    if yMin < 0 {
        yMin = 0;
    }
    if xMax > dst.width {
        xMax = dst.width;
    }
    if yMax > dst.height {
        yMax = dst.height;
    }
    f32 signedArea = (v2.x - v1.x) * (v3.y - v1.y) - (v3.x - v1.x) * (v2.y - v1.y);
    bool isBackFace = signedArea > 0.0f;
    var w1XStep = cast(i32, v3.y - v2.y);
    var w1YStep = cast(i32, v2.x - v3.x);
    var w2XStep = cast(i32, v1.y - v3.y);
    var w2YStep = cast(i32, v3.x - v1.x);
    var w3XStep = cast(i32, v2.y - v1.y);
    var w3YStep = cast(i32, v1.x - v2.x);
    if isBackFace != 0 {
        w1XStep = -w1XStep;
        w1YStep = -w1YStep;
        w2XStep = -w2XStep;
        w2YStep = -w2YStep;
        w3XStep = -w3XStep;
        w3YStep = -w3YStep;
    }
    var w1Row = cast(i32, (cast(f32, xMin) - v2.x) * cast(f32, w1XStep) + cast(f32, w1YStep) * (cast(f32, yMin) - v2.y));
    var w2Row = cast(i32, (cast(f32, xMin) - v3.x) * cast(f32, w2XStep) + cast(f32, w2YStep) * (cast(f32, yMin) - v3.y));
    var w3Row = cast(i32, (cast(f32, xMin) - v1.x) * cast(f32, w3XStep) + cast(f32, w3YStep) * (cast(f32, yMin) - v1.y));
    f32 wInvSum = 255.0f / cast(f32, w1Row + w2Row + w3Row);
    for i32 y = yMin; y <= yMax; y++ {
        i32 w1 = w1Row;
        i32 w2 = w2Row;
        i32 w3 = w3Row;
        for i32 x = xMin; x <= xMax; x++ {
            if (w1 | w2 | w3) >= 0 {
                var aW1 = cast(u8, cast(f32, w1) * wInvSum);
                var aW2 = cast(u8, cast(f32, w2) * wInvSum);
                var aW3 = cast(u8, cast(f32, w3) * wInvSum);
                Color finalColor;
                finalColor.r = cast(u8, (c1.r * aW1 + c2.r * aW2 + c3.r * aW3) / 255);
                finalColor.g = cast(u8, (c1.g * aW1 + c2.g * aW2 + c3.g * aW3) / 255);
                finalColor.b = cast(u8, (c1.b * aW1 + c2.b * aW2 + c3.b * aW3) / 255);
                finalColor.a = cast(u8, (c1.a * aW1 + c2.a * aW2 + c3.a * aW3) / 255);
                ImageDrawPixel(dst, x, y, finalColor);
            }
            w1 += w1XStep;
            w2 += w2XStep;
            w3 += w3XStep;
        }
        w1Row += w1YStep;
        w2Row += w2YStep;
        w3Row += w3YStep;
    }
}
// Draw triangle outline within an image
void ImageDrawTriangleLines(Image* dst, Vector2 v1, Vector2 v2, Vector2 v3, Color color) {
    ImageDrawLine(dst, cast(i32, v1.x), cast(i32, v1.y), cast(i32, v2.x), cast(i32, v2.y), color);
    ImageDrawLine(dst, cast(i32, v2.x), cast(i32, v2.y), cast(i32, v3.x), cast(i32, v3.y), color);
    ImageDrawLine(dst, cast(i32, v3.x), cast(i32, v3.y), cast(i32, v1.x), cast(i32, v1.y), color);
}
// Draw a triangle fan defined by points within an image (first vertex is the center)
void ImageDrawTriangleFan(Image* dst, Vector2* points, i32 pointCount, Color color) {
    if pointCount >= 3 {
        for i32 i = 1; i < pointCount - 1; i++ {
            ImageDrawTriangle(dst, points[0], points[i], points[i + 1], color);
        }
    }
}
// Draw a triangle strip defined by points within an image
void ImageDrawTriangleStrip(Image* dst, Vector2* points, i32 pointCount, Color color) {
    if pointCount >= 3 {
        for i32 i = 2; i < pointCount; i++ {
            if i % 2 == 0 {
                ImageDrawTriangle(dst, points[i], points[i - 2], points[i - 1], color);
            } else {
                ImageDrawTriangle(dst, points[i], points[i - 1], points[i - 2], color);
            }
        }
    }
}
// Draw an image (source) within an image (destination)
// NOTE: Color tint is applied to source image
void ImageDraw(Image* dst, Image src, Rectangle srcRec, Rectangle dstRec, Color tint) {
    if dst.data == null || dst.width == 0 || dst.height == 0 || src.data == null || src.width == 0 || src.height == 0 {
        return;
    }
    if dst.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        Image srcMod;
        Image* srcPtr = &src;
        bool useSrcMod = false;
        if srcRec.x < 0.0f {
            srcRec.width += srcRec.x;
            srcRec.x = 0.0f;
        }
        if srcRec.y < 0.0f {
            srcRec.height += srcRec.y;
            srcRec.y = 0.0f;
        }
        if srcRec.x + srcRec.width > cast(f32, src.width) {
            srcRec.width = cast(f32, src.width) - srcRec.x;
        }
        if srcRec.y + srcRec.height > cast(f32, src.height) {
            srcRec.height = cast(f32, src.height) - srcRec.y;
        }
        if cast(i32, srcRec.width) != cast(i32, dstRec.width) || cast(i32, srcRec.height) != cast(i32, dstRec.height) {
            srcMod = ImageFromImage(src, srcRec);
            ImageResize(&srcMod, cast(i32, dstRec.width), cast(i32, dstRec.height));
            srcRec = Rectangle{0.0f, 0.0f, cast(f32, srcMod.width), cast(f32, srcMod.height)};
            srcPtr = &srcMod;
            useSrcMod = true;
        }
        if dstRec.x < 0.0f {
            srcRec.x -= dstRec.x;
            srcRec.width += dstRec.x;
            dstRec.x = 0.0f;
        } else if dstRec.x + srcRec.width > cast(f32, dst.width) {
            srcRec.width = cast(f32, dst.width) - dstRec.x;
        }
        if dstRec.y < 0.0f {
            srcRec.y -= dstRec.y;
            srcRec.height += dstRec.y;
            dstRec.y = 0.0f;
        } else if dstRec.y + srcRec.height > cast(f32, dst.height) {
            srcRec.height = cast(f32, dst.height) - dstRec.y;
        }
        if cast(f32, dst.width) < srcRec.width {
            srcRec.width = cast(f32, dst.width);
        }
        if cast(f32, dst.height) < srcRec.height {
            srcRec.height = cast(f32, dst.height);
        }
        Color colSrc;
        Color colDst;
        Color blend;
        bool blendRequired = true;
        if tint.a == 255 && (srcPtr.format == PIXELFORMAT_UNCOMPRESSED_GRAYSCALE || srcPtr.format == PIXELFORMAT_UNCOMPRESSED_R5G6B5 || srcPtr.format == PIXELFORMAT_UNCOMPRESSED_R8G8B8 || srcPtr.format == PIXELFORMAT_UNCOMPRESSED_R32 || srcPtr.format == PIXELFORMAT_UNCOMPRESSED_R32G32B32 || srcPtr.format == PIXELFORMAT_UNCOMPRESSED_R16 || srcPtr.format == PIXELFORMAT_UNCOMPRESSED_R16G16B16) {
            blendRequired = false;
        }
        i32 strideDst = GetPixelDataSize(dst.width, 1, dst.format);
        i32 bytesPerPixelDst = strideDst / dst.width;
        i32 strideSrc = GetPixelDataSize(srcPtr.width, 1, srcPtr.format);
        i32 bytesPerPixelSrc = strideSrc / srcPtr.width;
        u8* pSrcBase = cast(u8*, srcPtr.data) + (cast(i32, srcRec.y) * srcPtr.width + cast(i32, srcRec.x)) * bytesPerPixelSrc;
        u8* pDstBase = cast(u8*, dst.data) + (cast(i32, dstRec.y) * dst.width + cast(i32, dstRec.x)) * bytesPerPixelDst;
        for i32 y = 0; y < cast(i32, srcRec.height); y++ {
            u8* pSrc = pSrcBase;
            u8* pDst = pDstBase;
            if !blendRequired && srcPtr.format == dst.format {
                memcpy(pDst, pSrc, cast(u64, cast(i32, srcRec.width) * bytesPerPixelSrc));
            } else {
                for i32 x = 0; x < cast(i32, srcRec.width); x++ {
                    colSrc = GetPixelColor(pSrc, srcPtr.format);
                    colDst = GetPixelColor(pDst, dst.format);
                    if blendRequired != 0 {
                        blend = ColorAlphaBlend(colDst, colSrc, tint);
                    } else {
                        blend = colSrc;
                    }
                    SetPixelColor(pDst, blend, dst.format);
                    pDst += bytesPerPixelDst;
                    pSrc += bytesPerPixelSrc;
                }
            }
            pSrcBase += strideSrc;
            pDstBase += strideDst;
        }
        if useSrcMod != 0 {
            UnloadImage(srcMod);
        }
        if dst.mipmaps > 1 && src.mipmaps > 1 {
            Image mipmapDst = *dst;
            mipmapDst.data = cast(u8*, mipmapDst.data) + GetPixelDataSize(mipmapDst.width, mipmapDst.height, mipmapDst.format);
            mipmapDst.width /= 2;
            mipmapDst.height /= 2;
            mipmapDst.mipmaps--;
            Image mipmapSrc = src;
            mipmapSrc.data = cast(u8*, mipmapSrc.data) + GetPixelDataSize(mipmapSrc.width, mipmapSrc.height, mipmapSrc.format);
            mipmapSrc.width /= 2;
            mipmapSrc.height /= 2;
            mipmapSrc.mipmaps--;
            Rectangle mipmapSrcRec = srcRec;
            mipmapSrcRec.width /= 2.0f;
            mipmapSrcRec.height /= 2.0f;
            mipmapSrcRec.x /= 2.0f;
            mipmapSrcRec.y /= 2.0f;
            Rectangle mipmapDstRec = dstRec;
            mipmapDstRec.width /= 2.0f;
            mipmapDstRec.height /= 2.0f;
            mipmapDstRec.x /= 2.0f;
            mipmapDstRec.y /= 2.0f;
            ImageDraw(&mipmapDst, mipmapSrc, mipmapSrcRec, mipmapDstRec, tint);
        }
    }
}
// Draw text (default font) within an image (destination)
void ImageDrawText(Image* dst, u8* text, i32 posX, i32 posY, i32 fontSize, Color color) {
    if GetFontDefault().texture.id == 0 {
        LoadFontDefault();
    }
    var position = Vector2{cast(f32, posX), cast(f32, posY)};
    ImageDrawTextEx(dst, GetFontDefault(), text, position, cast(f32, fontSize), 1.0f, color);
}
// Draw text (custom sprite font) within an image (destination)
void ImageDrawTextEx(Image* dst, Font font, u8* text, Vector2 position, f32 fontSize, f32 spacing, Color tint) {
    Image imText = ImageTextEx(font, text, fontSize, spacing, tint);
    var srcRec = Rectangle{0.0f, 0.0f, cast(f32, imText.width), cast(f32, imText.height)};
    var dstRec = Rectangle{position.x, position.y, cast(f32, imText.width), cast(f32, imText.height)};
    ImageDraw(dst, imText, srcRec, dstRec, Color{255, 255, 255, 255});
    UnloadImage(imText);
}
//------------------------------------------------------------------------------------
// Texture loading functions
//------------------------------------------------------------------------------------
// Load texture from file into GPU memory (VRAM)
Texture2D LoadTexture(u8* fileName) {
    Texture2D texture;
    Image image = LoadImage(fileName);
    if image.data != null {
        texture = LoadTextureFromImage(image);
        UnloadImage(image);
    }
    return texture;
}
// Load a texture from image data
// NOTE: image is not unloaded, it must be done manually
Texture2D LoadTextureFromImage(Image image) {
    Texture2D texture;
    if image.width != 0 && image.height != 0 {
        texture.id = rlLoadTexture(image.data, image.width, image.height, image.format, image.mipmaps);
    } else {
            }
    texture.width = image.width;
    texture.height = image.height;
    texture.mipmaps = image.mipmaps;
    texture.format = image.format;
    return texture;
}
// Load cubemap from image, multiple image cubemap layouts supported
TextureCubemap LoadTextureCubemap(Image image, i32 layout) {
    TextureCubemap cubemap;
    if layout == CUBEMAP_LAYOUT_AUTO_DETECT {
        if image.width > image.height {
            if image.width / 6 == image.height {
                layout = CUBEMAP_LAYOUT_LINE_HORIZONTAL;
                cubemap.width = image.width / 6;
            } else if image.width / 4 == image.height / 3 {
                layout = CUBEMAP_LAYOUT_CROSS_FOUR_BY_THREE;
                cubemap.width = image.width / 4;
            }
        } else if image.height > image.width {
            if image.height / 6 == image.width {
                layout = CUBEMAP_LAYOUT_LINE_VERTICAL;
                cubemap.width = image.height / 6;
            } else if image.width / 3 == image.height / 4 {
                layout = CUBEMAP_LAYOUT_CROSS_THREE_BY_FOUR;
                cubemap.width = image.width / 3;
            }
        }
    } else {
        if layout == CUBEMAP_LAYOUT_LINE_VERTICAL {
            cubemap.width = image.height / 6;
        }
        if layout == CUBEMAP_LAYOUT_LINE_HORIZONTAL {
            cubemap.width = image.width / 6;
        }
        if layout == CUBEMAP_LAYOUT_CROSS_THREE_BY_FOUR {
            cubemap.width = image.width / 3;
        }
        if layout == CUBEMAP_LAYOUT_CROSS_FOUR_BY_THREE {
            cubemap.width = image.width / 4;
        }
    }
    cubemap.height = cubemap.width;
    if layout != CUBEMAP_LAYOUT_AUTO_DETECT {
        i32 size = cubemap.width;
        Image faces;
        Rectangle[6] faceRecs;
        for i32 i = 0; i < 6; i++ {
            faceRecs[i] = Rectangle{0.0f, 0.0f, cast(f32, size), cast(f32, size)};
        }
        if layout == CUBEMAP_LAYOUT_LINE_VERTICAL {
            faces = ImageCopy(image);
        } else {
            if layout == CUBEMAP_LAYOUT_LINE_HORIZONTAL {
                for i32 i = 0; i < 6; i++ {
                    faceRecs[i].x = cast(f32, size) * cast(f32, i);
                }
            } else if layout == CUBEMAP_LAYOUT_CROSS_THREE_BY_FOUR {
                faceRecs[0].x = cast(f32, size);
                faceRecs[0].y = cast(f32, size);
                faceRecs[1].x = cast(f32, size);
                faceRecs[1].y = cast(f32, size) * 3.0f;
                faceRecs[2].x = cast(f32, size);
                faceRecs[2].y = 0.0f;
                faceRecs[3].x = cast(f32, size);
                faceRecs[3].y = cast(f32, size) * 2.0f;
                faceRecs[4].x = 0.0f;
                faceRecs[4].y = cast(f32, size);
                faceRecs[5].x = cast(f32, size) * 2.0f;
                faceRecs[5].y = cast(f32, size);
            } else if layout == CUBEMAP_LAYOUT_CROSS_FOUR_BY_THREE {
                faceRecs[0].x = cast(f32, size) * 2.0f;
                faceRecs[0].y = cast(f32, size);
                faceRecs[1].x = 0.0f;
                faceRecs[1].y = cast(f32, size);
                faceRecs[2].x = cast(f32, size);
                faceRecs[2].y = 0.0f;
                faceRecs[3].x = cast(f32, size);
                faceRecs[3].y = cast(f32, size) * 2.0f;
                faceRecs[4].x = cast(f32, size);
                faceRecs[4].y = cast(f32, size);
                faceRecs[5].x = cast(f32, size) * 3.0f;
                faceRecs[5].y = cast(f32, size);
            }
            faces = GenImageColor(size, size * 6, Color{255, 0, 255, 255});
            ImageFormat(&faces, image.format);
            Image mipmapped = ImageCopy(image);
            if image.mipmaps > 1 {
                ImageMipmaps(&mipmapped);
                ImageMipmaps(&faces);
            }
            for i32 i = 0; i < 6; i++ {
                ImageDraw(&faces, mipmapped, faceRecs[i], Rectangle{0.0f, cast(f32, size) * cast(f32, i), cast(f32, size), cast(f32, size)}, Color{255, 255, 255, 255});
            }
            UnloadImage(mipmapped);
        }
        cubemap.id = rlLoadTextureCubemap(faces.data, size, faces.format, faces.mipmaps);
        if cubemap.id != 0 {
            cubemap.format = faces.format;
            cubemap.mipmaps = faces.mipmaps;
        } else {
                    }
        UnloadImage(faces);
    } else {
            }
    return cubemap;
}
// Load texture for rendering (framebuffer)
// NOTE: Render texture is loaded by default with RGBA color attachment and depth RenderBuffer
RenderTexture2D LoadRenderTexture(i32 width, i32 height) {
    RenderTexture2D target;
    target.id = rlLoadFramebuffer();
    if target.id > 0 {
        rlEnableFramebuffer(target.id);
        target.texture.id = rlLoadTexture(null, width, height, PIXELFORMAT_UNCOMPRESSED_R8G8B8A8, 1);
        target.texture.width = width;
        target.texture.height = height;
        target.texture.format = PIXELFORMAT_UNCOMPRESSED_R8G8B8A8;
        target.texture.mipmaps = 1;
        target.depth.id = rlLoadTextureDepth(width, height, true);
        target.depth.width = width;
        target.depth.height = height;
        target.depth.format = 19;
        target.depth.mipmaps = 1;
        rlFramebufferAttach(target.id, target.texture.id, RL_ATTACHMENT_COLOR_CHANNEL0, RL_ATTACHMENT_TEXTURE2D, 0);
        rlFramebufferAttach(target.id, target.depth.id, RL_ATTACHMENT_DEPTH, RL_ATTACHMENT_RENDERBUFFER, 0);
        if rlFramebufferComplete(target.id) != 0 {
                    }
        rlDisableFramebuffer();
    } else {
            }
    return target;
}
// Check if a texture is valid (loaded in GPU)
bool IsTextureValid(Texture2D texture) {
    bool result = false;
    if texture.id > 0 && texture.width > 0 && texture.height > 0 && texture.format > 0 && texture.mipmaps > 0 {
        result = true;
    }
    return result;
}
// Unload texture from GPU memory (VRAM)
void UnloadTexture(Texture2D texture) {
    if texture.id > 0 {
        rlUnloadTexture(texture.id);
            }
}
// Check if a render texture is valid (loaded in GPU)
bool IsRenderTextureValid(RenderTexture2D target) {
    bool result = false;
    if target.id > 0 && IsTextureValid(target.depth) && IsTextureValid(target.texture) {
        result = true;
    }
    return result;
}
// Unload render texture from GPU memory (VRAM)
void UnloadRenderTexture(RenderTexture2D target) {
    if target.id > 0 {
        if target.texture.id > 0 {
            rlUnloadTexture(target.texture.id);
        }
        rlUnloadFramebuffer(target.id);
    }
}
// Update GPU texture with new data
// NOTE 1: pixels data must match texture.format
// NOTE 2: pixels data must contain at least as many pixels as texture
void UpdateTexture(Texture2D texture, void* pixels) {
    rlUpdateTexture(texture.id, 0, 0, texture.width, texture.height, texture.format, pixels);
}
// Update GPU texture rectangle with new data
// NOTE 1: pixels data must match texture.format
// NOTE 2: pixels data must contain as many pixels as rec contains
// NOTE 3: rec must fit completely within texture's width and height
void UpdateTextureRec(Texture2D texture, Rectangle rec, void* pixels) {
    rlUpdateTexture(texture.id, cast(i32, rec.x), cast(i32, rec.y), cast(i32, rec.width), cast(i32, rec.height), texture.format, pixels);
}
//------------------------------------------------------------------------------------
// Texture configuration functions
//------------------------------------------------------------------------------------
// Generate GPU mipmaps for a texture
void GenTextureMipmaps(Texture2D* texture) {
    rlGenTextureMipmaps(texture.id, texture.width, texture.height, texture.format, &texture.mipmaps);
}
// Set texture scaling filter mode
void SetTextureFilter(Texture2D texture, i32 filter) {
    switch filter {
        case TEXTURE_FILTER_POINT: {
            {
                if texture.mipmaps > 1 {
                    rlTextureParameters(texture.id, 10241, 9984);
                    rlTextureParameters(texture.id, 10240, 9728);
                } else {
                    rlTextureParameters(texture.id, 10241, 9728);
                    rlTextureParameters(texture.id, 10240, 9728);
                }
            }
        }
        case TEXTURE_FILTER_BILINEAR: {
            {
                if texture.mipmaps > 1 {
                    rlTextureParameters(texture.id, 10241, 9985);
                    rlTextureParameters(texture.id, 10240, 9729);
                } else {
                    rlTextureParameters(texture.id, 10241, 9729);
                    rlTextureParameters(texture.id, 10240, 9729);
                }
            }
        }
        case TEXTURE_FILTER_TRILINEAR: {
            {
                if texture.mipmaps > 1 {
                    rlTextureParameters(texture.id, 10241, 9987);
                    rlTextureParameters(texture.id, 10240, 9729);
                } else {
                                        rlTextureParameters(texture.id, 10241, 9729);
                    rlTextureParameters(texture.id, 10240, 9729);
                }
            }
        }
        case TEXTURE_FILTER_ANISOTROPIC_4X: {
            rlTextureParameters(texture.id, 12288, 4);
        }
        case TEXTURE_FILTER_ANISOTROPIC_8X: {
            rlTextureParameters(texture.id, 12288, 8);
        }
        case TEXTURE_FILTER_ANISOTROPIC_16X: {
            rlTextureParameters(texture.id, 12288, 16);
        }
        default: {
        }
    }
}
// Set texture wrapping mode
void SetTextureWrap(Texture2D texture, i32 wrap) {
    switch wrap {
        case TEXTURE_WRAP_REPEAT: {
            {
                rlTextureParameters(texture.id, 10242, 10497);
                rlTextureParameters(texture.id, 10243, 10497);
            }
        }
        case TEXTURE_WRAP_CLAMP: {
            {
                rlTextureParameters(texture.id, 10242, 33071);
                rlTextureParameters(texture.id, 10243, 33071);
            }
        }
        case TEXTURE_WRAP_MIRROR_REPEAT: {
            {
                rlTextureParameters(texture.id, 10242, 33648);
                rlTextureParameters(texture.id, 10243, 33648);
            }
        }
        case TEXTURE_WRAP_MIRROR_CLAMP: {
            {
                rlTextureParameters(texture.id, 10242, 34626);
                rlTextureParameters(texture.id, 10243, 34626);
            }
        }
        default: {
        }
    }
}
//------------------------------------------------------------------------------------
// Texture drawing functions
//------------------------------------------------------------------------------------
// Draw a texture
void DrawTexture(Texture2D texture, i32 posX, i32 posY, Color tint) {
    DrawTextureEx(texture, Vector2{cast(f32, posX), cast(f32, posY)}, 0.0f, 1.0f, tint);
}
// Draw a texture with position defined as Vector2
void DrawTextureV(Texture2D texture, Vector2 position, Color tint) {
    DrawTextureEx(texture, position, 0.0f, 1.0f, tint);
}
// Draw a texture with extended parameters
void DrawTextureEx(Texture2D texture, Vector2 position, f32 rotation, f32 scale, Color tint) {
    var source = Rectangle{0.0f, 0.0f, cast(f32, texture.width), cast(f32, texture.height)};
    var dest = Rectangle{position.x, position.y, cast(f32, texture.width) * scale, cast(f32, texture.height) * scale};
    var origin = Vector2{0.0f, 0.0f};
    DrawTexturePro(texture, source, dest, origin, rotation, tint);
}
// Draw a part of a texture (defined by a rectangle)
void DrawTextureRec(Texture2D texture, Rectangle source, Vector2 position, Color tint) {
    var dest = Rectangle{position.x, position.y, fabsf(source.width), fabsf(source.height)};
    var origin = Vector2{0.0f, 0.0f};
    DrawTexturePro(texture, source, dest, origin, 0.0f, tint);
}
// Draw a part of a texture (defined by a rectangle) with 'pro' parameters
// NOTE: origin is relative to destination rectangle size
void DrawTexturePro(Texture2D texture, Rectangle source, Rectangle dest, Vector2 origin, f32 rotation, Color tint) {
    if texture.id > 0 {
        var width = cast(f32, texture.width);
        var height = cast(f32, texture.height);
        bool flipX = false;
        if source.width < 0.0f {
            flipX = true;
            source.width *= cast(f32, -1);
        }
        if source.height < 0.0f {
            source.y -= source.height;
        }
        if dest.width < 0.0f {
            dest.width *= cast(f32, -1);
        }
        if dest.height < 0.0f {
            dest.height *= cast(f32, -1);
        }
        Vector2 topLeft;
        Vector2 topRight;
        Vector2 bottomLeft;
        Vector2 bottomRight;
        if rotation == 0.0f {
            f32 x = dest.x - origin.x;
            f32 y = dest.y - origin.y;
            topLeft = Vector2{x, y};
            topRight = Vector2{x + dest.width, y};
            bottomLeft = Vector2{x, y + dest.height};
            bottomRight = Vector2{x + dest.width, y + dest.height};
        } else {
            f32 sinRotation = sinf(rotation * (3.141592f / 180.0f));
            f32 cosRotation = cosf(rotation * (3.141592f / 180.0f));
            f32 x = dest.x;
            f32 y = dest.y;
            f32 dx = -origin.x;
            f32 dy = -origin.y;
            topLeft.x = x + dx * cosRotation - dy * sinRotation;
            topLeft.y = y + dx * sinRotation + dy * cosRotation;
            topRight.x = x + (dx + dest.width) * cosRotation - dy * sinRotation;
            topRight.y = y + (dx + dest.width) * sinRotation + dy * cosRotation;
            bottomLeft.x = x + dx * cosRotation - (dy + dest.height) * sinRotation;
            bottomLeft.y = y + dx * sinRotation + (dy + dest.height) * cosRotation;
            bottomRight.x = x + (dx + dest.width) * cosRotation - (dy + dest.height) * sinRotation;
            bottomRight.y = y + (dx + dest.width) * sinRotation + (dy + dest.height) * cosRotation;
        }
        rlSetTexture(texture.id);
        rlBegin(7);
        rlColor4ub(tint.r, tint.g, tint.b, tint.a);
        rlNormal3f(0.0f, 0.0f, 1.0f);
        if flipX != 0 {
            rlTexCoord2f((source.x + source.width) / width, source.y / height);
        } else {
            rlTexCoord2f(source.x / width, source.y / height);
        }
        rlVertex2f(topLeft.x, topLeft.y);
        if flipX != 0 {
            rlTexCoord2f((source.x + source.width) / width, (source.y + source.height) / height);
        } else {
            rlTexCoord2f(source.x / width, (source.y + source.height) / height);
        }
        rlVertex2f(bottomLeft.x, bottomLeft.y);
        if flipX != 0 {
            rlTexCoord2f(source.x / width, (source.y + source.height) / height);
        } else {
            rlTexCoord2f((source.x + source.width) / width, (source.y + source.height) / height);
        }
        rlVertex2f(bottomRight.x, bottomRight.y);
        if flipX != 0 {
            rlTexCoord2f(source.x / width, source.y / height);
        } else {
            rlTexCoord2f((source.x + source.width) / width, source.y / height);
        }
        rlVertex2f(topRight.x, topRight.y);
        rlEnd();
        rlSetTexture(0);
    }
}
// Draw a texture (or part of it) that stretches or shrinks nicely using n-patch info
void DrawTextureNPatch(Texture2D texture, NPatchInfo nPatchInfo, Rectangle dest, Vector2 origin, f32 rotation, Color tint) {
    if texture.id > 0 {
        var width = cast(f32, texture.width);
        var height = cast(f32, texture.height);
        f32 patchWidth = cast(i32, dest.width) <= 0 ? 0.0f : dest.width;
        f32 patchHeight = cast(i32, dest.height) <= 0 ? 0.0f : dest.height;
        if nPatchInfo.source.width < 0.0f {
            nPatchInfo.source.x -= nPatchInfo.source.width;
        }
        if nPatchInfo.source.height < 0.0f {
            nPatchInfo.source.y -= nPatchInfo.source.height;
        }
        if nPatchInfo.layout == NPATCH_THREE_PATCH_HORIZONTAL {
            patchHeight = nPatchInfo.source.height;
        }
        if nPatchInfo.layout == NPATCH_THREE_PATCH_VERTICAL {
            patchWidth = nPatchInfo.source.width;
        }
        bool drawCenter = true;
        bool drawMiddle = true;
        var leftBorder = cast(f32, nPatchInfo.left);
        var topBorder = cast(f32, nPatchInfo.top);
        var rightBorder = cast(f32, nPatchInfo.right);
        var bottomBorder = cast(f32, nPatchInfo.bottom);
        if patchWidth <= leftBorder + rightBorder && nPatchInfo.layout != NPATCH_THREE_PATCH_VERTICAL {
            drawCenter = false;
            leftBorder = leftBorder / (leftBorder + rightBorder) * patchWidth;
            rightBorder = patchWidth - leftBorder;
        }
        if patchHeight <= topBorder + bottomBorder && nPatchInfo.layout != NPATCH_THREE_PATCH_HORIZONTAL {
            drawMiddle = false;
            topBorder = topBorder / (topBorder + bottomBorder) * patchHeight;
            bottomBorder = patchHeight - topBorder;
        }
        Vector2 vertA;
        Vector2 vertB;
        Vector2 vertC;
        Vector2 vertD;
        vertA.x = 0.0f;
        vertA.y = 0.0f;
        vertB.x = leftBorder;
        vertB.y = topBorder;
        vertC.x = patchWidth - rightBorder;
        vertC.y = patchHeight - bottomBorder;
        vertD.x = patchWidth;
        vertD.y = patchHeight;
        Vector2 coordA;
        Vector2 coordB;
        Vector2 coordC;
        Vector2 coordD;
        coordA.x = nPatchInfo.source.x / width;
        coordA.y = nPatchInfo.source.y / height;
        coordB.x = (nPatchInfo.source.x + leftBorder) / width;
        coordB.y = (nPatchInfo.source.y + topBorder) / height;
        coordC.x = (nPatchInfo.source.x + nPatchInfo.source.width - rightBorder) / width;
        coordC.y = (nPatchInfo.source.y + nPatchInfo.source.height - bottomBorder) / height;
        coordD.x = (nPatchInfo.source.x + nPatchInfo.source.width) / width;
        coordD.y = (nPatchInfo.source.y + nPatchInfo.source.height) / height;
        rlSetTexture(texture.id);
        rlPushMatrix();
        rlTranslatef(dest.x, dest.y, 0.0f);
        rlRotatef(rotation, 0.0f, 0.0f, 1.0f);
        rlTranslatef(-origin.x, -origin.y, 0.0f);
        rlBegin(7);
        rlColor4ub(tint.r, tint.g, tint.b, tint.a);
        rlNormal3f(0.0f, 0.0f, 1.0f);
        if nPatchInfo.layout == NPATCH_NINE_PATCH {
            rlTexCoord2f(coordA.x, coordB.y);
            rlVertex2f(vertA.x, vertB.y);
            rlTexCoord2f(coordB.x, coordB.y);
            rlVertex2f(vertB.x, vertB.y);
            rlTexCoord2f(coordB.x, coordA.y);
            rlVertex2f(vertB.x, vertA.y);
            rlTexCoord2f(coordA.x, coordA.y);
            rlVertex2f(vertA.x, vertA.y);
            if drawCenter != 0 {
                rlTexCoord2f(coordB.x, coordB.y);
                rlVertex2f(vertB.x, vertB.y);
                rlTexCoord2f(coordC.x, coordB.y);
                rlVertex2f(vertC.x, vertB.y);
                rlTexCoord2f(coordC.x, coordA.y);
                rlVertex2f(vertC.x, vertA.y);
                rlTexCoord2f(coordB.x, coordA.y);
                rlVertex2f(vertB.x, vertA.y);
            }
            rlTexCoord2f(coordC.x, coordB.y);
            rlVertex2f(vertC.x, vertB.y);
            rlTexCoord2f(coordD.x, coordB.y);
            rlVertex2f(vertD.x, vertB.y);
            rlTexCoord2f(coordD.x, coordA.y);
            rlVertex2f(vertD.x, vertA.y);
            rlTexCoord2f(coordC.x, coordA.y);
            rlVertex2f(vertC.x, vertA.y);
            if drawMiddle != 0 {
                rlTexCoord2f(coordA.x, coordC.y);
                rlVertex2f(vertA.x, vertC.y);
                rlTexCoord2f(coordB.x, coordC.y);
                rlVertex2f(vertB.x, vertC.y);
                rlTexCoord2f(coordB.x, coordB.y);
                rlVertex2f(vertB.x, vertB.y);
                rlTexCoord2f(coordA.x, coordB.y);
                rlVertex2f(vertA.x, vertB.y);
                if drawCenter != 0 {
                    rlTexCoord2f(coordB.x, coordC.y);
                    rlVertex2f(vertB.x, vertC.y);
                    rlTexCoord2f(coordC.x, coordC.y);
                    rlVertex2f(vertC.x, vertC.y);
                    rlTexCoord2f(coordC.x, coordB.y);
                    rlVertex2f(vertC.x, vertB.y);
                    rlTexCoord2f(coordB.x, coordB.y);
                    rlVertex2f(vertB.x, vertB.y);
                }
                rlTexCoord2f(coordC.x, coordC.y);
                rlVertex2f(vertC.x, vertC.y);
                rlTexCoord2f(coordD.x, coordC.y);
                rlVertex2f(vertD.x, vertC.y);
                rlTexCoord2f(coordD.x, coordB.y);
                rlVertex2f(vertD.x, vertB.y);
                rlTexCoord2f(coordC.x, coordB.y);
                rlVertex2f(vertC.x, vertB.y);
            }
            rlTexCoord2f(coordA.x, coordD.y);
            rlVertex2f(vertA.x, vertD.y);
            rlTexCoord2f(coordB.x, coordD.y);
            rlVertex2f(vertB.x, vertD.y);
            rlTexCoord2f(coordB.x, coordC.y);
            rlVertex2f(vertB.x, vertC.y);
            rlTexCoord2f(coordA.x, coordC.y);
            rlVertex2f(vertA.x, vertC.y);
            if drawCenter != 0 {
                rlTexCoord2f(coordB.x, coordD.y);
                rlVertex2f(vertB.x, vertD.y);
                rlTexCoord2f(coordC.x, coordD.y);
                rlVertex2f(vertC.x, vertD.y);
                rlTexCoord2f(coordC.x, coordC.y);
                rlVertex2f(vertC.x, vertC.y);
                rlTexCoord2f(coordB.x, coordC.y);
                rlVertex2f(vertB.x, vertC.y);
            }
            rlTexCoord2f(coordC.x, coordD.y);
            rlVertex2f(vertC.x, vertD.y);
            rlTexCoord2f(coordD.x, coordD.y);
            rlVertex2f(vertD.x, vertD.y);
            rlTexCoord2f(coordD.x, coordC.y);
            rlVertex2f(vertD.x, vertC.y);
            rlTexCoord2f(coordC.x, coordC.y);
            rlVertex2f(vertC.x, vertC.y);
        } else if nPatchInfo.layout == NPATCH_THREE_PATCH_VERTICAL {
            rlTexCoord2f(coordA.x, coordB.y);
            rlVertex2f(vertA.x, vertB.y);
            rlTexCoord2f(coordD.x, coordB.y);
            rlVertex2f(vertD.x, vertB.y);
            rlTexCoord2f(coordD.x, coordA.y);
            rlVertex2f(vertD.x, vertA.y);
            rlTexCoord2f(coordA.x, coordA.y);
            rlVertex2f(vertA.x, vertA.y);
            if drawCenter != 0 {
                rlTexCoord2f(coordA.x, coordC.y);
                rlVertex2f(vertA.x, vertC.y);
                rlTexCoord2f(coordD.x, coordC.y);
                rlVertex2f(vertD.x, vertC.y);
                rlTexCoord2f(coordD.x, coordB.y);
                rlVertex2f(vertD.x, vertB.y);
                rlTexCoord2f(coordA.x, coordB.y);
                rlVertex2f(vertA.x, vertB.y);
            }
            rlTexCoord2f(coordA.x, coordD.y);
            rlVertex2f(vertA.x, vertD.y);
            rlTexCoord2f(coordD.x, coordD.y);
            rlVertex2f(vertD.x, vertD.y);
            rlTexCoord2f(coordD.x, coordC.y);
            rlVertex2f(vertD.x, vertC.y);
            rlTexCoord2f(coordA.x, coordC.y);
            rlVertex2f(vertA.x, vertC.y);
        } else if nPatchInfo.layout == NPATCH_THREE_PATCH_HORIZONTAL {
            rlTexCoord2f(coordA.x, coordD.y);
            rlVertex2f(vertA.x, vertD.y);
            rlTexCoord2f(coordB.x, coordD.y);
            rlVertex2f(vertB.x, vertD.y);
            rlTexCoord2f(coordB.x, coordA.y);
            rlVertex2f(vertB.x, vertA.y);
            rlTexCoord2f(coordA.x, coordA.y);
            rlVertex2f(vertA.x, vertA.y);
            if drawCenter != 0 {
                rlTexCoord2f(coordB.x, coordD.y);
                rlVertex2f(vertB.x, vertD.y);
                rlTexCoord2f(coordC.x, coordD.y);
                rlVertex2f(vertC.x, vertD.y);
                rlTexCoord2f(coordC.x, coordA.y);
                rlVertex2f(vertC.x, vertA.y);
                rlTexCoord2f(coordB.x, coordA.y);
                rlVertex2f(vertB.x, vertA.y);
            }
            rlTexCoord2f(coordC.x, coordD.y);
            rlVertex2f(vertC.x, vertD.y);
            rlTexCoord2f(coordD.x, coordD.y);
            rlVertex2f(vertD.x, vertD.y);
            rlTexCoord2f(coordD.x, coordA.y);
            rlVertex2f(vertD.x, vertA.y);
            rlTexCoord2f(coordC.x, coordA.y);
            rlVertex2f(vertC.x, vertA.y);
        }
        rlEnd();
        rlPopMatrix();
        rlSetTexture(0);
    }
}
// Check if two colors are equal
bool ColorIsEqual(Color col1, Color col2) {
    bool result = false;
    if col1.r == col2.r && col1.g == col2.g && col1.b == col2.b && col1.a == col2.a {
        result = true;
    }
    return result;
}
// Get color with alpha applied, alpha goes from 0.0f to 1.0f
Color Fade(Color color, f32 alpha) {
    Color result = color;
    if alpha < 0.0f {
        alpha = 0.0f;
    } else if alpha > 1.0f {
        alpha = 1.0f;
    }
    result.a = cast(u8, 255.0f * alpha);
    return result;
}
// Get hexadecimal value for a Color
i32 ColorToInt(Color color) {
    i32 result = 0;
    result = cast(i32, cast(u32, color.r) << 24 | cast(u32, color.g) << 16 | cast(u32, color.b) << 8 | cast(u32, color.a));
    return result;
}
// Get color normalized as float [0..1]
Vector4 ColorNormalize(Color color) {
    Vector4 result;
    result.x = cast(f32, color.r) / 255.0f;
    result.y = cast(f32, color.g) / 255.0f;
    result.z = cast(f32, color.b) / 255.0f;
    result.w = cast(f32, color.a) / 255.0f;
    return result;
}
// Get color from normalized values [0..1]
Color ColorFromNormalized(Vector4 normalized) {
    Color result;
    result.r = cast(u8, normalized.x * 255.0f);
    result.g = cast(u8, normalized.y * 255.0f);
    result.b = cast(u8, normalized.z * 255.0f);
    result.a = cast(u8, normalized.w * 255.0f);
    return result;
}
// Get HSV values for a Color
// NOTE: Hue is returned as degrees [0..360]
Vector3 ColorToHSV(Color color) {
    Vector3 hsv;
    var rgb = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
    f32 min = 0.0f;
    f32 max = 0.0f;
    f32 delta = 0.0f;
    min = rgb.x < rgb.y ? rgb.x : rgb.y;
    min = min < rgb.z ? min : rgb.z;
    max = rgb.x > rgb.y ? rgb.x : rgb.y;
    max = max > rgb.z ? max : rgb.z;
    hsv.z = max;
    delta = max - min;
    if delta < 0.000010f {
        hsv.y = 0.0f;
        hsv.x = 0.0f;
        return hsv;
    }
    if max > 0.0f {
        hsv.y = delta / max;
    } else {
        hsv.y = 0.0f;
        hsv.x = NAN;
        return hsv;
    }
    if rgb.x >= max {
        hsv.x = (rgb.y - rgb.z) / delta;
    } else {
        if rgb.y >= max {
            hsv.x = 2.0f + (rgb.z - rgb.x) / delta;
        } else {
            hsv.x = 4.0f + (rgb.x - rgb.y) / delta;
        }
    }
    hsv.x *= 60.0f;
    if hsv.x < 0.0f {
        hsv.x += 360.0f;
    }
    return hsv;
}
// Get a Color from HSV values
// Implementation reference: https://en.wikipedia.org/wiki/HSL_and_HSV#Alternative_HSV_conversion
// NOTE: Color->HSV->Color conversion will not yield exactly the same color due to rounding errors
// Hue is provided in degrees: [0..360]
// Saturation/Value are provided normalized: [0.0f..1.0f]
Color ColorFromHSV(f32 hue, f32 saturation, f32 value) {
    var color = Color{0, 0, 0, 255};
    f32 k = fmodf(5.0f + hue / 60.0f, 6.0f);
    f32 t = 4.0f - k;
    k = t < k ? t : k;
    k = k < 1.0f ? k : 1.0f;
    k = k > 0.0f ? k : 0.0f;
    color.r = cast(u8, (value - value * saturation * k) * 255.0f);
    k = fmodf(3.0f + hue / 60.0f, 6.0f);
    t = 4.0f - k;
    k = t < k ? t : k;
    k = k < 1.0f ? k : 1.0f;
    k = k > 0.0f ? k : 0.0f;
    color.g = cast(u8, (value - value * saturation * k) * 255.0f);
    k = fmodf(1.0f + hue / 60.0f, 6.0f);
    t = 4.0f - k;
    k = t < k ? t : k;
    k = k < 1.0f ? k : 1.0f;
    k = k > 0.0f ? k : 0.0f;
    color.b = cast(u8, (value - value * saturation * k) * 255.0f);
    return color;
}
// Get color multiplied with another color
Color ColorTint(Color color, Color tint) {
    Color result = color;
    var r = cast(u8, cast(i32, color.r) * cast(i32, tint.r) / 255);
    var g = cast(u8, cast(i32, color.g) * cast(i32, tint.g) / 255);
    var b = cast(u8, cast(i32, color.b) * cast(i32, tint.b) / 255);
    var a = cast(u8, cast(i32, color.a) * cast(i32, tint.a) / 255);
    result.r = r;
    result.g = g;
    result.b = b;
    result.a = a;
    return result;
}
// Get color with brightness correction, brightness factor goes from -1.0f to 1.0f
Color ColorBrightness(Color color, f32 factor) {
    Color result = color;
    if factor > 1.0f {
        factor = 1.0f;
    } else if factor < -1.0f {
        factor = -1.0f;
    }
    var red = cast(f32, color.r);
    var green = cast(f32, color.g);
    var blue = cast(f32, color.b);
    if factor < 0.0f {
        factor = 1.0f + factor;
        red *= factor;
        green *= factor;
        blue *= factor;
    } else {
        red = (255.0f - red) * factor + red;
        green = (255.0f - green) * factor + green;
        blue = (255.0f - blue) * factor + blue;
    }
    result.r = cast(u8, red);
    result.g = cast(u8, green);
    result.b = cast(u8, blue);
    return result;
}
// Get color with contrast correction
// NOTE: Contrast values between -1.0f and 1.0f
Color ColorContrast(Color color, f32 contrast) {
    Color result = color;
    if contrast < -1.0f {
        contrast = -1.0f;
    } else if contrast > 1.0f {
        contrast = 1.0f;
    }
    contrast = 1.0f + contrast;
    contrast *= contrast;
    f32 pR = cast(f32, color.r) / 255.0f;
    pR -= 0.500000f;
    pR *= contrast;
    pR += 0.500000f;
    pR *= 255.0f;
    if pR < 0.0f {
        pR = 0.0f;
    } else if pR > 255.0f {
        pR = 255.0f;
    }
    f32 pG = cast(f32, color.g) / 255.0f;
    pG -= 0.500000f;
    pG *= contrast;
    pG += 0.500000f;
    pG *= 255.0f;
    if pG < 0.0f {
        pG = 0.0f;
    } else if pG > 255.0f {
        pG = 255.0f;
    }
    f32 pB = cast(f32, color.b) / 255.0f;
    pB -= 0.500000f;
    pB *= contrast;
    pB += 0.500000f;
    pB *= 255.0f;
    if pB < 0.0f {
        pB = 0.0f;
    } else if pB > 255.0f {
        pB = 255.0f;
    }
    result.r = cast(u8, pR);
    result.g = cast(u8, pG);
    result.b = cast(u8, pB);
    return result;
}
// Get color with alpha applied, alpha goes from 0.0f to 1.0f
Color ColorAlpha(Color color, f32 alpha) {
    Color result = color;
    if alpha < 0.0f {
        alpha = 0.0f;
    } else if alpha > 1.0f {
        alpha = 1.0f;
    }
    result.a = cast(u8, 255.0f * alpha);
    return result;
}
// Get src alpha-blended into dst color with tint
Color ColorAlphaBlend(Color dst, Color src, Color tint) {
    var result = Color{255, 255, 255, 255};
    src.r = cast(u8, cast(u32, src.r) * (cast(u32, tint.r) + 1) >> 8);
    src.g = cast(u8, cast(u32, src.g) * (cast(u32, tint.g) + 1) >> 8);
    src.b = cast(u8, cast(u32, src.b) * (cast(u32, tint.b) + 1) >> 8);
    src.a = cast(u8, cast(u32, src.a) * (cast(u32, tint.a) + 1) >> 8);
    if src.a == 0 {
        result = dst;
    } else if src.a == 255 {
        result = src;
    } else {
        u32 alpha = cast(u32, src.a) + 1;
        result.a = cast(u8, alpha * 256 + cast(u32, dst.a) * (256 - alpha) >> 8);
        if result.a > 0 {
            result.r = cast(u8, (cast(u32, src.r) * alpha * 256 + cast(u32, dst.r) * cast(u32, dst.a) * (256 - alpha)) / result.a >> 8);
            result.g = cast(u8, (cast(u32, src.g) * alpha * 256 + cast(u32, dst.g) * cast(u32, dst.a) * (256 - alpha)) / result.a >> 8);
            result.b = cast(u8, (cast(u32, src.b) * alpha * 256 + cast(u32, dst.b) * cast(u32, dst.a) * (256 - alpha)) / result.a >> 8);
        }
    }
    when defined(COLORALPHABLEND_FLOAT) {
        if src.a == 0 {
            result = dst;
        } else if src.a == 255 {
            result = src;
        } else {
            Vector4 fdst = ColorNormalize(dst);
            Vector4 fsrc = ColorNormalize(src);
            Vector4 ftint = ColorNormalize(tint);
            Vector4 fout;
            fout.w = fsrc.w + fdst.w * (1.0f - fsrc.w);
            if fout.w > 0.0f {
                fout.x = (fsrc.x * fsrc.w + fdst.x * fdst.w * (1.0f - fsrc.w)) / fout.w;
                fout.y = (fsrc.y * fsrc.w + fdst.y * fdst.w * (1.0f - fsrc.w)) / fout.w;
                fout.z = (fsrc.z * fsrc.w + fdst.z * fdst.w * (1.0f - fsrc.w)) / fout.w;
            }
            result = Color{cast(u8, fout.x * 255.0f), cast(u8, fout.y * 255.0f), cast(u8, fout.z * 255.0f), cast(u8, fout.w * 255.0f)};
        }
    }
    return result;
}
// Get color lerp interpolation between two colors, factor [0.0f..1.0f]
Color ColorLerp(Color color1, Color color2, f32 factor) {
    Color color;
    if factor < 0.0f {
        factor = 0.0f;
    } else if factor > 1.0f {
        factor = 1.0f;
    }
    color.r = cast(u8, (1.0f - factor) * cast(f32, color1.r) + factor * cast(f32, color2.r));
    color.g = cast(u8, (1.0f - factor) * cast(f32, color1.g) + factor * cast(f32, color2.g));
    color.b = cast(u8, (1.0f - factor) * cast(f32, color1.b) + factor * cast(f32, color2.b));
    color.a = cast(u8, (1.0f - factor) * cast(f32, color1.a) + factor * cast(f32, color2.a));
    return color;
}
// Get a Color struct from hexadecimal value
Color GetColor(u32 hexValue) {
    Color color;
    color.r = cast(u8, hexValue >> 24) & 255;
    color.g = cast(u8, hexValue >> 16) & 255;
    color.b = cast(u8, hexValue >> 8) & 255;
    color.a = cast(u8, hexValue) & 255;
    return color;
}
// Get color from a pixel from certain format
Color GetPixelColor(void* srcPtr, i32 format_var) {
    Color color;
    switch format_var {
        case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
            color = Color{cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[0], 255};
        }
        case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
            color = Color{cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[1]};
        }
        case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
            {
                color.r = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 11) * 255 / 31);
                color.g = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 5 & 63) * 255 / 63);
                color.b = cast(u8, (cast(u16*, srcPtr)[0] & 31) * 255 / 31);
                color.a = 255;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
            {
                color.r = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 11) * 255 / 31);
                color.g = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 6 & 31) * 255 / 31);
                color.b = cast(u8, (cast(u16*, srcPtr)[0] & 31) * 255 / 31);
                color.a = cast(u8, (cast(u16*, srcPtr)[0] & 1) != 0 ? 255 : 0);
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
            {
                color.r = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 12) * 255 / 15);
                color.g = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 8 & 15) * 255 / 15);
                color.b = cast(u8, (cast(i32, cast(u16*, srcPtr)[0]) >> 4 & 15) * 255 / 15);
                color.a = cast(u8, (cast(u16*, srcPtr)[0] & 15) * 255 / 15);
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
            color = Color{cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[1], cast(u8*, srcPtr)[2], cast(u8*, srcPtr)[3]};
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
            color = Color{cast(u8*, srcPtr)[0], cast(u8*, srcPtr)[1], cast(u8*, srcPtr)[2], 255};
        }
        case PIXELFORMAT_UNCOMPRESSED_R32: {
            {
                color.r = cast(u8, cast(f32*, srcPtr)[0] * 255.0f);
                color.g = cast(u8, cast(f32*, srcPtr)[0] * 255.0f);
                color.b = cast(u8, cast(f32*, srcPtr)[0] * 255.0f);
                color.a = 255;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
            {
                color.r = cast(u8, cast(f32*, srcPtr)[0] * 255.0f);
                color.g = cast(u8, cast(f32*, srcPtr)[1] * 255.0f);
                color.b = cast(u8, cast(f32*, srcPtr)[2] * 255.0f);
                color.a = 255;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
            {
                color.r = cast(u8, cast(f32*, srcPtr)[0] * 255.0f);
                color.g = cast(u8, cast(f32*, srcPtr)[1] * 255.0f);
                color.b = cast(u8, cast(f32*, srcPtr)[2] * 255.0f);
                color.a = cast(u8, cast(f32*, srcPtr)[3] * 255.0f);
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R16: {
            {
                color.r = cast(u8, HalfToFloat(cast(u16*, srcPtr)[0]) * 255.0f);
                color.g = cast(u8, HalfToFloat(cast(u16*, srcPtr)[0]) * 255.0f);
                color.b = cast(u8, HalfToFloat(cast(u16*, srcPtr)[0]) * 255.0f);
                color.a = 255;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
            {
                color.r = cast(u8, HalfToFloat(cast(u16*, srcPtr)[0]) * 255.0f);
                color.g = cast(u8, HalfToFloat(cast(u16*, srcPtr)[1]) * 255.0f);
                color.b = cast(u8, HalfToFloat(cast(u16*, srcPtr)[2]) * 255.0f);
                color.a = 255;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
            {
                color.r = cast(u8, HalfToFloat(cast(u16*, srcPtr)[0]) * 255.0f);
                color.g = cast(u8, HalfToFloat(cast(u16*, srcPtr)[1]) * 255.0f);
                color.b = cast(u8, HalfToFloat(cast(u16*, srcPtr)[2]) * 255.0f);
                color.a = cast(u8, HalfToFloat(cast(u16*, srcPtr)[3]) * 255.0f);
            }
        }
        default: {
        }
    }
    return color;
}
// Set pixel color formatted into destination pointer
void SetPixelColor(void* dstPtr, Color color, i32 format_var) {
    switch format_var {
        case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                var gray = cast(u8, (coln.x * 0.298999f + coln.y * 0.586999f + coln.z * 0.114000f) * 255.0f);
                cast(u8*, dstPtr)[0] = gray;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                var gray = cast(u8, (coln.x * 0.298999f + coln.y * 0.586999f + coln.z * 0.114000f) * 255.0f);
                cast(u8*, dstPtr)[0] = gray;
                cast(u8*, dstPtr)[1] = color.a;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
            {
                var coln = Vector3{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f};
                var r = cast(u8, round(coln.x * 31.0f));
                var g = cast(u8, round(coln.y * 63.0f));
                var b = cast(u8, round(coln.z * 31.0f));
                cast(u16*, dstPtr)[0] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 5 | cast(u16, b));
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
            {
                var coln = Vector4{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f, cast(f32, color.a) / 255.0f};
                var r = cast(u8, round(coln.x * 31.0f));
                var g = cast(u8, round(coln.y * 31.0f));
                var b = cast(u8, round(coln.z * 31.0f));
                var a = cast(u8, coln.w > cast(f32, 50) / 255.0f ? 1 : 0);
                cast(u16*, dstPtr)[0] = cast(u16, cast(u16, r) << 11 | cast(u16, g) << 6 | cast(u16, b) << 1 | cast(u16, a));
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
            {
                var coln = Vector4{cast(f32, color.r) / 255.0f, cast(f32, color.g) / 255.0f, cast(f32, color.b) / 255.0f, cast(f32, color.a) / 255.0f};
                var r = cast(u8, round(coln.x * 15.0f));
                var g = cast(u8, round(coln.y * 15.0f));
                var b = cast(u8, round(coln.z * 15.0f));
                var a = cast(u8, round(coln.w * 15.0f));
                cast(u16*, dstPtr)[0] = cast(u16, cast(u16, r) << 12 | cast(u16, g) << 8 | cast(u16, b) << 4 | cast(u16, a));
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
            {
                cast(u8*, dstPtr)[0] = color.r;
                cast(u8*, dstPtr)[1] = color.g;
                cast(u8*, dstPtr)[2] = color.b;
            }
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
            {
                cast(u8*, dstPtr)[0] = color.r;
                cast(u8*, dstPtr)[1] = color.g;
                cast(u8*, dstPtr)[2] = color.b;
                cast(u8*, dstPtr)[3] = color.a;
            }
        }
        default: {
        }
    }
}
// Get pixel data size in bytes for certain format
// NOTE: Size can be requested for Image or Texture data
i32 GetPixelDataSize(i32 width, i32 height, i32 format_var) {
    i32 dataSize = 0;
    i32 bpp = 0;
    switch format_var {
        case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
            bpp = 8;
        }
        case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA, PIXELFORMAT_UNCOMPRESSED_R5G6B5, PIXELFORMAT_UNCOMPRESSED_R5G5B5A1, PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
            bpp = 16;
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
            bpp = 32;
        }
        case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
            bpp = 24;
        }
        case PIXELFORMAT_UNCOMPRESSED_R32: {
            bpp = 32;
        }
        case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
            bpp = 32 * 3;
        }
        case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
            bpp = 32 * 4;
        }
        case PIXELFORMAT_UNCOMPRESSED_R16: {
            bpp = 16;
        }
        case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
            bpp = 16 * 3;
        }
        case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
            bpp = 16 * 4;
        }
        case PIXELFORMAT_COMPRESSED_DXT1_RGB, PIXELFORMAT_COMPRESSED_DXT1_RGBA, PIXELFORMAT_COMPRESSED_ETC1_RGB, PIXELFORMAT_COMPRESSED_ETC2_RGB, PIXELFORMAT_COMPRESSED_PVRT_RGB, PIXELFORMAT_COMPRESSED_PVRT_RGBA: {
            bpp = 4;
        }
        case PIXELFORMAT_COMPRESSED_DXT3_RGBA, PIXELFORMAT_COMPRESSED_DXT5_RGBA, PIXELFORMAT_COMPRESSED_ETC2_EAC_RGBA, PIXELFORMAT_COMPRESSED_ASTC_4x4_RGBA: {
            bpp = 8;
        }
        case PIXELFORMAT_COMPRESSED_ASTC_8x8_RGBA: {
            bpp = 2;
        }
        default: {
        }
    }
    f64 bytesPerPixel = cast(f64, bpp) / 8.0;
    dataSize = cast(i32, bytesPerPixel * cast(f64, width) * cast(f64, height));
    if width < 4 && height < 4 {
        if format_var >= PIXELFORMAT_COMPRESSED_DXT1_RGB && format_var < PIXELFORMAT_COMPRESSED_DXT3_RGBA {
            dataSize = 8;
        } else if format_var >= PIXELFORMAT_COMPRESSED_DXT3_RGBA && format_var < PIXELFORMAT_COMPRESSED_ASTC_8x8_RGBA {
            dataSize = 16;
        }
    }
    return dataSize;
}
//----------------------------------------------------------------------------------
// Module Internal Functions Definition
//----------------------------------------------------------------------------------
// Convert half-float (stored as unsigned short) to float
// REF: https://stackoverflow.com/questions/1659440/32-bit-to-16-bit-floating-point-conversion/60047308#60047308
private { f32 HalfToFloat(u16 x) {
    f32 result = 0.0f;
    __anon_struct_54 uni;
    var e = cast(u32, cast(i32, x & 31744) >> 10);
    var m = cast(u32, cast(i32, x & 1023) << 13);
    uni.fm = cast(f32, m);
    u32 v = uni.ui >> 23;
    uni.ui = cast(u32, cast(u32, cast(u32, cast(i32, x & 32768) << 16) | cast(u32, e != 0) * (e + 112 << 23 | m)) | cast(u32, e == 0 & m != 0) * (v - 37 << 23 | m << 150 - v & 8380416));
    result = uni.fm;
    return result;
}}
// Convert float to half-float (stored as unsigned short)
private { u16 FloatToHalf(f32 x) {
    u16 result = 0;
    __anon_struct_55 uni;
    uni.fm = x;
    u32 b = uni.ui + 4096;
    u32 e = (b & 2139095040) >> 23;
    u32 m = b & 8388607;
    result = cast(u16, (b & 2147483648) >> 16 | cast(u32, e > 112) * (e - 112 << 10 & 31744 | m >> 13) | cast(u32, e < 113 & e > 101) * ((8384512 + m >> 125 - e) + 1 >> 1) | cast(u32, cast(i32, e > 143) * 32767));
    return result;
}}
// Get pixel data from image as Vector4 array (float normalized)
private { Vector4* LoadImageDataNormalized(Image image) {
    var pixels = new(Vector4[image.width * image.height]);
    if image.format >= PIXELFORMAT_COMPRESSED_DXT1_RGB {
            } else {
        {
            i32 i = 0;
            i32 k = 0;
            for ; i < image.width * image.height; i++ {
                switch image.format {
                    case PIXELFORMAT_UNCOMPRESSED_GRAYSCALE: {
                        {
                            pixels[i].x = cast(f32, cast(u8*, image.data)[i]) / 255.0f;
                            pixels[i].y = cast(f32, cast(u8*, image.data)[i]) / 255.0f;
                            pixels[i].z = cast(f32, cast(u8*, image.data)[i]) / 255.0f;
                            pixels[i].w = 1.0f;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_GRAY_ALPHA: {
                        {
                            pixels[i].x = cast(f32, cast(u8*, image.data)[k]) / 255.0f;
                            pixels[i].y = cast(f32, cast(u8*, image.data)[k]) / 255.0f;
                            pixels[i].z = cast(f32, cast(u8*, image.data)[k]) / 255.0f;
                            pixels[i].w = cast(f32, cast(u8*, image.data)[k + 1]) / 255.0f;
                            k += 2;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R5G5B5A1: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            pixels[i].x = cast(f32, cast(i32, pixel & 63488) >> 11) * (1.0f / 31.0f);
                            pixels[i].y = cast(f32, cast(i32, pixel & 1984) >> 6) * (1.0f / 31.0f);
                            pixels[i].z = cast(f32, cast(i32, pixel & 62) >> 1) * (1.0f / 31.0f);
                            pixels[i].w = (pixel & 1) == 0 ? 0.0f : 1.0f;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R5G6B5: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            pixels[i].x = cast(f32, cast(i32, pixel & 63488) >> 11) * (1.0f / 31.0f);
                            pixels[i].y = cast(f32, cast(i32, pixel & 2016) >> 5) * (1.0f / 63.0f);
                            pixels[i].z = cast(f32, pixel & 31) * (1.0f / 31.0f);
                            pixels[i].w = 1.0f;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R4G4B4A4: {
                        {
                            u16 pixel = cast(u16*, image.data)[i];
                            pixels[i].x = cast(f32, cast(i32, pixel & 61440) >> 12) * (1.0f / 15.0f);
                            pixels[i].y = cast(f32, cast(i32, pixel & 3840) >> 8) * (1.0f / 15.0f);
                            pixels[i].z = cast(f32, cast(i32, pixel & 240) >> 4) * (1.0f / 15.0f);
                            pixels[i].w = cast(f32, pixel & 15) * (1.0f / 15.0f);
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R8G8B8A8: {
                        {
                            pixels[i].x = cast(f32, cast(u8*, image.data)[k]) / 255.0f;
                            pixels[i].y = cast(f32, cast(u8*, image.data)[k + 1]) / 255.0f;
                            pixels[i].z = cast(f32, cast(u8*, image.data)[k + 2]) / 255.0f;
                            pixels[i].w = cast(f32, cast(u8*, image.data)[k + 3]) / 255.0f;
                            k += 4;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R8G8B8: {
                        {
                            pixels[i].x = cast(f32, cast(u8*, image.data)[k]) / 255.0f;
                            pixels[i].y = cast(f32, cast(u8*, image.data)[k + 1]) / 255.0f;
                            pixels[i].z = cast(f32, cast(u8*, image.data)[k + 2]) / 255.0f;
                            pixels[i].w = 1.0f;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32: {
                        {
                            pixels[i].x = cast(f32*, image.data)[k];
                            pixels[i].y = 0.0f;
                            pixels[i].z = 0.0f;
                            pixels[i].w = 1.0f;
                            k += 1;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32G32B32: {
                        {
                            pixels[i].x = cast(f32*, image.data)[k];
                            pixels[i].y = cast(f32*, image.data)[k + 1];
                            pixels[i].z = cast(f32*, image.data)[k + 2];
                            pixels[i].w = 1.0f;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R32G32B32A32: {
                        {
                            pixels[i].x = cast(f32*, image.data)[k];
                            pixels[i].y = cast(f32*, image.data)[k + 1];
                            pixels[i].z = cast(f32*, image.data)[k + 2];
                            pixels[i].w = cast(f32*, image.data)[k + 3];
                            k += 4;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16: {
                        {
                            pixels[i].x = HalfToFloat(cast(u16*, image.data)[k]);
                            pixels[i].y = 0.0f;
                            pixels[i].z = 0.0f;
                            pixels[i].w = 1.0f;
                            k += 1;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16G16B16: {
                        {
                            pixels[i].x = HalfToFloat(cast(u16*, image.data)[k]);
                            pixels[i].y = HalfToFloat(cast(u16*, image.data)[k + 1]);
                            pixels[i].z = HalfToFloat(cast(u16*, image.data)[k + 2]);
                            pixels[i].w = 1.0f;
                            k += 3;
                        }
                    }
                    case PIXELFORMAT_UNCOMPRESSED_R16G16B16A16: {
                        {
                            pixels[i].x = HalfToFloat(cast(u16*, image.data)[k]);
                            pixels[i].y = HalfToFloat(cast(u16*, image.data)[k + 1]);
                            pixels[i].z = HalfToFloat(cast(u16*, image.data)[k + 2]);
                            pixels[i].w = HalfToFloat(cast(u16*, image.data)[k + 3]);
                            k += 4;
                        }
                    }
                    default: {
                    }
                }
            }
        }
    }
    return pixels;
}}
