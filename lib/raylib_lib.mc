when defined(STBI_NO_PNG) {
} else {
private { stbi__uint16* stbi__convert_format16(stbi__uint16* data, i32 img_n, i32 req_comp, u32 x, u32 y) {
        i32 i;
        i32 j;
        stbi__uint16* good;
        if req_comp == img_n {
            return data;
        }
        assert(req_comp >= 1 && req_comp <= 4);
        good = cast(stbi__uint16*, stbi__malloc(cast(u32, req_comp) * x * y * 2));
        if good == null {
            free(data);
            return cast(stbi__uint16*, cast(u8*, cast(u64, stbi__err("outofmem") != 0 ? null : null)));
        }
        for j = 0; j < cast(i32, y); ++j {
            stbi__uint16* src = data + cast(u32, j) * x * cast(u32, img_n);
            stbi__uint16* dest = good + cast(u32, j) * x * cast(u32, req_comp);
            switch img_n * 8 + req_comp {
                case 1 * 8 + 2: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        dest[1] = 65535;
                        src += 1;
                        dest += 2;
                    }
                }
                case 1 * 8 + 3: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        src += 1;
                        dest += 3;
                    }
                }
                case 1 * 8 + 4: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        dest[3] = 65535;
                        src += 1;
                        dest += 4;
                    }
                }
                case 2 * 8 + 1: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        src += 2;
                        dest += 1;
                    }
                }
                case 2 * 8 + 3: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        src += 2;
                        dest += 3;
                    }
                }
                case 2 * 8 + 4: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        dest[3] = src[1];
                        src += 2;
                        dest += 4;
                    }
                }
                case 3 * 8 + 4: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        dest[1] = src[1];
                        dest[2] = src[2];
                        dest[3] = 65535;
                        src += 3;
                        dest += 4;
                    }
                }
                case 3 * 8 + 1: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y_16(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        src += 3;
                        dest += 1;
                    }
                }
                case 3 * 8 + 2: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y_16(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        dest[1] = 65535;
                        src += 3;
                        dest += 2;
                    }
                }
                case 4 * 8 + 1: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y_16(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        src += 4;
                        dest += 1;
                    }
                }
                case 4 * 8 + 2: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y_16(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        dest[1] = src[3];
                        src += 4;
                        dest += 2;
                    }
                }
                case 4 * 8 + 3: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        dest[1] = src[1];
                        dest[2] = src[2];
                        src += 4;
                        dest += 3;
                    }
                }
                default: {
                    assert(0);
                    free(data);
                    free(good);
                    return cast(stbi__uint16*, cast(u8*, cast(u64, stbi__err("unsupported") != 0 ? null : null)));
                }
