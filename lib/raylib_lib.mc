// Show mouse cursor
void ShowCursor() {
    glfwSetInputMode(platform.handle, 208897, 212993);
    CORE.Input.Mouse.cursorHidden = false;
}
// Hide mouse cursor
void HideCursor() {
    glfwSetInputMode(platform.handle, 208897, 212994);
    CORE.Input.Mouse.cursorHidden = true;
}
// Enable cursor (unlock cursor)
void EnableCursor() {
    glfwSetInputMode(platform.handle, 208897, 212993);
    SetMousePosition(cast(i32, CORE.Window.screen.width / 2), cast(i32, CORE.Window.screen.height / 2));
    if glfwRawMouseMotionSupported() != 0 {
        glfwSetInputMode(platform.handle, 208901, 0);
    }
    CORE.Input.Mouse.cursorHidden = false;
    CORE.Input.Mouse.cursorLocked = false;
}
// Disable cursor (lock cursor)
void DisableCursor() {
    SetMousePosition(cast(i32, CORE.Window.screen.width / 2), cast(i32, CORE.Window.screen.height / 2));
    glfwSetInputMode(platform.handle, 208897, 212995);
    if glfwRawMouseMotionSupported() != 0 {
        glfwSetInputMode(platform.handle, 208901, 1);
    }
    CORE.Input.Mouse.cursorHidden = true;
    CORE.Input.Mouse.cursorLocked = true;
}
// Swap back buffer with front buffer (screen drawing)
void SwapScreenBuffer() {
    glfwSwapBuffers(platform.handle);
}
//----------------------------------------------------------------------------------
// Module Functions Definition: Misc
//----------------------------------------------------------------------------------
// Get elapsed time measure in seconds since InitTimer()
f64 GetTime() {
    f64 time = glfwGetTime();
    return time;
}
// Open URL with default system browser (if available)
// NOTE: This function is only safe to use if you control the URL given
// A user could craft a malicious string performing another action
// Only call this function yourself not with user input or make sure to check the string yourself
// REF: https://github.com/raysan5/raylib/issues/686
void OpenURL(u8* url) {
    if strchr(url, 39) != null {
            } else {
        var cmd = new(u8[strlen(url) + 32]);
        when os(windows) {
            sprintf(cmd, "explorer \"%s\"", url);
        }
        when os(linux) {
            sprintf(cmd, "xdg-open '%s'", url);
        }
        when os(macos) || os(ios) {
            sprintf(cmd, "open '%s'", url);
        }
        i32 result = system(cmd);
        if result == -1 {
                    }
        free(cmd);
    }
}
