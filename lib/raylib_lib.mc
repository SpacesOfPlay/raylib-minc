// Module Functions Definition: Inputs
//----------------------------------------------------------------------------------
// Set internal gamepad mappings
i32 SetGamepadMappings(u8* mappings) {
    return glfwUpdateGamepadMappings(mappings);
}
// Set gamepad vibration
void SetGamepadVibration(i32 gamepad, f32 leftMotor, f32 rightMotor, f32 duration) {
    }
// Set mouse position XY
void SetMousePosition(i32 x, i32 y) {
    CORE.Input.Mouse.currentPosition = Vector2{cast(f32, x), cast(f32, y)};
    CORE.Input.Mouse.previousPosition = CORE.Input.Mouse.currentPosition;
    glfwSetCursorPos(platform.handle, CORE.Input.Mouse.currentPosition.x, CORE.Input.Mouse.currentPosition.y);
}
// Set mouse cursor
void SetMouseCursor(i32 cursor) {
    CORE.Input.Mouse.cursor = cursor;
    if cursor == MOUSE_CURSOR_DEFAULT {
        glfwSetCursor(platform.handle, null);
    } else {
        glfwSetCursor(platform.handle, glfwCreateStandardCursor(221184 + cursor));
    }
}
// Get physical key name
u8* GetKeyName(i32 key) {
    return glfwGetKeyName(key, glfwGetKeyScancode(key));
}
// Register all input events
void PollInputEvents() {
    UpdateGestures();
    CORE.Input.Keyboard.keyPressedQueueCount = 0;
    CORE.Input.Keyboard.charPressedQueueCount = 0;
    CORE.Input.Gamepad.lastButtonPressed = GAMEPAD_BUTTON_UNKNOWN;
    for i32 i = 0; i < 512; i++ {
        CORE.Input.Keyboard.previousKeyState[i] = CORE.Input.Keyboard.currentKeyState[i];
        CORE.Input.Keyboard.keyRepeatInFrame[i] = 0;
    }
    for i32 i = 0; i < 8; i++ {
        CORE.Input.Mouse.previousButtonState[i] = CORE.Input.Mouse.currentButtonState[i];
    }
    CORE.Input.Mouse.previousWheelMove = CORE.Input.Mouse.currentWheelMove;
    CORE.Input.Mouse.currentWheelMove = Vector2{0.0f, 0.0f};
    CORE.Input.Mouse.previousPosition = CORE.Input.Mouse.currentPosition;
    for i32 i = 0; i < 8; i++ {
        CORE.Input.Touch.previousTouchState[i] = CORE.Input.Touch.currentTouchState[i];
    }
    CORE.Input.Touch.position[0] = CORE.Input.Mouse.currentPosition;
    for i32 i = 0; i < 4; i++ {
        if glfwJoystickPresent(i) != 0 {
            CORE.Input.Gamepad.ready[i] = true;
        } else {
            CORE.Input.Gamepad.ready[i] = false;
        }
    }
    for i32 i = 0; i < 4; i++ {
        if CORE.Input.Gamepad.ready[i] != 0 {
            for i32 k = 0; k < 32; k++ {
                CORE.Input.Gamepad.previousButtonState[i][k] = CORE.Input.Gamepad.currentButtonState[i][k];
            }
            GLFWgamepadstate state;
            i32 result = glfwGetGamepadState(i, &state);
            if result == 0 {
                state.axes[GAMEPAD_AXIS_LEFT_TRIGGER] = -1.0f;
                state.axes[GAMEPAD_AXIS_RIGHT_TRIGGER] = -1.0f;
            }
            u8* buttons = state.buttons;
            for i32 k = 0; buttons != null && k < 32; k++ {
                i32 button = -1;
                switch k {
                    case 3: {
                        button = GAMEPAD_BUTTON_RIGHT_FACE_UP;
                    }
                    case 1: {
                        button = GAMEPAD_BUTTON_RIGHT_FACE_RIGHT;
                    }
                    case 0: {
                        button = GAMEPAD_BUTTON_RIGHT_FACE_DOWN;
                    }
                    case 2: {
                        button = GAMEPAD_BUTTON_RIGHT_FACE_LEFT;
                    }
                    case 4: {
                        button = GAMEPAD_BUTTON_LEFT_TRIGGER_1;
                    }
                    case 5: {
                        button = GAMEPAD_BUTTON_RIGHT_TRIGGER_1;
                    }
                    case 6: {
                        button = GAMEPAD_BUTTON_MIDDLE_LEFT;
                    }
                    case 8: {
                        button = GAMEPAD_BUTTON_MIDDLE;
                    }
                    case 7: {
                        button = GAMEPAD_BUTTON_MIDDLE_RIGHT;
                    }
                    case 11: {
                        button = GAMEPAD_BUTTON_LEFT_FACE_UP;
                    }
                    case 12: {
                        button = GAMEPAD_BUTTON_LEFT_FACE_RIGHT;
                    }
                    case 13: {
                        button = GAMEPAD_BUTTON_LEFT_FACE_DOWN;
                    }
                    case 14: {
                        button = GAMEPAD_BUTTON_LEFT_FACE_LEFT;
                    }
                    case 9: {
                        button = GAMEPAD_BUTTON_LEFT_THUMB;
                    }
                    case 10: {
                        button = GAMEPAD_BUTTON_RIGHT_THUMB;
                    }
                    default: {
                    }
                }
                if button != -1 {
                    if buttons[k] == 1 {
                        CORE.Input.Gamepad.currentButtonState[i][button] = 1;
                        CORE.Input.Gamepad.lastButtonPressed = button;
                    } else {
                        CORE.Input.Gamepad.currentButtonState[i][button] = 0;
                    }
                }
            }
            f32* axes = state.axes;
            for i32 k = 0; axes != null && k < 5 + 1; k++ {
                CORE.Input.Gamepad.axisState[i][k] = axes[k];
            }
            if CORE.Input.Gamepad.axisState[i][GAMEPAD_AXIS_LEFT_TRIGGER] > 0.100000f {
                CORE.Input.Gamepad.currentButtonState[i][GAMEPAD_BUTTON_LEFT_TRIGGER_2] = 1;
                CORE.Input.Gamepad.lastButtonPressed = GAMEPAD_BUTTON_LEFT_TRIGGER_2;
            } else {
                CORE.Input.Gamepad.currentButtonState[i][GAMEPAD_BUTTON_LEFT_TRIGGER_2] = 0;
            }
            if CORE.Input.Gamepad.axisState[i][GAMEPAD_AXIS_RIGHT_TRIGGER] > 0.100000f {
                CORE.Input.Gamepad.currentButtonState[i][GAMEPAD_BUTTON_RIGHT_TRIGGER_2] = 1;
                CORE.Input.Gamepad.lastButtonPressed = GAMEPAD_BUTTON_RIGHT_TRIGGER_2;
            } else {
                CORE.Input.Gamepad.currentButtonState[i][GAMEPAD_BUTTON_RIGHT_TRIGGER_2] = 0;
            }
            CORE.Input.Gamepad.axisCount[i] = 5 + 1;
        }
    }
    CORE.Window.resizedLastFrame = false;
    if CORE.Window.eventWaiting || (CORE.Window.flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) && !((CORE.Window.flags & cast(u32, FLAG_WINDOW_ALWAYS_RUN)) == cast(u32, FLAG_WINDOW_ALWAYS_RUN)) {
        glfwWaitEvents();
        CORE.Time.previous = GetTime();
    } else {
        glfwPollEvents();
    }
    CORE.Window.shouldClose = cast(bool, glfwWindowShouldClose(platform.handle));
    glfwSetWindowShouldClose(platform.handle, 0);
}
//----------------------------------------------------------------------------------
// Module Internal Functions Definition
//----------------------------------------------------------------------------------
// Function wrappers around RL_*ALLOC macros, used by glfwInitAllocator() inside of InitPlatform()
// GLFWallocator expects function pointers with specific signatures to be provided
// REF: https://www.glfw.org/docs/latest/intro_guide.html#init_allocator
private { void* AllocateWrapper(u64 size, void* user) {
    ignore user;
    return calloc(size, cast(u64, 1));
}}
private { void* ReallocateWrapper(void* block, u64 size, void* user) {
    ignore user;
    return realloc(block, size);
}}
private { void DeallocateWrapper(void* block, void* user) {
    ignore user;
    free(block);
}}
// Initialize platform: graphics, inputs and more
i32 InitPlatform() {
    glfwSetErrorCallback(ErrorCallback);
    var allocator = GLFWallocator{.allocate = AllocateWrapper, .reallocate = ReallocateWrapper, .deallocate = DeallocateWrapper, .user = null};
    glfwInitAllocator(&allocator);
    when os(macos) || os(ios) {
        glfwInitHint(331777, 0);
    }
    i32 result = glfwInit();
    if result == 0 {
                return -1;
    }
    glfwDefaultWindowHints();
    glfwWindowHint(131078, 0);
    u32 requestedWindowFlags = CORE.Window.flags;
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIDDEN)) == cast(u32, FLAG_WINDOW_HIDDEN) {
        glfwWindowHint(131076, 0);
    } else {
        glfwWindowHint(131076, 1);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_UNDECORATED)) == cast(u32, FLAG_WINDOW_UNDECORATED) {
        glfwWindowHint(131077, 0);
    } else {
        glfwWindowHint(131077, 1);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_RESIZABLE)) == cast(u32, FLAG_WINDOW_RESIZABLE) {
        glfwWindowHint(131075, 1);
    } else {
        glfwWindowHint(131075, 0);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) {
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MINIMIZED);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MAXIMIZED)) == cast(u32, FLAG_WINDOW_MAXIMIZED) {
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MAXIMIZED);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_UNFOCUSED)) == cast(u32, FLAG_WINDOW_UNFOCUSED) {
        glfwWindowHint(131073, 0);
    } else {
        glfwWindowHint(131073, 1);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_TOPMOST)) == cast(u32, FLAG_WINDOW_TOPMOST) {
        glfwWindowHint(131079, 1);
    } else {
        glfwWindowHint(131079, 0);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_TRANSPARENT)) == cast(u32, FLAG_WINDOW_TRANSPARENT) {
        glfwWindowHint(131082, 1);
    } else {
        glfwWindowHint(131082, 0);
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
        when os(macos) || os(ios) {
            glfwWindowHint(139277, 0);
        }
        glfwWindowHint(139276, 1);
        when os(macos) || os(ios) {
            glfwWindowHint(139277, 1);
        }
    } else {
        glfwWindowHint(139276, 0);
        when os(macos) || os(ios) {
            glfwWindowHint(139277, 0);
        }
    }
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH)) == cast(u32, FLAG_WINDOW_MOUSE_PASSTHROUGH) {
        glfwWindowHint(131085, 1);
    } else {
        glfwWindowHint(131085, 0);
    }
    if (CORE.Window.flags & cast(u32, FLAG_MSAA_4X_HINT)) == cast(u32, FLAG_MSAA_4X_HINT) {
                glfwWindowHint(135181, 4);
    }
    if rlGetVersion() == RL_OPENGL_21 {
        glfwWindowHint(139266, 2);
        glfwWindowHint(139267, 1);
    } else if rlGetVersion() == RL_OPENGL_33 {
        glfwWindowHint(139266, 3);
        glfwWindowHint(139267, 3);
        glfwWindowHint(139272, 204801);
        when os(macos) || os(ios) {
            glfwWindowHint(139270, 1);
        } else {
            glfwWindowHint(139270, 0);
        }
    } else if rlGetVersion() == RL_OPENGL_43 {
        glfwWindowHint(139266, 4);
        glfwWindowHint(139267, 3);
        glfwWindowHint(139272, 204801);
        glfwWindowHint(139270, 0);
    } else if rlGetVersion() == RL_OPENGL_ES_20 {
        glfwWindowHint(139266, 2);
        glfwWindowHint(139267, 0);
        glfwWindowHint(139265, 196610);
        glfwWindowHint(139275, 221186);
    } else if rlGetVersion() == RL_OPENGL_ES_30 {
        glfwWindowHint(139266, 3);
        glfwWindowHint(139267, 0);
        glfwWindowHint(139265, 196610);
        glfwWindowHint(139275, 221186);
    }
    glfwSetJoystickCallback(null);
    if CORE.Window.screen.width == 0 || CORE.Window.screen.height == 0 {
        CORE.Window.flags |= cast(u32, FLAG_FULLSCREEN_MODE);
    }
    if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) {
        GLFWmonitor* monitor = glfwGetPrimaryMonitor();
        if monitor == null {
                        return -1;
        }
        GLFWvidmode* mode = glfwGetVideoMode(monitor);
        CORE.Window.display.width = cast(u32, mode.width);
        CORE.Window.display.height = cast(u32, mode.height);
        if CORE.Window.screen.width == 0 || CORE.Window.screen.height == 0 {
            CORE.Window.previousScreen.width = 800;
            CORE.Window.previousScreen.height = 450;
            CORE.Window.previousPosition.x = cast(i32, CORE.Window.display.width / 2 - cast(u32, 800 / 2));
            CORE.Window.previousPosition.y = cast(i32, CORE.Window.display.height / 2 - cast(u32, 450 / 2));
            if CORE.Window.screen.width == 0 {
                CORE.Window.screen.width = CORE.Window.display.width;
            }
            if CORE.Window.screen.height == 0 {
                CORE.Window.screen.height = CORE.Window.display.height;
            }
        } else {
            CORE.Window.previousScreen = CORE.Window.screen;
            CORE.Window.screen = CORE.Window.display;
        }
        platform.handle = glfwCreateWindow(cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height), CORE.Window.title != null ? CORE.Window.title : " ", monitor, null);
        if platform.handle == null {
            glfwTerminate();
                        return -1;
        }
    } else {
        if CORE.Window.screen.width == 0 {
            CORE.Window.screen.width = 1;
        }
        if CORE.Window.screen.height == 0 {
            CORE.Window.screen.height = 1;
        }
        platform.handle = glfwCreateWindow(cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height), CORE.Window.title != null ? CORE.Window.title : " ", null, null);
        if platform.handle == null {
            glfwTerminate();
                        return -1;
        }
        i32 monitorCount = 0;
        i32 monitorIndex = GetCurrentMonitor();
        GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
        if monitorIndex < monitorCount {
            GLFWmonitor* monitor = monitors[monitorIndex];
            GLFWvidmode* mode = glfwGetVideoMode(monitor);
            CORE.Window.display.width = cast(u32, mode.width);
            CORE.Window.display.height = cast(u32, mode.height);
            if CORE.Window.screen.width == 0 {
                CORE.Window.screen.width = CORE.Window.display.width;
            }
            if CORE.Window.screen.height == 0 {
                CORE.Window.screen.height = CORE.Window.display.height;
            }
            glfwSetWindowSize(platform.handle, cast(i32, CORE.Window.screen.width), cast(i32, CORE.Window.screen.height));
        } else {
            glfwTerminate();
                        return -1;
        }
        CORE.Window.render.width = CORE.Window.screen.width;
        CORE.Window.render.height = CORE.Window.screen.height;
    }
    glfwMakeContextCurrent(platform.handle);
    result = glfwGetError(null);
    if result != 65546 && result != 65544 {
        CORE.Window.ready = true;
    }
    if CORE.Window.ready != 0 {
        glfwSwapInterval(0);
        if (CORE.Window.flags & cast(u32, FLAG_VSYNC_HINT)) == cast(u32, FLAG_VSYNC_HINT) {
            glfwSwapInterval(1);
                    }
        if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
            Vector2 scaleDpi = GetWindowScaleDPI();
            CORE.Window.render.width = cast(u32, cast(i32, cast(f32, CORE.Window.screen.width) * scaleDpi.x));
            CORE.Window.render.height = cast(u32, cast(i32, cast(f32, CORE.Window.screen.height) * scaleDpi.y));
            CORE.Window.screenScale = MatrixScale(scaleDpi.x, scaleDpi.y, 1.0f);
            when !(os(macos) || os(ios)) {
                if glfwGetPlatform() == 393219 {
                    i32 fbWidth = 0;
                    i32 fbHeight = 0;
                    glfwGetFramebufferSize(platform.handle, &fbWidth, &fbHeight);
                    CORE.Window.render.width = cast(u32, fbWidth);
                    CORE.Window.render.height = cast(u32, fbHeight);
                } else {
                    SetMouseScale(1.0f / scaleDpi.x, 1.0f / scaleDpi.y);
                    glfwSetWindowSize(platform.handle, cast(i32, CORE.Window.render.width), cast(i32, CORE.Window.render.height));
                }
            }
        } else {
            CORE.Window.render = CORE.Window.screen;
        }
        CORE.Window.currentFbo = CORE.Window.render;
                                                i32 monitorCount = 0;
        i32 monitorIndex = GetCurrentMonitor();
        GLFWmonitor** monitors = glfwGetMonitors(&monitorCount);
        GLFWmonitor* monitor = monitors[monitorIndex];
        i32 monitorX = 0;
        i32 monitorY = 0;
        i32 monitorWidth = 0;
        i32 monitorHeight = 0;
        glfwGetMonitorWorkarea(monitor, &monitorX, &monitorY, &monitorWidth, &monitorHeight);
        when os(macos) || os(ios) {
            CORE.Window.position.x = cast(i32, cast(u32, monitorX) + (cast(u32, monitorWidth) - CORE.Window.screen.width) / 2);
            CORE.Window.position.y = cast(i32, cast(u32, monitorY) + (cast(u32, monitorHeight) - CORE.Window.screen.height) / 2);
        } else {
            CORE.Window.position.x = cast(i32, cast(u32, monitorX) + (cast(u32, monitorWidth) - CORE.Window.render.width) / 2);
            CORE.Window.position.y = cast(i32, cast(u32, monitorY) + (cast(u32, monitorHeight) - CORE.Window.render.height) / 2);
        }
        SetWindowPosition(CORE.Window.position.x, CORE.Window.position.y);
        if (CORE.Window.flags & cast(u32, FLAG_WINDOW_MINIMIZED)) == cast(u32, FLAG_WINDOW_MINIMIZED) {
            MinimizeWindow();
        }
    } else {
                return -1;
    }
    SetWindowState(requestedWindowFlags);
    rlLoadExtensions(cast(void*, glfwGetProcAddress));
    glfwSetWindowSizeCallback(platform.handle, WindowSizeCallback);
    glfwSetFramebufferSizeCallback(platform.handle, FramebufferSizeCallback);
    glfwSetWindowPosCallback(platform.handle, WindowPosCallback);
    glfwSetWindowMaximizeCallback(platform.handle, WindowMaximizeCallback);
    glfwSetWindowIconifyCallback(platform.handle, WindowIconifyCallback);
    glfwSetWindowFocusCallback(platform.handle, WindowFocusCallback);
    glfwSetDropCallback(platform.handle, WindowDropCallback);
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
        glfwSetWindowContentScaleCallback(platform.handle, WindowContentScaleCallback);
    }
    glfwSetKeyCallback(platform.handle, KeyCallback);
    glfwSetCharCallback(platform.handle, CharCallback);
    glfwSetMouseButtonCallback(platform.handle, MouseButtonCallback);
    glfwSetCursorPosCallback(platform.handle, MouseCursorPosCallback);
    glfwSetScrollCallback(platform.handle, MouseScrollCallback);
    glfwSetCursorEnterCallback(platform.handle, CursorEnterCallback);
    glfwSetJoystickCallback(JoystickCallback);
    glfwSetInputMode(platform.handle, 208900, 1);
    for i32 i = 0; i < 4; i++ {
        if glfwJoystickPresent(i) != 0 {
            CORE.Input.Gamepad.ready[i] = true;
            CORE.Input.Gamepad.axisCount[i] = 5 + 1;
            strncpy(CORE.Input.Gamepad.name[i], glfwGetJoystickName(i), cast(u64, 128 - 1));
        }
    }
    InitTimer();
    CORE.Storage.basePath = GetWorkingDirectory();
    u8* glfwPlatform = "";
    switch glfwGetPlatform() {
        case 393217: {
            glfwPlatform = "Win32";
        }
        case 393218: {
            glfwPlatform = "Cocoa";
        }
        case 393219: {
            glfwPlatform = "Wayland";
        }
        case 393220: {
            glfwPlatform = "X11";
        }
        case 393221: {
            glfwPlatform = "Null";
        }
        default: {
        }
    }
        return 0;
}
// Close platform
void ClosePlatform() {
    glfwDestroyWindow(platform.handle);
    glfwTerminate();
    when os(windows) {
        timeEndPeriod(1);
    }
}
//----------------------------------------------------------------------------------
// Module Internal Functions Definition
// NOTE: Those functions are only required for current platform
//----------------------------------------------------------------------------------
// GLFW3: Error callback, runs on GLFW3 error
private { void ErrorCallback(i32 error, u8* description) {
    }}
// GLFW3: Window size change callback, runs when window is resized
// NOTE: Window resizing not enabled by default, use SetConfigFlags()
private { void WindowSizeCallback(GLFWwindow* window, i32 width, i32 height) {
}}
// GLFW3: Framebuffer size change callback, runs when framebuffer is resized
// WARNING: If FLAG_WINDOW_HIGHDPI is set, WindowContentScaleCallback() is called before this function
private { void FramebufferSizeCallback(GLFWwindow* window, i32 width, i32 height) {
    if width == 0 || height == 0 {
        return;
    }
    SetupViewport(width, height);
    CORE.Window.render.width = cast(u32, width);
    CORE.Window.render.height = cast(u32, height);
    CORE.Window.currentFbo = CORE.Window.render;
    CORE.Window.resizedLastFrame = true;
    if (CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE) {
        CORE.Window.screen.width = cast(u32, width);
        CORE.Window.screen.height = cast(u32, height);
        CORE.Window.screenScale = MatrixScale(1.0f, 1.0f, 1.0f);
        SetMouseScale(1.0f, 1.0f);
    } else {
        if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) {
            Vector2 scaleDpi = GetWindowScaleDPI();
            CORE.Window.screen.width = cast(u32, cast(i32, cast(f32, width) / scaleDpi.x));
            CORE.Window.screen.height = cast(u32, cast(i32, cast(f32, height) / scaleDpi.y));
            CORE.Window.screenScale = MatrixScale(scaleDpi.x, scaleDpi.y, 1.0f);
            SetMouseScale(1.0f / scaleDpi.x, 1.0f / scaleDpi.y);
        } else {
            CORE.Window.screen.width = cast(u32, width);
            CORE.Window.screen.height = cast(u32, height);
        }
    }
}}
// GLFW3: Window content scale callback, runs on monitor content scale change detected
// WARNING: If FLAG_WINDOW_HIGHDPI is not set, this function is not called
private { void WindowContentScaleCallback(GLFWwindow* window, f32 scalex, f32 scaley) {
    CORE.Window.render.width = cast(u32, cast(i32, cast(f32, CORE.Window.screen.width) * scalex));
    CORE.Window.render.height = cast(u32, cast(i32, cast(f32, CORE.Window.screen.height) * scaley));
    CORE.Window.currentFbo = CORE.Window.render;
    CORE.Window.screenScale = MatrixScale(scalex, scaley, 1.0f);
    SetMouseScale(1.0f / scalex, 1.0f / scaley);
}}
// GLFW3: Window position callback, runs when window position changes
private { void WindowPosCallback(GLFWwindow* window, i32 x, i32 y) {
    CORE.Window.position.x = x;
    CORE.Window.position.y = y;
}}
// GLFW3: Window iconify callback, runs when window is minimized/restored
private { void WindowIconifyCallback(GLFWwindow* window, i32 iconified) {
    if iconified != 0 {
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_MINIMIZED);
    } else {
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MINIMIZED);
    }
}}
// GLFW3: Window maximize callback, runs when window is maximized/restored
private { void WindowMaximizeCallback(GLFWwindow* window, i32 maximized) {
    if maximized != 0 {
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_MAXIMIZED);
    } else {
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_MAXIMIZED);
    }
}}
// GLFW3: Window focus callback, runs when window get/lose focus
private { void WindowFocusCallback(GLFWwindow* window, i32 focused) {
    if focused != 0 {
        CORE.Window.flags &= cast(u32, ~FLAG_WINDOW_UNFOCUSED);
    } else {
        CORE.Window.flags |= cast(u32, FLAG_WINDOW_UNFOCUSED);
    }
}}
// GLFW3: Window drop callback, runs when files are dropped into window
private { void WindowDropCallback(GLFWwindow* window, i32 count, u8** paths) {
    if count > 0 {
        if CORE.Window.dropFileCount > 0 {
            for u32 i = 0; i < CORE.Window.dropFileCount; i++ {
                free(CORE.Window.dropFilepaths[i]);
            }
            free(CORE.Window.dropFilepaths);
            CORE.Window.dropFileCount = 0;
            CORE.Window.dropFilepaths = null;
        }
        CORE.Window.dropFileCount = cast(u32, count);
        CORE.Window.dropFilepaths = new(u8*[CORE.Window.dropFileCount]);
        for u32 i = 0; i < CORE.Window.dropFileCount; i++ {
            CORE.Window.dropFilepaths[i] = new(u8[4096]);
            strncpy(CORE.Window.dropFilepaths[i], paths[i], cast(u64, 4096 - 1));
        }
    }
}}
// GLFW3: Keyboard callback, runs on key pressed
private { void KeyCallback(GLFWwindow* window, i32 key, i32 scancode, i32 action, i32 mods) {
    if key < 0 {
        return;
    }
    if action == 0 {
        CORE.Input.Keyboard.currentKeyState[key] = 0;
    } else if action == 1 {
        CORE.Input.Keyboard.currentKeyState[key] = 1;
    } else if action == 2 {
        CORE.Input.Keyboard.keyRepeatInFrame[key] = 1;
    }
    if key == KEY_CAPS_LOCK && (mods & 16) == 16 || key == KEY_NUM_LOCK && (mods & 32) == 32 {
        CORE.Input.Keyboard.currentKeyState[key] = 1;
    }
    if CORE.Input.Keyboard.keyPressedQueueCount < 16 && action == 1 {
        CORE.Input.Keyboard.keyPressedQueue[CORE.Input.Keyboard.keyPressedQueueCount] = key;
        CORE.Input.Keyboard.keyPressedQueueCount++;
    }
    if key == CORE.Input.Keyboard.exitKey && action == 1 {
        glfwSetWindowShouldClose(platform.handle, 1);
    }
}}
// GLFW3: Char callback, runs on key pressed to get unicode codepoint value
private { void CharCallback(GLFWwindow* window, u32 codepoint) {
    if CORE.Input.Keyboard.charPressedQueueCount < 16 {
        CORE.Input.Keyboard.charPressedQueue[CORE.Input.Keyboard.charPressedQueueCount] = cast(i32, codepoint);
        CORE.Input.Keyboard.charPressedQueueCount++;
    }
}}
// GLFW3: Mouse button callback, runs on mouse button pressed
private { void MouseButtonCallback(GLFWwindow* window, i32 button, i32 action, i32 mods) {
    CORE.Input.Mouse.currentButtonState[button] = cast(u8, action);
    CORE.Input.Touch.currentTouchState[button] = cast(u8, action);
    GestureEvent gestureEvent;
    if CORE.Input.Mouse.currentButtonState[button] == 1 && CORE.Input.Mouse.previousButtonState[button] == 0 {
        gestureEvent.touchAction = TOUCH_ACTION_DOWN;
    } else if CORE.Input.Mouse.currentButtonState[button] == 0 && CORE.Input.Mouse.previousButtonState[button] == 1 {
        gestureEvent.touchAction = TOUCH_ACTION_UP;
    }
    gestureEvent.pointId[0] = 0;
    gestureEvent.pointCount = 1;
    gestureEvent.position[0] = GetMousePosition();
    gestureEvent.position[0].x /= cast(f32, GetScreenWidth());
    gestureEvent.position[0].y /= cast(f32, GetScreenHeight());
    ProcessGestureEvent(gestureEvent);
}}
// GLFW3: Cursor position callback, runs on mouse movement
private { void MouseCursorPosCallback(GLFWwindow* window, f64 x, f64 y) {
    CORE.Input.Mouse.currentPosition.x = cast(f32, x);
    CORE.Input.Mouse.currentPosition.y = cast(f32, y);
    CORE.Input.Touch.position[0] = CORE.Input.Mouse.currentPosition;
    GestureEvent gestureEvent;
    gestureEvent.touchAction = TOUCH_ACTION_MOVE;
    gestureEvent.pointId[0] = 0;
    gestureEvent.pointCount = 1;
    gestureEvent.position[0] = CORE.Input.Touch.position[0];
    gestureEvent.position[0].x /= cast(f32, GetScreenWidth());
    gestureEvent.position[0].y /= cast(f32, GetScreenHeight());
    ProcessGestureEvent(gestureEvent);
}}
// GLFW3: Mouse wheel scroll callback, runs on mouse wheel changes
private { void MouseScrollCallback(GLFWwindow* window, f64 xoffset, f64 yoffset) {
    CORE.Input.Mouse.currentWheelMove = Vector2{cast(f32, xoffset), cast(f32, yoffset)};
}}
// GLFW3: Cursor ennter callback, when cursor enters the window
private { void CursorEnterCallback(GLFWwindow* window, i32 enter) {
    if enter != 0 {
        CORE.Input.Mouse.cursorOnScreen = true;
    } else {
        CORE.Input.Mouse.cursorOnScreen = false;
    }
}}
// GLFW3: Joystick connected/disconnected callback
private { void JoystickCallback(i32 jid, i32 event) {
    if jid < 4 {
        if event == 262145 {
            memset(CORE.Input.Gamepad.name[jid], 0, cast(u64, 128));
            strncpy(CORE.Input.Gamepad.name[jid], glfwGetJoystickName(jid), cast(u64, 128 - 1));
        } else if event == 262146 {
            memset(CORE.Input.Gamepad.name[jid], 0, cast(u64, 128));
        }
    }
}}
when os(windows) {
}
// EOF
