when !(defined(STBI_NO_LINEAR)) {
private { f32* stbi__ldr_to_hdr(stbi_uc* data, i32 x, i32 y, i32 comp) {
        i32 i;
        i32 k;
        i32 n;
        f32* output;
        if data == null {
            return null;
        }
        output = cast(f32*, stbi__malloc_mad4(x, y, comp, cast(i32, sizeof(f32)), 0));
        if output == null {
            free(data);
            return cast(f32*, cast(u64, stbi__err("outofmem") != 0 ? null : null));
        }
        if (comp & 1) != 0 {
            n = comp;
        } else {
            n = comp - 1;
        }
        for i = 0; i < x * y; ++i {
            for k = 0; k < n; ++k {
                output[i * comp + k] = cast(f32, cast(f32, pow(cast(f32, data[i * comp + k]) / 255.0f, stbi__l2h_gamma)) * stbi__l2h_scale);
            }
        }
        if n < comp {
            for i = 0; i < x * y; ++i {
                output[i * comp + n] = cast(f32, data[i * comp + n]) / 255.0f;
            }
        }
        free(data);
        return output;
    }}
}
//////////////////////////////////////////////////////////////////////////////
//
//  "baseline" JPEG/JFIF decoder
//
//    simple implementation
//      - doesn't support delayed output of y-dimension
//      - simple interface (only one output format: 8-bit interleaved RGB)
//      - doesn't try to recover corrupt jpegs
//      - doesn't allow partial loading, loading multiple at once
//      - still fast on x86 (copying globals into locals doesn't help x86)
//      - allocates lots of intermediate memory (full size of all components)
//        - non-interleaved case requires this anyway
//        - allows good upsampling (see next)
//    high-quality
//      - upsampled channels are bilinearly interpolated, even across blocks
//      - quality integer IDCT derived from IJG's 'slow'
//    performance
//      - fast huffman; reasonable integer IDCT
//      - some SIMD kernels for common paths on targets with SSE2/NEON
//      - uses a lot of intermediate memory, could cache poorly
// public domain zlib decode    v0.2  Sean Barrett 2006-11-18
//    simple implementation
//      - all input must be provided in an upfront buffer
//      - all output is written to a single output buffer (can malloc/realloc)
//    performance
//      - fast huffman
when !(defined(STBI_NO_ZLIB)) {
private { i32 stbi__bitreverse16(i32 n) {
        n = (n & 43690) >> 1 | (n & 21845) << 1;
        n = (n & 52428) >> 2 | (n & 13107) << 2;
        n = (n & 61680) >> 4 | (n & 3855) << 4;
        n = (n & 65280) >> 8 | (n & 255) << 8;
        return n;
    }}
private { i32 stbi__bit_reverse(i32 v, i32 bits) {
        assert(bits <= 16);
        return stbi__bitreverse16(v) >> 16 - bits;
    }}
private { i32 stbi__zbuild_huffman(stbi__zhuffman* z, stbi_uc* sizelist, i32 num) {
        i32 i;
        i32 k = 0;
        i32 code;
        i32[16] next_code;
        i32[17] sizes;
        memset(sizes, 0, cast(u64, sizeof(sizes)));
        memset(z.fast, 0, cast(u64, sizeof(z.fast)));
        for i = 0; i < num; ++i {
            ++sizes[sizelist[i]];
        }
        sizes[0] = 0;
        for i = 1; i < 16; ++i {
            if sizes[i] > 1 << i {
                return stbi__err("bad sizes");
            }
        }
        code = 0;
        for i = 1; i < 16; ++i {
            next_code[i] = code;
            z.firstcode[i] = cast(stbi__uint16, code);
            z.firstsymbol[i] = cast(stbi__uint16, k);
            code = code + sizes[i];
            if sizes[i] != 0 {
                if code - 1 >= 1 << i {
                    return stbi__err("bad codelengths");
                }
            }
            z.maxcode[i] = code << 16 - i;
            code <<= 1;
            k += sizes[i];
        }
        z.maxcode[16] = 65536;
        for i = 0; i < num; ++i {
            var s = cast(i32, sizelist[i]);
            if s != 0 {
                var c = cast(i32, next_code[s] - z.firstcode[s] + z.firstsymbol[s]);
                var fastv = cast(stbi__uint16, s << 9 | i);
                z.size[c] = cast(stbi_uc, s);
                z.value[c] = cast(stbi__uint16, i);
                if s <= 9 {
                    i32 j = stbi__bit_reverse(next_code[s], s);
                    while j < 1 << 9 {
                        z.fast[j] = fastv;
                        j += 1 << s;
                    }
                }
                ++next_code[s];
            }
        }
        return 1;
    }}
private { i32 stbi__zeof(stbi__zbuf* z) {
        return z.zbuffer >= z.zbuffer_end;
    }}
private { stbi_uc stbi__zget8(stbi__zbuf* z) {
        return cast(stbi_uc, stbi__zeof(z) != 0 ? 0 : *z.zbuffer++);
    }}
private { void stbi__fill_bits(stbi__zbuf* z) {
        while true {
            if z.code_buffer >= cast(u32, 1 << z.num_bits) {
                z.zbuffer = z.zbuffer_end;
                return;
            }
            z.code_buffer |= cast(u32, stbi__zget8(z)) << cast(u32, z.num_bits);
            z.num_bits += 8;
            if !(z.num_bits <= 24) { break; }
        }
    }}
private { u32 stbi__zreceive(stbi__zbuf* z, i32 n) {
        u32 k;
        if z.num_bits < n {
            stbi__fill_bits(z);
        }
        k = z.code_buffer & cast(u32, (1 << n) - 1);
        z.code_buffer >>= cast(stbi__uint32, n);
        z.num_bits -= n;
        return k;
    }}
private { i32 stbi__zhuffman_decode_slowpath(stbi__zbuf* a, stbi__zhuffman* z) {
        i32 b;
        i32 s;
        i32 k;
        k = stbi__bit_reverse(cast(i32, a.code_buffer), 16);
        for s = 9 + 1; true; ++s {
            if k < z.maxcode[s] {
                break;
            }
        }
        if s >= 16 {
            return -1;
        }
        b = cast(i32, (k >> 16 - s) - z.firstcode[s] + z.firstsymbol[s]);
        if b >= 288 {
            return -1;
        }
        if cast(i32, z.size[b]) != s {
            return -1;
        }
        a.code_buffer >>= cast(stbi__uint32, s);
        a.num_bits -= s;
        return cast(i32, z.value[b]);
    }}
private { i32 stbi__zhuffman_decode(stbi__zbuf* a, stbi__zhuffman* z) {
        i32 b;
        i32 s;
        if a.num_bits < 16 {
            if stbi__zeof(a) != 0 {
                if a.hit_zeof_once == 0 {
                    a.hit_zeof_once = 1;
                    a.num_bits += 16;
                } else {
                    return -1;
                }
            } else {
                stbi__fill_bits(a);
            }
        }
        b = cast(i32, z.fast[a.code_buffer & cast(u32, (1 << 9) - 1)]);
        if b != 0 {
            s = b >> 9;
            a.code_buffer >>= cast(stbi__uint32, s);
            a.num_bits -= s;
            return b & 511;
        }
        return stbi__zhuffman_decode_slowpath(a, z);
    }}
private { i32 stbi__zexpand(stbi__zbuf* z, u8* zout, i32 n) {
        u8* q;
        u32 cur;
        u32 limit;
        u32 old_limit;
        z.zout = zout;
        if z.z_expandable == 0 {
            return stbi__err("output buffer limit");
        }
        cur = cast(u32, cast(i64, z.zout - z.zout_start));
        old_limit = cast(u32, cast(i64, z.zout_end - z.zout_start));
        limit = old_limit;
        if UINT_MAX - cur < cast(u32, n) {
            return stbi__err("outofmem");
        }
        while cur + cast(u32, n) > limit {
            if limit > cast(u32, UINT_MAX / 2) {
                return stbi__err("outofmem");
            }
            limit *= 2;
        }
        q = cast(u8*, realloc(z.zout_start, cast(u64, limit)));
        ignore sizeof(old_limit);
        if q == null {
            return stbi__err("outofmem");
        }
        z.zout_start = q;
        z.zout = q + cur;
        z.zout_end = q + limit;
