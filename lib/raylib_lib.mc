                                }
                            }
                        }
                        break case;
                    }
                }
                case (cast(u32, 73) << 24) + (cast(u32, 68) << 16) + (cast(u32, 65) << 8) + cast(u32, 84): {
                    {
                        if first != 0 {
                            return stbi__err("first not IHDR");
                        }
                        if pal_img_n && !pal_len {
                            return stbi__err("no PLTE");
                        }
                        if scan == STBI__SCAN_header {
                            if pal_img_n != 0 {
