                            return stbi__err("first not IHDR");
                        }
                        if c.length > cast(u32, 256 * 3) {
                            return stbi__err("invalid PLTE");
                        }
                        pal_len = c.length / 3;
                        if pal_len * 3 != c.length {
                            return stbi__err("invalid PLTE");
                        }
