//----------------------------------------------------------------------------------
// Module Functions Definition
//----------------------------------------------------------------------------------
// Draw a line in 3D world space
void DrawLine3D(Vector3 startPos, Vector3 endPos, Color color) {
    rlBegin(1);
    rlColor4ub(color.r, color.g, color.b, color.a);
    rlVertex3f(startPos.x, startPos.y, startPos.z);
    rlVertex3f(endPos.x, endPos.y, endPos.z);
    rlEnd();
}
// Draw a point in 3D space, actually a small line
// WARNING: OpenGL ES 2.0 does not support point mode drawing
void DrawPoint3D(Vector3 position, Color color) {
    rlPushMatrix();
    rlTranslatef(position.x, position.y, position.z);
    rlBegin(1);
    rlColor4ub(color.r, color.g, color.b, color.a);
    rlVertex3f(0.0f, 0.0f, 0.0f);
    rlVertex3f(0.0f, 0.0f, 0.100000f);
    rlEnd();
    rlPopMatrix();
}
// Draw a circle in 3D world space
void DrawCircle3D(Vector3 center, f32 radius, Vector3 rotationAxis, f32 rotationAngle, Color color) {
    rlPushMatrix();
    rlTranslatef(center.x, center.y, center.z);
    rlRotatef(rotationAngle, rotationAxis.x, rotationAxis.y, rotationAxis.z);
    rlBegin(1);
    for i32 i = 0; i < 360; i += 10 {
        rlColor4ub(color.r, color.g, color.b, color.a);
        rlVertex3f(sinf(3.141592f / 180.0f * cast(f32, i)) * radius, cosf(3.141592f / 180.0f * cast(f32, i)) * radius, 0.0f);
        rlVertex3f(sinf(3.141592f / 180.0f * cast(f32, i + 10)) * radius, cosf(3.141592f / 180.0f * cast(f32, i + 10)) * radius, 0.0f);
    }
    rlEnd();
    rlPopMatrix();
}
// Draw a color-filled triangle (vertex in counter-clockwise order!)
void DrawTriangle3D(Vector3 v1, Vector3 v2, Vector3 v3, Color color) {
    rlBegin(4);
    rlColor4ub(color.r, color.g, color.b, color.a);
    rlVertex3f(v1.x, v1.y, v1.z);
    rlVertex3f(v2.x, v2.y, v2.z);
    rlVertex3f(v3.x, v3.y, v3.z);
    rlEnd();
}
// Draw a triangle strip defined by points
void DrawTriangleStrip3D(Vector3* points, i32 pointCount, Color color) {
    if pointCount < 3 {
        return;
    }
    rlBegin(4);
    rlColor4ub(color.r, color.g, color.b, color.a);
    for i32 i = 2; i < pointCount; i++ {
        if i % 2 == 0 {
            rlVertex3f(points[i].x, points[i].y, points[i].z);
            rlVertex3f(points[i - 2].x, points[i - 2].y, points[i - 2].z);
            rlVertex3f(points[i - 1].x, points[i - 1].y, points[i - 1].z);
        } else {
            rlVertex3f(points[i].x, points[i].y, points[i].z);
            rlVertex3f(points[i - 1].x, points[i - 1].y, points[i - 1].z);
            rlVertex3f(points[i - 2].x, points[i - 2].y, points[i - 2].z);
        }
    }
    rlEnd();
}
// Draw cube
// NOTE: Cube position is the center position
void DrawCube(Vector3 position, f32 width, f32 height, f32 length, Color color) {
    f32 x = 0.0f;
    f32 y = 0.0f;
    f32 z = 0.0f;
    rlPushMatrix();
    rlTranslatef(position.x, position.y, position.z);
    rlBegin(4);
    rlColor4ub(color.r, color.g, color.b, color.a);
    rlNormal3f(0.0f, 0.0f, 1.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlNormal3f(0.0f, 0.0f, -1.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlNormal3f(0.0f, 1.0f, 0.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlNormal3f(0.0f, -1.0f, 0.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlNormal3f(1.0f, 0.0f, 0.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x + width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x + width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlNormal3f(-1.0f, 0.0f, 0.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z - length / 2.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y + height / 2.0f, z + length / 2.0f);
    rlVertex3f(x - width / 2.0f, y - height / 2.0f, z - length / 2.0f);
    rlEnd();
    rlPopMatrix();
}
// Draw cube (Vector version)
