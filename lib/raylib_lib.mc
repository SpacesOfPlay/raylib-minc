            rlVertex3f(cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))) * sinf(3.141592f / 180.0f * (360.0f * cast(f32, j + 1) / cast(f32, slices))), sinf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))), cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))) * cosf(3.141592f / 180.0f * (360.0f * cast(f32, j + 1) / cast(f32, slices))));
            rlVertex3f(cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))) * sinf(3.141592f / 180.0f * (360.0f * cast(f32, j) / cast(f32, slices))), sinf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))), cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))) * cosf(3.141592f / 180.0f * (360.0f * cast(f32, j) / cast(f32, slices))));
            rlVertex3f(cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))) * sinf(3.141592f / 180.0f * (360.0f * cast(f32, j) / cast(f32, slices))), sinf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))), cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i + 1))) * cosf(3.141592f / 180.0f * (360.0f * cast(f32, j) / cast(f32, slices))));
            rlVertex3f(cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i))) * sinf(3.141592f / 180.0f * (360.0f * cast(f32, j) / cast(f32, slices))), sinf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i))), cosf(3.141592f / 180.0f * (270.0f + 180.0f / cast(f32, rings + 1) * cast(f32, i))) * cosf(3.141592f / 180.0f * (360.0f * cast(f32, j) / cast(f32, slices))));
        }
