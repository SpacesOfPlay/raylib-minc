//----------------------------------------------------------------------------------
// Defines and Macros
//----------------------------------------------------------------------------------
// Allow custom memory allocators
// NOTE: Require recompiling raylib sources
// NOTE: MSVC C++ compiler does not support compound literals (C99 feature)
// Plain structures in C++ (without constructors) can be initialized with { }
// This is called aggregate initialization (C++11 feature)
// Some compilers (mostly macos clang) default to C++98,
// where aggregate initialization can't be used
// So, give a more clear error stating how to fix this
// NOTE: Set some defines with some data types declared by raylib
// Other modules (raymath, rlgl) also require some of those types, so,
// to be able to use those other modules as standalone (not depending on raylib)
// this defines are useful for internal check and avoid type (re)definitions
// Some Basic Colors
// NOTE: Custom raylib color palette for amazing visuals on WHITE background
//----------------------------------------------------------------------------------
// Types and Structures Definition
//----------------------------------------------------------------------------------
// Boolean type
// Vector2, 2 components
struct Vector2 {
    f32 x;
    f32 y;
}

// Vector3, 3 components
struct Vector3 {
    f32 x;
    f32 y;
    f32 z;
}

// Vector4, 4 components
struct Vector4 {
    f32 x;
    f32 y;
    f32 z;
    f32 w;
}

// Matrix, 4x4 components, column major, OpenGL style, right-handed
struct Matrix {
    f32 m0;
    f32 m4;
    f32 m8;
    f32 m12;
    f32 m1;
    f32 m5;
    f32 m9;
    f32 m13;
    f32 m2;
    f32 m6;
    f32 m10;
    f32 m14;
    f32 m3;
    f32 m7;
    f32 m11;
    f32 m15;
}

// Color, 4 components, R8G8B8A8 (32bit)
struct Color {
    u8 r;
    u8 g;
    u8 b;
    u8 a;
}

// Rectangle, 4 components
struct Rectangle {
    f32 x;
    f32 y;
    f32 width;
    f32 height;
}

// Image, pixel data stored in CPU memory (RAM)
struct Image {
    void* data;
    i32 width;
    i32 height;
    i32 mipmaps;
    i32 format;
}

// Texture, tex data stored in GPU memory (VRAM)
struct Texture {
    u32 id;
    i32 width;
    i32 height;
    i32 mipmaps;
    i32 format;
}

// RenderTexture, fbo for texture rendering
struct RenderTexture {
    u32 id;
    Texture texture;
    Texture depth;
}

// NPatchInfo, n-patch layout info
struct NPatchInfo {
    Rectangle source;
    i32 left;
    i32 top;
    i32 right;
    i32 bottom;
    i32 layout;
}

// GlyphInfo, font characters glyphs info
struct GlyphInfo {
    i32 value;
    i32 offsetX;
    i32 offsetY;
    i32 advanceX;
    Image image;
}

// Font, font texture and GlyphInfo array data
struct Font {
    i32 baseSize;
    i32 glyphCount;
    i32 glyphPadding;
    Texture2D texture;
    Rectangle* recs;
    GlyphInfo* glyphs;
}

// Camera, defines position/orientation in 3d space
struct Camera3D {
    Vector3 position;
    Vector3 target;
    Vector3 up;
    f32 fovy;
    i32 projection;
}

// Camera type fallback, defaults to Camera3D
// Camera2D, defines position/orientation in 2d space
struct Camera2D {
    Vector2 offset;
    Vector2 target;
    f32 rotation;
    f32 zoom;
}

// Mesh, vertex data and vao/vbo
struct Mesh {
    i32 vertexCount;
    i32 triangleCount;
    f32* vertices;
    f32* texcoords;
    f32* texcoords2;
    f32* normals;
    f32* tangents;
    u8* colors;
    u16* indices;
    i32 boneCount;
    u8* boneIndices;
    f32* boneWeights;
    f32* animVertices;
    f32* animNormals;
    u32 vaoId;
    u32* vboId;
}

// Shader
struct Shader {
    u32 id;
    i32* locs;
}

// MaterialMap
struct MaterialMap {
    Texture2D texture;
    Color color;
    f32 value;
}

// Material, includes shader and maps
struct Material {
    Shader shader;
    MaterialMap* maps;
    f32[4] params;
}

// Transform, vertex transformation data
struct Transform {
    Vector3 translation;
    Quaternion rotation;
    Vector3 scale;
}

// Bone, skeletal animation bone
struct BoneInfo {
    u8[32] name;
    i32 parent;
}

// Skeleton, animation bones hierarchy
struct ModelSkeleton {
    i32 boneCount;
    BoneInfo* bones;
    ModelAnimPose bindPose;
}

// Model, meshes, materials and animation data
struct Model {
    Matrix transform;
    i32 meshCount;
    i32 materialCount;
    Mesh* meshes;
    Material* materials;
    i32* meshMaterial;
    ModelSkeleton skeleton;
    ModelAnimPose currentPose;
    Matrix* boneMatrices;
}

// ModelAnimation, contains a full animation sequence
struct ModelAnimation {
    u8[32] name;
    i32 boneCount;
    i32 keyframeCount;
    ModelAnimPose* keyframePoses;
}

// Ray, ray for raycasting
struct Ray {
    Vector3 position;
    Vector3 direction;
}

// RayCollision, ray hit information
struct RayCollision {
    bool hit;
    f32 distance;
    Vector3 point;
    Vector3 normal;
}

// BoundingBox
struct BoundingBox {
    Vector3 min;
    Vector3 max;
}

// Wave, audio wave data
struct Wave {
    u32 frameCount;
    u32 sampleRate;
    u32 sampleSize;
    u32 channels;
    void* data;
}

// AudioStream, custom audio stream
struct AudioStream {
    rAudioBuffer* buffer;
    rAudioProcessor* processor;
    u32 sampleRate;
    u32 sampleSize;
    u32 channels;
}

// Sound
struct Sound {
    AudioStream stream;
    u32 frameCount;
}

// Music, audio stream, anything longer than ~10 seconds should be streamed
struct Music {
    AudioStream stream;
    u32 frameCount;
    bool looping;
    i32 ctxType;
    void* ctxData;
}

// VrDeviceInfo, Head-Mounted-Display device parameters
struct VrDeviceInfo {
    i32 hResolution;
    i32 vResolution;
    f32 hScreenSize;
    f32 vScreenSize;
    f32 eyeToScreenDistance;
    f32 lensSeparationDistance;
    f32 interpupillaryDistance;
    f32[4] lensDistortionValues;
    f32[4] chromaAbCorrection;
}

// VrStereoConfig, VR stereo rendering configuration for simulator
struct VrStereoConfig {
    Matrix[2] projection;
    Matrix[2] viewOffset;
    f32[2] leftLensCenter;
    f32[2] rightLensCenter;
    f32[2] leftScreenCenter;
    f32[2] rightScreenCenter;
    f32[2] scale;
    f32[2] scaleIn;
}

// File path list
struct FilePathList {
    u32 count;
    u8** paths;
}

// Automation event
struct AutomationEvent {
    u32 frame;
    u32 type;
    i32[4] params;
}

// Automation event list
struct AutomationEventList {
    u32 capacity;
    u32 count;
    AutomationEvent* events;
}

// Internal Matrix stack
// Shader limits
// Projection matrix culling
// Texture parameters (equivalent to OpenGL defines)
// Matrix modes (equivalent to OpenGL)
// Primitive assembly draw modes
// GL equivalent data types
// GL buffer usage hint
// GL Shader type
// GL blending factors
// GL blending functions/equations
// Default shader vertex attribute locations
//----------------------------------------------------------------------------------
// Types and Structures Definition
//----------------------------------------------------------------------------------
// Dynamic vertex buffers (position + texcoords + colors + indices arrays)
struct rlVertexBuffer {
    i32 elementCount;
    f32* vertices;
    f32* texcoords;
    f32* normals;
    u8* colors;
    u32* indices;
    u32 vaoId;
    u32[5] vboId;
}

// Draw call type
// NOTE: Only texture changes register a new draw, other state-change-related elements are not
// used at this moment (vaoId, shaderId, matrices), raylib forces a batch draw call if any
// of those state-change happens (this is done in core module)
struct rlDrawCall {
    i32 mode;
    i32 vertexCount;
    i32 vertexAlignment;
    u32 textureId;
}

// rlRenderBatch type
struct rlRenderBatch {
    i32 bufferCount;
    i32 currentBuffer;
    rlVertexBuffer* vertexBuffer;
    rlDrawCall* draws;
    i32 drawCounter;
    f32 currentDepth;
}

// OpenGL extension functions loader signature (same as GLADloadproc)
struct rlglData {
    rlRenderBatch* currentBatch;
    rlRenderBatch defaultBatch;
    rlglLoadProc loader;
    struct {
        i32 vertexCounter;
        f32 texcoordx;
        f32 texcoordy;
        f32 normalx;
        f32 normaly;
        f32 normalz;
        u8 colorr;
        u8 colorg;
        u8 colorb;
        u8 colora;
        i32 currentMatrixMode;
        Matrix* currentMatrix;
        Matrix modelview;
        Matrix projection;
        Matrix transform;
        bool transformRequired;
        Matrix[32] stack;
        i32 stackCounter;
        u32 currentTextureId;
        u32 defaultTextureId;
        u32[4] activeTextureId;
        u32 defaultVShaderId;
        u32 defaultFShaderId;
        u32 defaultShaderId;
        i32* defaultShaderLocs;
        u32 currentShaderId;
        i32* currentShaderLocs;
        bool stereoRender;
        Matrix[2] projectionStereo;
        Matrix[2] viewOffsetStereo;
        i32 currentBlendMode;
        i32 glBlendSrcFactor;
        i32 glBlendDstFactor;
        i32 glBlendEquation;
        i32 glBlendSrcFactorRGB;
        i32 glBlendDestFactorRGB;
        i32 glBlendSrcFactorAlpha;
        i32 glBlendDestFactorAlpha;
        i32 glBlendEquationRGB;
        i32 glBlendEquationAlpha;
        bool glCustomBlendModeModified;
        i32 framebufferWidth;
        i32 framebufferHeight;
    } State;
    struct {
        bool vao;
        bool instancing;
        bool texNPOT;
        bool texDepth;
        bool texDepthWebGL;
        bool texFloat32;
        bool texFloat16;
        bool texCompDXT;
        bool texCompETC1;
        bool texCompETC2;
        bool texCompPVRT;
        bool texCompASTC;
        bool texMirrorClamp;
        bool texAnisoFilter;
        bool computeShader;
        bool ssbo;
        f32 maxAnisotropyLevel;
        i32 maxDepthBits;
    } ExtSupported;
}

// Get identity matrix
// Auxiliar matrix math functions
struct rl_float16 {
    f32[16] v;
}

//----------------------------------------------------------------------------------
// Defines and Macros
//----------------------------------------------------------------------------------
// Get float vector for Matrix
// Get float vector for Vector3
//----------------------------------------------------------------------------------
// Types and Structures Definition
//----------------------------------------------------------------------------------
// NOTE: Helper types to be used instead of array return types for *ToFloat functions
struct c_float3 {
    f32[3] v;
}

struct c_float16 {
    f32[16] v;
}

// Gesture event
struct GestureEvent {
    i32 touchAction;
    i32 pointCount;
    i32[8] pointId;
    Vector2[8] position;
}

// Update gestures detected (must be called every frame)
/***********************************************************************************
*
*   RGESTURES IMPLEMENTATION
*
************************************************************************************/
//----------------------------------------------------------------------------------
// Defines and Macros
//----------------------------------------------------------------------------------
//----------------------------------------------------------------------------------
// Types and Structures Definition
//----------------------------------------------------------------------------------
// Gestures module state context [136 bytes]
struct GesturesData {
    u32 current;
    u32 enabledFlags;
    struct {
        i32 firstId;
        i32 pointCount;
        f64 eventTime;
        Vector2 upPosition;
        Vector2 downPositionA;
        Vector2 downPositionB;
        Vector2 downDragPosition;
        Vector2 moveDownPositionA;
        Vector2 moveDownPositionB;
        Vector2 previousPositionA;
        Vector2 previousPositionB;
        i32 tapCounter;
    } Touch;
    struct {
        bool resetRequired;
        f64 timeDuration;
    } Hold;
    struct {
        Vector2 vector;
        f32 angle;
        f32 distance;
        f32 intensity;
    } Drag;
    struct {
        f64 startTime;
    } Swipe;
    struct {
        Vector2 vector;
        f32 angle;
        f32 distance;
    } Pinch;
}

// Camera system functionality
/*
# Small Deflate
`sdefl` is a small bare bone lossless compression library in ANSI C (ISO C90)
which implements the Deflate (RFC 1951) compressed data format specification standard.
It is mainly tuned to get as much speed and compression ratio from as little code
as needed to keep the implementation as concise as possible.

## Features
- Portable single header and source file duo written in ANSI C (ISO C90)
- Dual license with either MIT or public domain
- Small implementation
    - Deflate: 525 LoC
    - Inflate: 500 LoC
- Webassembly:
    - Deflate ~3.7 KB (~2.2KB compressed)
    - Inflate ~3.6 KB (~2.2KB compressed)

## Usage:
This file behaves differently depending on what symbols you define
before including it.

Header-File mode:
If you do not define `SINFL_IMPLEMENTATION` before including this file, it
will operate in header only mode. In this mode it declares all used structs
and the API of the library without including the implementation of the library.

Implementation mode:
If you define `SINFL_IMPLEMENTATION` before including this file, it will
compile the implementation. Make sure that you only include
this file implementation in *one* C or C++ file to prevent collisions.

### Benchmark

