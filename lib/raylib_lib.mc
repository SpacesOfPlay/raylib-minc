Vector2 GetWindowPosition() {
    return Vector2{cast(f32, CORE.Window.position.x), cast(f32, CORE.Window.position.y)};
}
// Get window scale DPI factor for current monitor
Vector2 GetWindowScaleDPI() {
    var scale = Vector2{1.0f, 1.0f};
    if (CORE.Window.flags & cast(u32, FLAG_WINDOW_HIGHDPI)) == cast(u32, FLAG_WINDOW_HIGHDPI) && !((CORE.Window.flags & cast(u32, FLAG_FULLSCREEN_MODE)) == cast(u32, FLAG_FULLSCREEN_MODE)) {
        glfwGetWindowContentScale(platform.handle, &scale.x, &scale.y);
