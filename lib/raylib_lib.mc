// nothing
when defined(STBI_NO_PNG) {
} else {
    //////////////////////////////////////////////////////////////////////////////
    //
    //  generic converter from built-in img_n to req_comp
    //    individual types do this automatically as much as possible (e.g. jpeg
    //    does all cases internally since it needs to colorspace convert anyway,
    //    and it never has alpha, so very few cases ). png can automatically
    //    interleave an alpha=255 channel, but falls back to this for other cases
    //
    //  assume data buffer is malloced, so malloc a new one and free that one
    //  only failure mode is malloc failing
private { stbi_uc stbi__compute_y(i32 r, i32 g, i32 b) {
        return cast(stbi_uc, r * 77 + g * 150 + 29 * b >> 8);
    }}
}
when defined(STBI_NO_PNG) {
} else {
private { u8* stbi__convert_format(u8* data, i32 img_n, i32 req_comp, u32 x, u32 y) {
        i32 i;
        i32 j;
        u8* good;
        if req_comp == img_n {
            return data;
        }
        assert(req_comp >= 1 && req_comp <= 4);
        good = cast(u8*, stbi__malloc_mad3(req_comp, cast(i32, x), cast(i32, y), 0));
        if good == null {
            free(data);
            return cast(u8*, cast(u64, stbi__err("outofmem") != 0 ? null : null));
        }
        for j = 0; j < cast(i32, y); ++j {
            u8* src = data + cast(u32, j) * x * cast(u32, img_n);
            u8* dest = good + cast(u32, j) * x * cast(u32, req_comp);
            switch img_n * 8 + req_comp {
                case 1 * 8 + 2: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        dest[1] = 255;
                        src += 1;
                        dest += 2;
                    }
                }
                case 1 * 8 + 3: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        src += 1;
                        dest += 3;
                    }
                }
                case 1 * 8 + 4: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        dest[3] = 255;
                        src += 1;
                        dest += 4;
                    }
                }
                case 2 * 8 + 1: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        src += 2;
                        dest += 1;
                    }
                }
                case 2 * 8 + 3: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        src += 2;
                        dest += 3;
                    }
                }
                case 2 * 8 + 4: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[2] = src[0];
                        dest[1] = dest[2];
                        dest[0] = dest[1];
                        dest[3] = src[1];
                        src += 2;
                        dest += 4;
                    }
                }
                case 3 * 8 + 4: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        dest[1] = src[1];
                        dest[2] = src[2];
                        dest[3] = 255;
                        src += 3;
                        dest += 4;
                    }
                }
                case 3 * 8 + 1: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        src += 3;
                        dest += 1;
                    }
                }
                case 3 * 8 + 2: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        dest[1] = 255;
                        src += 3;
                        dest += 2;
                    }
                }
                case 4 * 8 + 1: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        src += 4;
                        dest += 1;
                    }
                }
                case 4 * 8 + 2: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = stbi__compute_y(cast(i32, src[0]), cast(i32, src[1]), cast(i32, src[2]));
                        dest[1] = src[3];
                        src += 4;
                        dest += 2;
                    }
                }
                case 4 * 8 + 3: {
                    for i = cast(i32, x - 1); i >= 0; --i {
                        dest[0] = src[0];
                        dest[1] = src[1];
                        dest[2] = src[2];
                        src += 4;
                        dest += 3;
                    }
                }
                default: {
                    assert(0);
                    free(data);
                    free(good);
                    return cast(u8*, cast(u64, stbi__err("unsupported") != 0 ? null : null));
                }
            }
        }
        free(data);
        return good;
    }}
}
when defined(STBI_NO_PNG) {
