struct sdefl_freq {
    u32[288] lit;
    u32[32] off;
}

struct sdefl_code_words {
    u32[288] lit;
    u32[32] off;
}

struct sdefl_lens {
    u8[288] lit;
    u8[32] off;
}

struct sdefl_codes {
    sdefl_code_words word;
    sdefl_lens len;
}

struct sdefl_seqt {
    i32 off;
    i32 len;
}

struct sdefl {
    i32 bits;
    i32 bitcnt;
    i32[32768] tbl;
    i32[32768] prv;
    i32 seq_cnt;
    sdefl_seqt[87382] seq;
    sdefl_freq freq;
    sdefl_codes cod;
}

struct sdefl_symcnt {
    i32 items;
    i32 lit;
    i32 off;
}

struct sdefl_match_codest {
    i32 ls;
    i32 lc;
    i32 dc;
    i32 dx;
}

struct sdefl_match {
    i32 off;
    i32 len;
}

struct dirent {
    u8* d_name;
}

// C99's intptr_t not sufficiently portable
struct DIR {
    handle_type handle;
    _finddata_t info;
    dirent result;
    u8* name;
}

// File and directory scan filters
// NOTE: Used in ScanDirectoryFiles(), LoadDirectoryFilesEx() and GetDirectoryFileCountEx()
// WARNING: Custom file filters can be specified but following raylib IsFileExtension() convention: ".png;.wav;.glb"
// Flags bitwise operation macros
//----------------------------------------------------------------------------------
// Types and Structures Definition
//----------------------------------------------------------------------------------
struct Point {
    i32 x;
    i32 y;
}

struct Size {
    u32 width;
    u32 height;
}

// Core global state context data
struct CoreData {
    struct {
        u8* title;
        u32 flags;
        bool ready;
        bool shouldClose;
        bool resizedLastFrame;
        bool eventWaiting;
        bool usingFbo;
        Size display;
        Size screen;
        Point position;
        Size previousScreen;
        Point previousPosition;
        Size render;
        Point renderOffset;
        Size currentFbo;
        Size screenMin;
        Size screenMax;
        Matrix screenScale;
        u8** dropFilepaths;
        u32 dropFileCount;
    } Window;
    struct {
        u8* basePath;
    } Storage;
    struct {
        struct {
            i32 exitKey;
            u8[512] currentKeyState;
            u8[512] previousKeyState;
            u8[512] keyRepeatInFrame;
            i32[16] keyPressedQueue;
            i32 keyPressedQueueCount;
            i32[16] charPressedQueue;
            i32 charPressedQueueCount;
        } Keyboard;
        struct {
            Vector2 offset;
            Vector2 scale;
            Vector2 currentPosition;
            Vector2 previousPosition;
            Vector2 lockedPosition;
            i32 cursor;
            bool cursorHidden;
            bool cursorLocked;
            bool cursorOnScreen;
            u8[8] currentButtonState;
            u8[8] previousButtonState;
            Vector2 currentWheelMove;
            Vector2 previousWheelMove;
        } Mouse;
        struct {
            i32 pointCount;
            i32[8] pointId;
            Vector2[8] position;
            Vector2[8] previousPosition;
            u8[8] currentTouchState;
            u8[8] previousTouchState;
        } Touch;
        struct {
            i32 lastButtonPressed;
            i32[4] axisCount;
            bool[4] ready;
            __arr_u8_128[4] name;
            __arr_u8_32[4] currentButtonState;
            __arr_u8_32[4] previousButtonState;
            __arr_f32_8[4] axisState;
        } Gamepad;
    } Input;
    struct {
        f64 current;
        f64 previous;
        f64 update;
        f64 draw;
        f64 frame;
        f64 target;
        u64 base;
        u32 frameCounter;
    } Time;
}

/*! @brief Video mode type.
 *
 *  This describes a single video mode.
 *
 *  @sa @ref monitor_modes
 *  @sa @ref glfwGetVideoMode
 *  @sa @ref glfwGetVideoModes
 *
 *  @since Added in version 1.0.
 *  @glfw3 Added refresh rate member.
 *
 *  @ingroup monitor
 */
struct GLFWvidmode {
    i32 width;
    i32 height;
    i32 redBits;
    i32 greenBits;
    i32 blueBits;
    i32 refreshRate;
}

/*! @brief Gamma ramp.
 *
 *  This describes the gamma ramp for a monitor.
 *
 *  @sa @ref monitor_gamma
 *  @sa @ref glfwGetGammaRamp
 *  @sa @ref glfwSetGammaRamp
 *
 *  @since Added in version 3.0.
 *
 *  @ingroup monitor
 */
struct GLFWgammaramp {
    u16* red;
    u16* green;
    u16* blue;
    u32 size;
}

/*! @brief Image data.
 *
 *  This describes a single 2D image.  See the documentation for each related
 *  function what the expected pixel format is.
 *
 *  @sa @ref cursor_custom
 *  @sa @ref window_icon
 *
 *  @since Added in version 2.1.
 *  @glfw3 Removed format and bytes-per-pixel members.
 *
 *  @ingroup window
 */
struct GLFWimage {
    i32 width;
    i32 height;
    u8* pixels;
}

/*! @brief Gamepad input state
 *
 *  This describes the input state of a gamepad.
 *
 *  @sa @ref gamepad
 *  @sa @ref glfwGetGamepadState
 *
 *  @since Added in version 3.3.
 *
 *  @ingroup input
 */
struct GLFWgamepadstate {
    u8[15] buttons;
    f32[6] axes;
}

/*! @brief Custom heap memory allocator.
 *
 *  This describes a custom heap memory allocator for GLFW.  To set an allocator, pass it
 *  to @ref glfwInitAllocator before initializing the library.
 *
 *  @sa @ref init_allocator
 *  @sa @ref glfwInitAllocator
 *
 *  @since Added in version 3.4.
 *
 *  @ingroup init
 */
struct GLFWallocator {
    GLFWallocatefun allocate;
    GLFWreallocatefun reallocate;
    GLFWdeallocatefun deallocate;
    void* user;
}

