// Returns the cameras forward vector (normalized)
Vector3 GetCameraForward(Camera* camera) {
    return Vector3Normalize(Vector3Subtract(camera.target, camera.position));
}
// Returns the cameras up vector (normalized)
// Note: The up vector might not be perpendicular to the forward vector
Vector3 GetCameraUp(Camera* camera) {
    return Vector3Normalize(camera.up);
}
// Returns the cameras right vector (normalized)
Vector3 GetCameraRight(Camera* camera) {
    Vector3 forward = GetCameraForward(camera);
    Vector3 up = GetCameraUp(camera);
    return Vector3Normalize(Vector3CrossProduct(forward, up));
}
// Moves the camera in its forward direction
void CameraMoveForward(Camera* camera, f32 distance, bool moveInWorldPlane) {
    Vector3 forward = GetCameraForward(camera);
    if moveInWorldPlane != 0 {
        if fabsf(camera.up.z) > 0.707100f {
            forward.z = 0.0f;
        } else if fabsf(camera.up.x) > 0.707100f {
            forward.x = 0.0f;
        } else {
            forward.y = 0.0f;
        }
        forward = Vector3Normalize(forward);
    }
    forward = Vector3Scale(forward, distance);
    camera.position = Vector3Add(camera.position, forward);
    camera.target = Vector3Add(camera.target, forward);
}
// Moves the camera in its up direction
void CameraMoveUp(Camera* camera, f32 distance) {
    Vector3 up = GetCameraUp(camera);
    up = Vector3Scale(up, distance);
    camera.position = Vector3Add(camera.position, up);
    camera.target = Vector3Add(camera.target, up);
}
// Moves the camera target in its current right direction
void CameraMoveRight(Camera* camera, f32 distance, bool moveInWorldPlane) {
    Vector3 right = GetCameraRight(camera);
    if moveInWorldPlane != 0 {
        if fabsf(camera.up.z) > 0.707100f {
            right.z = 0.0f;
        } else if fabsf(camera.up.x) > 0.707100f {
            right.x = 0.0f;
        } else {
            right.y = 0.0f;
        }
        right = Vector3Normalize(right);
    }
    right = Vector3Scale(right, distance);
    camera.position = Vector3Add(camera.position, right);
    camera.target = Vector3Add(camera.target, right);
}
// Moves the camera position closer/farther to/from the camera target
void CameraMoveToTarget(Camera* camera, f32 delta) {
    f32 distance = Vector3Distance(camera.position, camera.target);
    distance += delta;
    if distance <= 0.0f {
        distance = 0.001000f;
    }
    Vector3 forward = GetCameraForward(camera);
    camera.position = Vector3Add(camera.target, Vector3Scale(forward, -distance));
}
// Rotates the camera around its up vector
// Yaw is "looking left and right"
// If rotateAroundTarget is false, the camera rotates around its position
// Note: angle must be provided in radians
void CameraYaw(Camera* camera, f32 angle, bool rotateAroundTarget) {
    Vector3 up = GetCameraUp(camera);
    Vector3 targetPosition = Vector3Subtract(camera.target, camera.position);
    targetPosition = Vector3RotateByAxisAngle(targetPosition, up, angle);
    if rotateAroundTarget != 0 {
        camera.position = Vector3Subtract(camera.target, targetPosition);
    } else {
        camera.target = Vector3Add(camera.position, targetPosition);
    }
}
// Rotates the camera around its right vector, pitch is "looking up and down"
//  - lockView prevents camera overrotation (aka "somersaults")
//  - rotateAroundTarget defines if rotation is around target or around its position
//  - rotateUp rotates the up direction as well (typically only useful in CAMERA_FREE)
// NOTE: [angle] must be provided in radians
void CameraPitch(Camera* camera, f32 angle, bool lockView, bool rotateAroundTarget, bool rotateUp) {
    Vector3 up = GetCameraUp(camera);
    Vector3 targetPosition = Vector3Subtract(camera.target, camera.position);
    if lockView != 0 {
        f32 maxAngleUp = Vector3Angle(up, targetPosition);
        maxAngleUp -= 0.001000f;
        if angle > maxAngleUp {
            angle = maxAngleUp;
        }
        f32 maxAngleDown = Vector3Angle(Vector3Negate(up), targetPosition);
        maxAngleDown *= -1.0f;
        maxAngleDown += 0.001000f;
        if angle < maxAngleDown {
            angle = maxAngleDown;
        }
    }
    Vector3 right = GetCameraRight(camera);
    targetPosition = Vector3RotateByAxisAngle(targetPosition, right, angle);
    if rotateAroundTarget != 0 {
        camera.position = Vector3Subtract(camera.target, targetPosition);
    } else {
        camera.target = Vector3Add(camera.position, targetPosition);
    }
    if rotateUp != 0 {
        camera.up = Vector3RotateByAxisAngle(camera.up, right, angle);
    }
}
// Rotates the camera around its forward vector
// Roll is "turning your head sideways to the left or right"
// Note: angle must be provided in radians
void CameraRoll(Camera* camera, f32 angle) {
    Vector3 forward = GetCameraForward(camera);
    camera.up = Vector3RotateByAxisAngle(camera.up, forward, angle);
}
// Returns the camera view matrix
Matrix GetCameraViewMatrix(Camera* camera) {
    return MatrixLookAt(camera.position, camera.target, camera.up);
}
// Returns the camera projection matrix
Matrix GetCameraProjectionMatrix(Camera* camera, f32 aspect) {
    if camera.projection == CAMERA_PERSPECTIVE {
        return MatrixPerspective(camera.fovy * (3.141592f / 180.0f), aspect, 0.050000, 4000.0);
    } else if camera.projection == CAMERA_ORTHOGRAPHIC {
        f64 top = cast(f64, camera.fovy) / 2.0;
        f64 right = top * aspect;
        return MatrixOrtho(-right, right, -top, top, 0.050000, 4000.0);
    }
    return MatrixIdentity();
}
// Update camera position for selected mode
// Camera mode: CAMERA_FREE, CAMERA_FIRST_PERSON, CAMERA_THIRD_PERSON, CAMERA_ORBITAL or CUSTOM
void UpdateCamera(Camera* camera, i32 mode) {
    Vector2 mousePositionDelta = GetMouseDelta();
    bool moveInWorldPlane = mode == CAMERA_FIRST_PERSON || mode == CAMERA_THIRD_PERSON;
    bool rotateAroundTarget = mode == CAMERA_THIRD_PERSON || mode == CAMERA_ORBITAL;
    bool lockView = mode == CAMERA_FREE || mode == CAMERA_FIRST_PERSON || mode == CAMERA_THIRD_PERSON || mode == CAMERA_ORBITAL;
    bool rotateUp = false;
    f32 cameraMoveSpeed = 5.400000f * GetFrameTime();
    f32 cameraRotationSpeed = 0.030000f * GetFrameTime();
    f32 cameraPanSpeed = 2.0f * GetFrameTime();
    f32 cameraOrbitalSpeed = 0.500000f * GetFrameTime();
    if mode == CAMERA_CUSTOM {
    } else if mode == CAMERA_ORBITAL {
        Matrix rotation = MatrixRotate(GetCameraUp(camera), cameraOrbitalSpeed);
        Vector3 view = Vector3Subtract(camera.position, camera.target);
        view = Vector3Transform(view, rotation);
        camera.position = Vector3Add(camera.target, view);
    } else {
        if IsKeyDown(KEY_DOWN) != 0 {
            CameraPitch(camera, -cameraRotationSpeed, lockView, rotateAroundTarget, rotateUp);
        }
        if IsKeyDown(KEY_UP) != 0 {
            CameraPitch(camera, cameraRotationSpeed, lockView, rotateAroundTarget, rotateUp);
        }
        if IsKeyDown(KEY_RIGHT) != 0 {
            CameraYaw(camera, -cameraRotationSpeed, rotateAroundTarget);
        }
        if IsKeyDown(KEY_LEFT) != 0 {
            CameraYaw(camera, cameraRotationSpeed, rotateAroundTarget);
        }
        if IsKeyDown(KEY_Q) != 0 {
            CameraRoll(camera, -cameraRotationSpeed);
        }
        if IsKeyDown(KEY_E) != 0 {
            CameraRoll(camera, cameraRotationSpeed);
        }
        if mode == CAMERA_FREE && IsMouseButtonDown(MOUSE_BUTTON_MIDDLE) {
            Vector2 mouseDelta = GetMouseDelta();
            if mouseDelta.x > 0.0f {
                CameraMoveRight(camera, cameraPanSpeed, moveInWorldPlane);
            }
            if mouseDelta.x < 0.0f {
                CameraMoveRight(camera, -cameraPanSpeed, moveInWorldPlane);
            }
            if mouseDelta.y > 0.0f {
                CameraMoveUp(camera, -cameraPanSpeed);
            }
            if mouseDelta.y < 0.0f {
                CameraMoveUp(camera, cameraPanSpeed);
            }
        } else {
            CameraYaw(camera, -mousePositionDelta.x * 0.003000f, rotateAroundTarget);
            CameraPitch(camera, -mousePositionDelta.y * 0.003000f, lockView, rotateAroundTarget, rotateUp);
        }
        if IsKeyDown(KEY_W) != 0 {
            CameraMoveForward(camera, cameraMoveSpeed, moveInWorldPlane);
        }
        if IsKeyDown(KEY_A) != 0 {
            CameraMoveRight(camera, -cameraMoveSpeed, moveInWorldPlane);
        }
        if IsKeyDown(KEY_S) != 0 {
            CameraMoveForward(camera, -cameraMoveSpeed, moveInWorldPlane);
        }
        if IsKeyDown(KEY_D) != 0 {
            CameraMoveRight(camera, cameraMoveSpeed, moveInWorldPlane);
        }
        if IsGamepadAvailable(0) != 0 {
            CameraYaw(camera, -(GetGamepadAxisMovement(0, GAMEPAD_AXIS_RIGHT_X) * 2.0f) * 0.003000f, rotateAroundTarget);
            CameraPitch(camera, -(GetGamepadAxisMovement(0, GAMEPAD_AXIS_RIGHT_Y) * 2.0f) * 0.003000f, lockView, rotateAroundTarget, rotateUp);
            if GetGamepadAxisMovement(0, GAMEPAD_AXIS_LEFT_Y) <= -0.250000f {
                CameraMoveForward(camera, cameraMoveSpeed, moveInWorldPlane);
            }
            if GetGamepadAxisMovement(0, GAMEPAD_AXIS_LEFT_X) <= -0.250000f {
                CameraMoveRight(camera, -cameraMoveSpeed, moveInWorldPlane);
            }
            if GetGamepadAxisMovement(0, GAMEPAD_AXIS_LEFT_Y) >= 0.250000f {
                CameraMoveForward(camera, -cameraMoveSpeed, moveInWorldPlane);
            }
            if GetGamepadAxisMovement(0, GAMEPAD_AXIS_LEFT_X) >= 0.250000f {
                CameraMoveRight(camera, cameraMoveSpeed, moveInWorldPlane);
            }
        }
        if mode == CAMERA_FREE {
            if IsKeyDown(KEY_SPACE) != 0 {
                CameraMoveUp(camera, cameraMoveSpeed);
            }
            if IsKeyDown(KEY_LEFT_CONTROL) != 0 {
                CameraMoveUp(camera, -cameraMoveSpeed);
            }
        }
    }
    if mode == CAMERA_THIRD_PERSON || mode == CAMERA_ORBITAL || mode == CAMERA_FREE {
        CameraMoveToTarget(camera, -GetMouseWheelMove());
        if IsKeyPressed(KEY_KP_SUBTRACT) != 0 {
            CameraMoveToTarget(camera, 2.0f);
        }
        if IsKeyPressed(KEY_KP_ADD) != 0 {
            CameraMoveToTarget(camera, -2.0f);
        }
    }
}
// Update camera movement, movement/rotation values should be provided by user
void UpdateCameraPro(Camera* camera, Vector3 movement, Vector3 rotation, f32 zoom) {
    bool lockView = true;
    bool rotateAroundTarget = false;
    bool rotateUp = false;
    bool moveInWorldPlane = true;
    CameraPitch(camera, -rotation.y * (3.141592f / 180.0f), lockView, rotateAroundTarget, rotateUp);
    CameraYaw(camera, -rotation.x * (3.141592f / 180.0f), rotateAroundTarget);
    CameraRoll(camera, rotation.z * (3.141592f / 180.0f));
    CameraMoveForward(camera, movement.x, moveInWorldPlane);
    CameraMoveRight(camera, movement.y, moveInWorldPlane);
    CameraMoveUp(camera, movement.z);
    CameraMoveToTarget(camera, zoom);
}
private { i32 sinfl_bsr(u32 n) {
    when os(windows) {
        u64 uln = 0;
        rl_BitScanReverse_u64(&uln, n);
        return cast(i32, uln);
    } else {
        return 31 - __builtin_clz(n);
    }
}}
private { u64 sinfl_read64(void* p) {
    u64 n;
    memcpy(&n, p, cast(u64, 8));
    return n;
}}
private { void sinfl_copy64(u8** dst, u8** src) {
    memcpy(*dst, *src, cast(u64, 8));
    *dst += 8;
    *src += 8;
}}
private { u8* sinfl_write64(u8* dst, u64 w) {
    memcpy(dst, &w, cast(u64, 8));
    return dst + 8;
}}
private { void sinfl_refill(sinfl* s) {
    if cast(i64, s.bitend - s.bitptr) >= 8 {
        s.bitbuf |= sinfl_read64(s.bitptr) << cast(u64, s.bitcnt);
        s.bitptr += 63 - s.bitcnt >> 3;
        s.bitcnt |= 56;
    } else {
        i32 bitswant = 63 - s.bitcnt;
        i32 byteswant = bitswant >> 3;
        i32 bytesuse = cast(i64, s.bitend - s.bitptr) <= byteswant ? cast(i32, cast(i64, s.bitend - s.bitptr)) : byteswant;
        u64 n = 0;
        memcpy(&n, s.bitptr, cast(u64, bytesuse));
        s.bitbuf |= n << cast(u64, s.bitcnt);
        s.bitptr += bytesuse;
        s.bitcnt += bytesuse << 3;
    }
}}
private { i32 sinfl_peek(sinfl* s, i32 cnt) {
    return cast(i32, s.bitbuf & cast(u64, (1 << cnt) - 1));
}}
private { void sinfl_eat(sinfl* s, i32 cnt) {
    s.bitbuf >>= cast(u64, cnt);
    s.bitcnt -= cnt;
}}
private { i32 sinfl__get(sinfl* s, i32 cnt) {
    i32 res = sinfl_peek(s, cnt);
    sinfl_eat(s, cnt);
    return res;
}}
private { i32 sinfl_get(sinfl* s, i32 cnt) {
    sinfl_refill(s);
    return sinfl__get(s, cnt);
}}
private { i32 sinfl_build_tbl(sinfl_gen* gen, u32* tbl, i32 tbl_bits, i32* cnt) {
    i32 tbl_end = 0;
    while true {
        gen.cnt = cnt[gen.len];
        if !gen.cnt == 0 {
            break;
        }
        ++gen.len;
    }
    tbl_end = 1 << gen.len;
    while gen.len <= tbl_bits {
        while true {
            u32 bit = 0;
            tbl[gen.word] = cast(u32, cast(i32, *gen.sorted++) << 16 | gen.len);
            if gen.word == tbl_end - 1 {
                for ; gen.len < tbl_bits; gen.len++ {
                    memcpy(&tbl[tbl_end], tbl, cast(u64, tbl_end) * cast(u64, sizeof(tbl[0])));
                    tbl_end <<= 1;
                }
                return 1;
            }
            bit = cast(u32, 1 << sinfl_bsr(cast(u32, gen.word ^ tbl_end - 1)));
            gen.word &= cast(i32, bit - 1);
            gen.word |= cast(i32, bit);
            if !(--gen.cnt != 0) { break; }
        }
        while true {
            if ++gen.len <= tbl_bits {
                memcpy(&tbl[tbl_end], tbl, cast(u64, tbl_end) * cast(u64, sizeof(tbl[0])));
                tbl_end <<= 1;
            }
            gen.cnt = cnt[gen.len];
            if !(gen.cnt == 0) { break; }
        }
    }
    return 0;
}}
private { void sinfl_build_subtbl(sinfl_gen* gen, u32* tbl, i32 tbl_bits, i32* cnt) {
    i32 sub_bits = 0;
    i32 sub_start = 0;
    i32 sub_prefix = -1;
    i32 tbl_end = 1 << tbl_bits;
    while 1 != 0 {
        u32 entry;
        i32 bit;
        i32 stride;
        i32 i;
        if (gen.word & (1 << tbl_bits) - 1) != sub_prefix {
            i32 used = 0;
            sub_prefix = gen.word & (1 << tbl_bits) - 1;
            sub_start = tbl_end;
            sub_bits = gen.len - tbl_bits;
            used = gen.cnt;
            while used < 1 << sub_bits {
                sub_bits++;
                used = (used << 1) + cnt[tbl_bits + sub_bits];
            }
            tbl_end = sub_start + (1 << sub_bits);
            tbl[sub_prefix] = cast(u32, sub_start << 16 | 16 | sub_bits & 15);
        }
        entry = cast(u32, cast(i32, *gen.sorted) << 16 | gen.len - tbl_bits & 15);
        gen.sorted++;
        i = sub_start + (gen.word >> tbl_bits);
        stride = 1 << gen.len - tbl_bits;
        while true {
            tbl[i] = entry;
            i += stride;
            if !(i < tbl_end) { break; }
        }
        if gen.word == (1 << gen.len) - 1 {
            return;
        }
        bit = 1 << sinfl_bsr(cast(u32, gen.word ^ (1 << gen.len) - 1));
        gen.word &= bit - 1;
        gen.word |= bit;
        gen.cnt--;
        while gen.cnt == 0 {
            gen.cnt = cnt[++gen.len];
        }
    }
}}
private { void sinfl_build(u32* tbl, u8* lens, i32 tbl_bits, i32 maxlen, i32 symcnt) {
    i32 i;
    i32 used = 0;
    i16[288] sort;
    i32[16] cnt;
    i32[16] off;
    sinfl_gen gen;
    gen.sorted = sort;
    gen.len = 1;
    for i = 0; i < symcnt; ++i {
        cnt[lens[i]]++;
    }
    off[1] = cnt[0];
    for i = 1; i < maxlen; ++i {
        off[i + 1] = off[i] + cnt[i];
        used = (used << 1) + cnt[i];
    }
    used = (used << 1) + cnt[i];
    for i = 0; i < symcnt; ++i {
        gen.sorted[off[lens[i]]++] = cast(i16, i);
    }
    gen.sorted += off[0];
    if used < 1 << maxlen {
        for i = 0; i < 1 << tbl_bits; ++i {
            tbl[i] = cast(u32, 0 << 16 | 1);
        }
        return;
    }
    if sinfl_build_tbl(&gen, tbl, tbl_bits, cnt) == 0 {
        sinfl_build_subtbl(&gen, tbl, tbl_bits, cnt);
    }
}}
private { i32 sinfl_decode(sinfl* s, u32* tbl, i32 bit_len) {
    i32 idx = sinfl_peek(s, bit_len);
    u32 key = tbl[idx];
    if (key & 16) != 0 {
        var len = cast(i32, key & 15);
        sinfl_eat(s, bit_len);
        idx = sinfl_peek(s, len);
        key = tbl[(key >> 16 & 65535) + cast(u32, idx)];
    }
    sinfl_eat(s, cast(i32, key & 15));
    return cast(i32, key >> 16 & 4095);
}}
private { i32 sinfl_decompress(u8* out, i32 cap, u8* in, i32 size) {
    u8* oe = out + cap;
    u8* e = in + size;
    u8* o = out;
        sinfl_states state = hdr;
    sinfl s;
    i32 last = 0;
    s.bitptr = in;
    s.bitend = e;
    while 1 != 0 {
        switch state {
            case hdr: {
                {
                    i32 type = 0;
                    sinfl_refill(&s);
                    last = sinfl__get(&s, 1);
                    type = sinfl__get(&s, 2);
                    switch type {
                        default: {
                            return cast(i32, cast(i64, out - o));
                        }
                        case 0: {
                            state = stored;
                        }
                        case 1: {
                            state = fixed;
                        }
                        case 2: {
                            state = dyn;
                        }
                    }
                }
            }
            case stored: {
                {
                    u32 len;
                    u32 nlen;
                    sinfl__get(&s, s.bitcnt & 7);
                    len = cast(u16, sinfl__get(&s, 16));
                    nlen = cast(u16, sinfl__get(&s, 16));
                    s.bitptr -= s.bitcnt / 8;
                    s.bitcnt = 0;
                    s.bitbuf = cast(u64, s.bitcnt);
                    if cast(u16, len) != cast(u16, ~nlen) {
                        return cast(i32, cast(i64, out - o));
                    }
                    if cast(i64, len) > cast(i64, e - s.bitptr) || !len {
                        return cast(i32, cast(i64, out - o));
                    }
                    memcpy(out, s.bitptr, cast(u64, len));
                    s.bitptr += len;
                    out += len;
                    if last != 0 {
                        return cast(i32, cast(i64, out - o));
                    }
                    state = hdr;
                }
            }
            case fixed: {
                {
                    i32 n;
                    u8[320] lens;
                    for n = 0; n <= 143; n++ {
                        lens[n] = 8;
                    }
                    for n = 144; n <= 255; n++ {
                        lens[n] = 9;
                    }
                    for n = 256; n <= 279; n++ {
                        lens[n] = 7;
                    }
                    for n = 280; n <= 287; n++ {
                        lens[n] = 8;
                    }
                    for n = 0; n < 32; n++ {
                        lens[288 + n] = 5;
                    }
                    sinfl_build(s.lits, lens, 10, 15, 288);
                    sinfl_build(s.dsts, lens + 288, 8, 15, 32);
                    state = blk;
                }
            }
            case dyn: {
                {
                    i32 n;
                    i32 i;
                    u32[128] hlens;
                    u8[19] nlens;
                    u8[320] lens;
                    sinfl_refill(&s);
                    {
                        i32 nlit = 257 + sinfl__get(&s, 5);
                        i32 ndist = 1 + sinfl__get(&s, 5);
                        i32 nlen = 4 + sinfl__get(&s, 4);
                        for n = 0; n < nlen; n++ {
                            nlens[sinfl_decompress__order[n]] = cast(u8, sinfl_get(&s, 3));
                        }
                        sinfl_build(hlens, nlens, 7, 7, 19);
                        n = 0;
                        while n < nlit + ndist {
                            i32 sym = 0;
                            sinfl_refill(&s);
                            sym = sinfl_decode(&s, hlens, 7);
                            switch sym {
                                default: {
                                    lens[n++] = cast(u8, sym);
                                }
                                case 16: {
                                    for i = 3 + sinfl_get(&s, 2); i != 0; i-- {
                                        lens[n] = lens[n - 1];
                                        n++;
                                    }
                                }
                                case 17: {
                                    for i = 3 + sinfl_get(&s, 3); i != 0; i-- {
                                        lens[n] = 0;
                                        n++;
                                    }
                                }
                                case 18: {
                                    for i = 11 + sinfl_get(&s, 7); i != 0; i-- {
                                        lens[n] = 0;
                                        n++;
                                    }
                                }
                            }
                        }
                        sinfl_build(s.lits, lens, 10, 15, nlit);
                        sinfl_build(s.dsts, lens + nlit, 8, 15, ndist);
                        state = blk;
                    }
                }
            }
            case blk: {
                {
                    while 1 != 0 {
                        i32 sym;
                        sinfl_refill(&s);
                        sym = sinfl_decode(&s, s.lits, 10);
                        if sym < 256 {
                            if out >= oe {
                                return cast(i32, cast(i64, out - o));
                            }
                            *out++ = cast(u8, sym);
                            sym = sinfl_decode(&s, s.lits, 10);
                            if sym < 256 {
                                *out++ = cast(u8, sym);
                                continue;
                            }
                        }
                        if sym == 256 {
                            if last != 0 {
                                return cast(i32, cast(i64, out - o));
                            }
                            state = hdr;
                            break;
                        }
                        if sym >= 286 {
                            return cast(i32, cast(i64, out - o));
                        }
                        sym -= 257;
                        {
                            i32 len = sinfl__get(&s, cast(i32, sinfl_decompress__lbits[sym])) + sinfl_decompress__lbase[sym];
                            i32 dsym = sinfl_decode(&s, s.dsts, 8);
                            i32 offs = sinfl__get(&s, cast(i32, sinfl_decompress__dbits[dsym])) + sinfl_decompress__dbase[dsym];
                            u8* dst = out;
                            u8* src = out - offs;
                            if offs > cast(i32, cast(i64, out - o)) {
                                return cast(i32, cast(i64, out - o));
                            }
                            out = out + len;
                            if cast(i64, oe - out) >= 3 * 8 - 3 {
                                if offs >= 8 {
                                    sinfl_copy64(&dst, &src);
                                    sinfl_copy64(&dst, &src);
                                    while true {
                                        sinfl_copy64(&dst, &src);
                                        if !(dst < out) { break; }
                                    }
                                } else if offs == 1 {
                                    u32 c = src[0];
                                    u32 hw = c << 24 | c << 16 | c << 8 | c;
                                    u64 w = cast(u64, hw) << 32 | hw;
                                    dst = sinfl_write64(dst, w);
                                    dst = sinfl_write64(dst, w);
                                    while true {
                                        dst = sinfl_write64(dst, w);
                                        if !(dst < out) { break; }
                                    }
                                } else {
                                    *dst++ = *src++;
                                    *dst++ = *src++;
                                    while true {
                                        *dst++ = *src++;
                                        if !(dst < out) { break; }
                                    }
                                }
                            } else {
                                *dst++ = *src++;
                                *dst++ = *src++;
                                while true {
                                    *dst++ = *src++;
                                    if !(dst < out) { break; }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    return cast(i32, cast(i64, out - o));
}}
i32 sinflate(void* out, i32 cap, void* in, i32 size) {
    return sinfl_decompress(cast(u8*, out), cap, cast(u8*, in), size);
}
private { u32 sinfl_adler32(u32 adler32, u8* in, i32 in_len) {
    u32 ADLER_MOD = 65521;
    u32 s1 = adler32 & 65535;
    u32 s2 = adler32 >> 16;
    u32 blk_len;
    u32 i;
    blk_len = cast(u32, in_len % 5552);
    while in_len != 0 {
        for i = 0; i + 7 < blk_len; i += 8 {
            s1 += in[0];
            s2 += s1;
            s1 += in[1];
            s2 += s1;
            s1 += in[2];
            s2 += s1;
            s1 += in[3];
            s2 += s1;
            s1 += in[4];
            s2 += s1;
            s1 += in[5];
            s2 += s1;
            s1 += in[6];
            s2 += s1;
            s1 += in[7];
            s2 += s1;
            in += 8;
        }
        for ; i < blk_len; ++i {
            s1 += *in++;
            s2 += s1;
        }
        s1 %= ADLER_MOD;
        s2 %= ADLER_MOD;
        in_len -= cast(i32, blk_len);
        blk_len = 5552;
    }
    return (s2 << 16) + s1;
}}
i32 zsinflate(void* out, i32 cap, void* mem, i32 size) {
    var in = cast(u8*, mem);
    if size >= 6 {
        u8* eob = in + size - 4;
        i32 n = sinfl_decompress(cast(u8*, out), cap, in + 2, size);
        u32 a = sinfl_adler32(1, cast(u8*, out), n);
        var h = cast(u32, cast(i32, eob[0]) << 24 | cast(i32, eob[1]) << 16 | cast(i32, eob[2]) << 8 | cast(i32, eob[3]) << 0);
        return a == h ? n : -1;
    } else {
        return -1;
    }
}
private { i32 sdefl_ilog2(i32 n) {
    if n == 0 {
        return 0;
    }
    return cast(i32, sizeof(u64)) * CHAR_BIT - 1 - __builtin_clzl(cast(u64, n));
}}
private { u32 sdefl_uload32(void* p) {
    u32 n = 0;
    memcpy(&n, p, cast(u64, sizeof(n)));
    return n;
}}
private { u32 sdefl_hash32(void* p) {
    u32 n = sdefl_uload32(p);
    return n * 2654435721 >> cast(u32, 32 - 15);
}}
private { void sdefl_put(u8** dst, sdefl* s, i32 code, i32 bitcnt) {
    s.bits |= code << s.bitcnt;
    s.bitcnt += bitcnt;
    while s.bitcnt >= 8 {
        u8* tar = *dst;
        *tar = cast(u8, s.bits & 255);
        s.bits >>= 8;
        s.bitcnt -= 8;
        *dst = *dst + 1;
    }
}}
private { void sdefl_heap_sub(u32* A, u32 len, u32 sub) {
    u32 c;
    u32 p = sub;
    u32 v = A[sub];
    while true {
        c = p << 1;
        if c <= len == 0 {
            break;
        }
        if c < len && A[c + 1] > A[c] {
            c++;
        }
        if v >= A[c] {
            break;
        }
        A[p] = A[c];
        p = c;
    }
    A[p] = v;
}}
private { void sdefl_heap_array(u32* A, u32 len) {
    u32 sub;
    for sub = len >> 1; sub >= 1; sub-- {
        sdefl_heap_sub(A, len, sub);
    }
}}
private { void sdefl_heap_sort(u32* A, u32 n) {
    A--;
    sdefl_heap_array(A, n);
    while n >= 2 {
        u32 tmp = A[n];
        A[n--] = A[1];
        A[1] = tmp;
        sdefl_heap_sub(A, n, 1);
    }
}}
private { u32 sdefl_sort_sym(u32 sym_cnt, u32* freqs, u8* lens, u32* sym_out) {
    u32[288] cnts;
    u32 cnt_num = sym_cnt + cast(u32, 3 / 4) + 3 & cast(u32, ~3);
    u32 used_sym = 0;
    u32 sym;
    u32 i;
    for sym = 0; sym < sym_cnt; sym++ {
        cnts[freqs[sym] < cnt_num - 1 ? freqs[sym] : cnt_num - 1]++;
    }
    for i = 1; i < cnt_num; i++ {
        u32 cnt = cnts[i];
        cnts[i] = used_sym;
        used_sym += cnt;
    }
    for sym = 0; sym < sym_cnt; sym++ {
        u32 freq = freqs[sym];
        if freq != 0 {
            u32 idx = freq < cnt_num - 1 ? freq : cnt_num - 1;
            sym_out[cnts[idx]++] = sym | freq << 10;
        } else {
            lens[sym] = 0;
        }
    }
    sdefl_heap_sort(sym_out + cnts[cnt_num - 2], cnts[cnt_num - 1] - cnts[cnt_num - 2]);
    return used_sym;
}}
private { void sdefl_build_tree(u32* A, u32 sym_cnt) {
    u32 i = 0;
    u32 b = 0;
    u32 e = 0;
    while true {
        u32 m;
        u32 n;
        u32 freq_shift;
        if i != sym_cnt && (b == e || A[i] >> 10 <= A[b] >> 10) {
            m = i++;
        } else {
            m = b++;
        }
        if i != sym_cnt && (b == e || A[i] >> 10 <= A[b] >> 10) {
            n = i++;
        } else {
            n = b++;
        }
        freq_shift = (A[m] & cast(u32, ~((1 << 10) - 1))) + (A[n] & cast(u32, ~((1 << 10) - 1)));
        A[m] = A[m] & cast(u32, (1 << 10) - 1) | e << 10;
        A[n] = A[n] & cast(u32, (1 << 10) - 1) | e << 10;
        A[e] = A[e] & cast(u32, (1 << 10) - 1) | freq_shift;
        if !(sym_cnt - ++e > 1) { break; }
    }
}}
private { void sdefl_gen_len_cnt(u32* A, u32 root, u32* len_cnt, u32 max_code_len) {
    i32 n;
    u32 i;
    for i = 0; i <= max_code_len; i++ {
        len_cnt[i] = 0;
    }
    len_cnt[1] = 2;
    A[root] &= cast(u32, (1 << 10) - 1);
    for n = cast(i32, root) - 1; n >= 0; n-- {
        u32 p = A[n] >> 10;
        u32 pdepth = A[p] >> 10;
        u32 depth = pdepth + 1;
        u32 len = depth;
        A[n] = A[n] & cast(u32, (1 << 10) - 1) | depth << 10;
        if len >= max_code_len {
            len = max_code_len;
            while true {
                len--;
                if !(len_cnt[len] == 0) { break; }
            }
        }
        len_cnt[len]--;
        len_cnt[len + 1] += 2;
    }
}}
private { void sdefl_gen_codes(u32* A, u8* lens, u32* len_cnt, u32 max_code_word_len, u32 sym_cnt) {
    u32 i;
    u32 sym;
    u32 len;
    u32[16] nxt;
    {
        i = 0;
        for len = max_code_word_len; len >= 1; len-- {
            u32 cnt = len_cnt[len];
            while cnt-- != 0 {
                lens[A[i++] & cast(u32, (1 << 10) - 1)] = cast(u8, len);
            }
        }
    }
    nxt[1] = 0;
    nxt[0] = nxt[1];
    for len = 2; len <= max_code_word_len; len++ {
        nxt[len] = nxt[len - 1] + len_cnt[len - 1] << 1;
    }
    for sym = 0; sym < sym_cnt; sym++ {
        A[sym] = nxt[lens[sym]]++;
    }
}}
private { u32 sdefl_rev(u32 c, u8 n) {
    c = (c & 21845) << 1 | (c & 43690) >> 1;
    c = (c & 13107) << 2 | (c & 52428) >> 2;
    c = (c & 3855) << 4 | (c & 61680) >> 4;
    c = (c & 255) << 8 | (c & 65280) >> 8;
    return c >> 16 - n;
}}
private { void sdefl_huff(u8* lens, u32* codes, u32* freqs, u32 num_syms, u32 max_code_len) {
    u32 c;
    u32* A = codes;
    u32[16] len_cnt;
    u32 used_syms = sdefl_sort_sym(num_syms, freqs, lens, A);
    if used_syms == 0 {
        return;
    }
    if used_syms == 1 {
        u32 s = A[0] & cast(u32, (1 << 10) - 1);
        u32 i = s != 0 ? s : 1;
        codes[0] = 0;
        lens[0] = 1;
        codes[i] = 1;
        lens[i] = 1;
        return;
    }
    sdefl_build_tree(A, used_syms);
    sdefl_gen_len_cnt(A, used_syms - 2, len_cnt, max_code_len);
    sdefl_gen_codes(A, lens, len_cnt, max_code_len, num_syms);
    for c = 0; c < num_syms; c++ {
        codes[c] = sdefl_rev(codes[c], lens[c]);
    }
}}
private { void sdefl_precode(sdefl_symcnt* cnt, u32* freqs, u32* items, u8* litlen, u8* offlen) {
    u32* at = items;
    u32 run_start = 0;
    u32 total = 0;
    u8[320] lens;
    for cnt.lit = 288; cnt.lit > 257; cnt.lit-- {
        if litlen[cnt.lit - 1] != 0 {
            break;
        }
    }
    for cnt.off = 32; cnt.off > 1; cnt.off-- {
        if offlen[cnt.off - 1] != 0 {
            break;
        }
    }
    total = cast(u32, cnt.lit + cnt.off);
    memcpy(lens, litlen, cast(u64, sizeof(u8)) * cast(u64, cnt.lit));
    memcpy(lens + cnt.lit, offlen, cast(u64, sizeof(u8)) * cast(u64, cnt.off));
    while true {
        u32 len = lens[run_start];
        u32 run_end = run_start;
        while true {
            run_end++;
            if !(run_end != total && len == lens[run_end]) { break; }
        }
        if len == 0 {
            while run_end - run_start >= 11 {
                u32 n = run_end - run_start - 11;
                u32 xbits = n < 127 ? n : 127;
                freqs[18]++;
                *at++ = 18 | xbits << 5;
                run_start += 11 + xbits;
            }
            if run_end - run_start >= 3 {
                u32 n = run_end - run_start - 3;
                u32 xbits = n < 7 ? n : 7;
                freqs[17]++;
                *at++ = 17 | xbits << 5;
                run_start += 3 + xbits;
            }
        } else if run_end - run_start >= 4 {
            freqs[len]++;
            *at++ = len;
            run_start++;
            while true {
                u32 xbits = run_end - run_start - 3;
                xbits = xbits < 3 ? xbits : 3;
                *at++ = 16 | xbits << 5;
                run_start += 3 + xbits;
                freqs[16]++;
                if !(run_end - run_start >= 3) { break; }
            }
        }
        while run_start != run_end {
            freqs[len]++;
            *at++ = len;
            run_start++;
        }
        if !(run_start != total) { break; }
    }
    cnt.items = cast(i32, cast(i64, at - items));
}}
private { void sdefl_match_codes(sdefl_match_codest* cod, i32 dist, i32 len) {
    assert(len <= 258);
    assert(dist <= 32768);
    cod.ls = cast(i32, sdefl_match_codes__lslot[len]);
    cod.lc = 257 + cod.ls;
    assert(cod.lc <= 285);
    cod.dx = sdefl_ilog2(1 << sdefl_ilog2(dist - 1) + 1 >> 2);
    cod.dc = cod.dx != 0 ? (cod.dx + 1 << 1) + (dist > sdefl_match_codes__dxmax[cod.dx]) : dist - 1;
}}
private { sdefl_blk_type sdefl_blk_type_v(sdefl* s, i32 blk_len, i32 pre_item_len, u32* pre_freq, u8* pre_len) {
    i32 dyn_cost = 0;
    i32 fix_cost = 0;
    i32 sym = 0;
    dyn_cost += 5 + 5 + 4 + 3 * pre_item_len;
    for sym = 0; sym < 19; sym++ {
        dyn_cost += cast(i32, pre_freq[sym] * (sdefl_blk_type_v__x_pre_bits[sym] + pre_len[sym]));
    }
    for sym = 0; sym < 256; sym++ {
        dyn_cost += cast(i32, s.freq.lit[sym] * s.cod.len.lit[sym]);
    }
    dyn_cost += cast(i32, s.cod.len.lit[256]);
    for sym = 257; sym < 286; sym++ {
        dyn_cost += cast(i32, s.freq.lit[sym] * (sdefl_blk_type_v__x_len_bits[sym - 257] + s.cod.len.lit[sym]));
    }
    for sym = 0; sym < 30; sym++ {
        dyn_cost += cast(i32, s.freq.off[sym] * (sdefl_blk_type_v__x_off_bits[sym] + s.cod.len.off[sym]));
    }
    fix_cost += 8 * (5 * ((blk_len + (65535 - 1)) / 65535) + blk_len + 1 + 2);
    return dyn_cost < fix_cost ? SDEFL_BLK_DYN : SDEFL_BLK_UCOMPR;
}}
private { void sdefl_put16(u8** dst, u16 x) {
    u8* val = *dst;
    val[0] = cast(u8, x & 255);
    val[1] = cast(u8, cast(i32, x) >> 8);
    *dst = val + 2;
}}
private { void sdefl_match_v(u8** dst, sdefl* s, i32 dist, i32 len) {
    sdefl_match_codest cod;
    sdefl_match_codes(&cod, dist, len);
    sdefl_put(dst, s, cast(i32, s.cod.word.lit[cod.lc]), cast(i32, s.cod.len.lit[cod.lc]));
    sdefl_put(dst, s, len - sdefl_match_v__lmin[cod.ls], sdefl_match_v__lxn[cod.ls]);
    sdefl_put(dst, s, cast(i32, s.cod.word.off[cod.dc]), cast(i32, s.cod.len.off[cod.dc]));
    sdefl_put(dst, s, dist - sdefl_match_v__dmin[cod.dc], cod.dx);
}}
private { void sdefl_flush(u8** dst, sdefl* s, i32 is_last, u8* in, i32 blk_begin, i32 blk_end) {
    i32 blk_len = blk_end - blk_begin;
    i32 j;
    i32 i = 0;
    i32 item_cnt = 0;
    sdefl_symcnt symcnt;
    u32[19] codes;
    u8[19] lens;
    u32[19] freqs;
    u32[320] items;
    s.freq.lit[256]++;
    sdefl_huff(s.cod.len.lit, s.cod.word.lit, s.freq.lit, 288, 14);
    sdefl_huff(s.cod.len.off, s.cod.word.off, s.freq.off, 32, 15);
    sdefl_precode(&symcnt, freqs, items, s.cod.len.lit, s.cod.len.off);
    sdefl_huff(lens, codes, freqs, 19, 7);
    for item_cnt = 19; item_cnt > 4; item_cnt-- {
        if lens[sdefl_flush__perm[item_cnt - 1]] != 0 {
            break;
        }
    }
    switch sdefl_blk_type_v(s, blk_len, item_cnt, freqs, lens) {
        case SDEFL_BLK_UCOMPR: {
            {
                i32 n = (blk_len + (65535 - 1)) / 65535;
                for i = 0; i < n; ++i {
                    i32 fin = is_last && i + 1 == n;
                    i32 amount = blk_len < 65535 ? blk_len : 65535;
                    sdefl_put(dst, s, !!fin, 1);
                    sdefl_put(dst, s, 0, 2);
                    if s.bitcnt != 0 {
                        sdefl_put(dst, s, 0, 8 - s.bitcnt);
                    }
                    assert(s.bitcnt == 0);
                    sdefl_put16(dst, cast(u16, amount));
                    sdefl_put16(dst, ~cast(u16, amount));
                    memcpy(*dst, in + blk_begin + i * 65535, cast(u64, amount));
                    *dst = *dst + amount;
                    blk_len -= amount;
                }
            }
        }
        case SDEFL_BLK_DYN: {
            {
                sdefl_put(dst, s, !!is_last, 1);
                sdefl_put(dst, s, 2, 2);
                sdefl_put(dst, s, symcnt.lit - 257, 5);
                sdefl_put(dst, s, symcnt.off - 1, 5);
                sdefl_put(dst, s, item_cnt - 4, 4);
                for i = 0; i < item_cnt; ++i {
                    sdefl_put(dst, s, cast(i32, lens[sdefl_flush__perm[i]]), 3);
                }
                for i = 0; i < symcnt.items; ++i {
                    u32 sym = items[i] & 31;
                    sdefl_put(dst, s, cast(i32, codes[sym]), cast(i32, lens[sym]));
                    if sym < 16 {
                        continue;
                    }
                    if sym == 16 {
                        sdefl_put(dst, s, cast(i32, items[i] >> 5), 2);
                    } else if sym == 17 {
                        sdefl_put(dst, s, cast(i32, items[i] >> 5), 3);
                    } else {
                        sdefl_put(dst, s, cast(i32, items[i] >> 5), 7);
                    }
                }
                for i = 0; i < s.seq_cnt; ++i {
                    if s.seq[i].off >= 0 {
                        for j = 0; j < s.seq[i].len; ++j {
                            var c = cast(i32, in[s.seq[i].off + j]);
                            sdefl_put(dst, s, cast(i32, s.cod.word.lit[c]), cast(i32, s.cod.len.lit[c]));
                        }
                    } else {
                        sdefl_match_v(dst, s, -s.seq[i].off, s.seq[i].len);
                    }
                }
                sdefl_put(dst, s, cast(i32, s.cod.word.lit[256]), cast(i32, s.cod.len.lit[256]));
            }
        }
    }
    memset(&s.freq, 0, cast(u64, sizeof(s.freq)));
    s.seq_cnt = 0;
}}
private { void sdefl_seq(sdefl* s, i32 off, i32 len) {
    assert(s.seq_cnt + 2 < (256 * 1024 + 2) / 3);
    s.seq[s.seq_cnt].off = off;
    s.seq[s.seq_cnt].len = len;
    s.seq_cnt++;
}}
private { void sdefl_reg_match(sdefl* s, i32 off, i32 len) {
    sdefl_match_codest cod;
    sdefl_match_codes(&cod, off, len);
    assert(cod.lc < 288);
    assert(cod.dc < 32);
    s.freq.lit[cod.lc]++;
    s.freq.off[cod.dc]++;
}}
private { void sdefl_fnd(sdefl_match* m, sdefl* s, i32 chain_len, i32 max_match, u8* in, i32 p, i32 e) {
    i32 i = s.tbl[sdefl_hash32(in + p)];
    i32 limit = p - (1 << 15) < -1 ? -1 : p - (1 << 15);
    assert(p < e);
    assert(p + max_match <= e);
    while i > limit {
        assert(i + m.len < e);
        assert(p + m.len < e);
        assert(i + 4 < e);
        assert(p + 4 < e);
        if in[i + m.len] == in[p + m.len] && sdefl_uload32(&in[i]) == sdefl_uload32(&in[p]) {
            i32 n = 4;
            while n < max_match && in[i + n] == in[p + n] {
                assert(i + n < e);
                assert(p + n < e);
                n++;
            }
            if n > m.len {
                m.len = n;
                m.off = p - i;
                if n == max_match {
                    break;
                }
            }
        }
        if --chain_len == 0 {
            break;
        }
        i = s.prv[i & (1 << 15) - 1];
    }
}}
private { i32 sdefl_compr(sdefl* s, u8* out, u8* in, i32 in_len, i32 lvl) {
    u8* q = out;
    i32 max_chain = lvl < 8 ? 1 << lvl + 1 : 1 << 13;
    i32 n;
    i32 i = 0;
    i32 litlen = 0;
    for n = 0; n < 1 << 15; ++n {
        s.tbl[n] = -1;
    }
    while true {
        i32 blk_begin = i;
        i32 blk_end = i + 256 * 1024 < in_len ? i + 256 * 1024 : in_len;
        while i < blk_end {
            sdefl_match m;
            i32 left = blk_end - i;
            i32 max_match = left > 258 ? 258 : left;
            i32 nice_match = cast(i32, sdefl_compr__pref[lvl]) < max_match ? cast(i32, sdefl_compr__pref[lvl]) : max_match;
            i32 run = 1;
            i32 inc = 1;
            i32 run_inc = 0;
            if max_match > 4 {
                sdefl_fnd(&m, s, max_chain, max_match, in, i, in_len);
            }
            if lvl >= 5 && m.len >= 4 && m.len + 1 < nice_match {
                sdefl_match m2;
                sdefl_fnd(&m2, s, max_chain, m.len + 1, in, i + 1, in_len);
                m.len = m2.len > m.len ? 0 : m.len;
            }
            if m.len >= 4 {
                if litlen != 0 {
                    sdefl_seq(s, i - litlen, litlen);
                    litlen = 0;
                }
                sdefl_seq(s, -m.off, m.len);
                sdefl_reg_match(s, m.off, m.len);
                if lvl < 2 && m.len >= nice_match {
                    inc = m.len;
                } else {
                    run = m.len;
                }
            } else {
                s.freq.lit[in[i]]++;
                litlen++;
            }
            run_inc = run * inc;
            if in_len - (i + run_inc) > 4 {
                while run-- > 0 {
                    u32 h = sdefl_hash32(&in[i]);
                    s.prv[i & (1 << 15) - 1] = s.tbl[h];
                    s.tbl[h] = i;
                    i += inc;
                    assert(i <= blk_end);
                }
            } else {
                i += run_inc;
                assert(i <= blk_end);
            }
        }
        if litlen != 0 {
            sdefl_seq(s, i - litlen, litlen);
            litlen = 0;
        }
        sdefl_flush(&q, s, blk_end == in_len, in, blk_begin, blk_end);
        if !(i < in_len) { break; }
    }
    if s.bitcnt != 0 {
        sdefl_put(&q, s, 0, 8 - s.bitcnt);
    }
    assert(s.bitcnt == 0);
    return cast(i32, cast(i64, q - out));
}}
i32 sdeflate(sdefl* s, void* out, void* in, i32 n, i32 lvl) {
    s.bitcnt = 0;
    s.bits = s.bitcnt;
    return sdefl_compr(s, cast(u8*, out), cast(u8*, in), n, lvl);
}
private { u32 sdefl_adler32(u32 adler32, u8* in, i32 in_len) {
    u32 ADLER_MOD = 65521;
    u32 s1 = adler32 & 65535;
    u32 s2 = adler32 >> 16;
    u32 blk_len;
    u32 i;
    blk_len = cast(u32, in_len % 5552);
    while in_len != 0 {
        for i = 0; i + 7 < blk_len; i += 8 {
            s1 += in[0];
            s2 += s1;
            s1 += in[1];
            s2 += s1;
            s1 += in[2];
            s2 += s1;
            s1 += in[3];
            s2 += s1;
            s1 += in[4];
            s2 += s1;
            s1 += in[5];
            s2 += s1;
            s1 += in[6];
            s2 += s1;
            s1 += in[7];
            s2 += s1;
            in += 8;
        }
        for ; i < blk_len; ++i {
            s1 += *in++;
            s2 += s1;
        }
        s1 %= ADLER_MOD;
        s2 %= ADLER_MOD;
        in_len -= cast(i32, blk_len);
        blk_len = 5552;
    }
    return (s2 << 16) + s1;
}}
i32 zsdeflate(sdefl* s, void* out, void* in, i32 n, i32 lvl) {
    i32 p = 0;
    u32 a = 0;
    var q = cast(u8*, out);
    s.bitcnt = 0;
    s.bits = s.bitcnt;
    sdefl_put(&q, s, 120, 8);
    sdefl_put(&q, s, 1, 8);
    q += sdefl_compr(s, q, cast(u8*, in), n, lvl);
    a = sdefl_adler32(1, cast(u8*, in), n);
    for p = 0; p < 4; ++p {
        sdefl_put(&q, s, cast(i32, a >> 24 & 255), 8);
        a <<= 8;
    }
    return cast(i32, cast(i64, q - cast(u8*, out)));
}
i32 sdefl_bound(i32 len) {
    i32 max_blocks = 1 + (len + (65535 - 1)) / 65535;
    i32 bound = 5 * max_blocks + len + 1 + 4 + 8;
    return bound;
}
// Deflate (RFC 1951) compressor
/**********************************************************************************************
*
*   rprand v1.1 - A simple and easy-to-use pseudo-random numbers generator (PRNG)
*
*   FEATURES:
*       - Pseudo-random values generation, 32 bits: [0..4294967295]
*       - Sequence generation avoiding duplicate values
*       - Using standard and proven prng algorithm (Xoshiro128**)
*       - State initialized with a separate generator (SplitMix64)
*
*   LIMITATIONS:
*       - No negative numbers, up to the user to manage them
*
*   POSSIBLE IMPROVEMENTS:
*       - Support 64 bits generation
*
*   ADDITIONAL NOTES:
*     This library implements two pseudo-random number generation algorithms:
*
*         - Xoshiro128** : https://prng.di.unimi.it/xoshiro128starstar.c
*         - SplitMix64   : https://prng.di.unimi.it/splitmix64.c
*
*     SplitMix64 is used to initialize the Xoshiro128** state, from a provided seed
*
*     It's suggested to use SplitMix64 to initialize the state of the generators starting from
*     a 64-bit seed, as research has shown that initialization must be performed with a generator
*     radically different in nature from the one initialized to avoid correlation on similar seeds.
*
*   CONFIGURATION:
*       #define RPRAND_IMPLEMENTATION
*           Generates the implementation of the library into the included file.
*           If not defined, the library is in header only mode and can be included in other headers
*           or source files without problems. But only ONE file should hold the implementation.
*
*   DEPENDENCIES: none
*
*   VERSIONS HISTORY:
*       1.0 (01-Jun-2023) First version
*
*
*   LICENSE: zlib/libpng
*
*   Copyright (c) 2023 Ramon Santamaria (@raysan5)
*
*   This software is provided "as-is", without any express or implied warranty. In no event
*   will the authors be held liable for any damages arising from the use of this software.
*
*   Permission is granted to anyone to use this software for any purpose, including commercial
*   applications, and to alter it and redistribute it freely, subject to the following restrictions:
*
*     1. The origin of this software must not be misrepresented; you must not claim that you
*     wrote the original software. If you use this software in a product, an acknowledgment
*     in the product documentation would be appreciated but is not required.
*
*     2. Altered source versions must be plainly marked as such, and must not be misrepresented
*     as being the original software.
*
*     3. This notice may not be removed or altered from any source distribution.
*
**********************************************************************************************/
