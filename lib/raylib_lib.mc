// OpenGL extension functions loader signature (same as GLADloadproc)
struct rlglData {
    rlRenderBatch* currentBatch;
    rlRenderBatch defaultBatch;
    rlglLoadProc loader;
    struct {
        i32 vertexCounter;
        f32 texcoordx;
        f32 texcoordy;
        f32 normalx;
        f32 normaly;
        f32 normalz;
        u8 colorr;
        u8 colorg;
        u8 colorb;
        u8 colora;
        i32 currentMatrixMode;
        Matrix* currentMatrix;
        Matrix modelview;
        Matrix projection;
        Matrix transform;
        bool transformRequired;
        Matrix[32] stack;
        i32 stackCounter;
        u32 currentTextureId;
        u32 defaultTextureId;
        u32[4] activeTextureId;
        u32 defaultVShaderId;
        u32 defaultFShaderId;
        u32 defaultShaderId;
        i32* defaultShaderLocs;
        u32 currentShaderId;
        i32* currentShaderLocs;
        bool stereoRender;
        Matrix[2] projectionStereo;
        Matrix[2] viewOffsetStereo;
        i32 currentBlendMode;
        i32 glBlendSrcFactor;
        i32 glBlendDstFactor;
        i32 glBlendEquation;
        i32 glBlendSrcFactorRGB;
        i32 glBlendDestFactorRGB;
        i32 glBlendSrcFactorAlpha;
        i32 glBlendDestFactorAlpha;
        i32 glBlendEquationRGB;
        i32 glBlendEquationAlpha;
        bool glCustomBlendModeModified;
        i32 framebufferWidth;
        i32 framebufferHeight;
    } State;
    struct {
        bool vao;
        bool instancing;
        bool texNPOT;
        bool texDepth;
        bool texDepthWebGL;
        bool texFloat32;
        bool texFloat16;
        bool texCompDXT;
        bool texCompETC1;
        bool texCompETC2;
        bool texCompPVRT;
        bool texCompASTC;
        bool texMirrorClamp;
        bool texAnisoFilter;
        bool computeShader;
        bool ssbo;
        f32 maxAnisotropyLevel;
        i32 maxDepthBits;
    } ExtSupported;
}

