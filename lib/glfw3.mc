// Stubs — not used by raylib.
i32 glfwGetPlatform() { return 0; }
GLFWglproc glfwGetProcAddress(u8* procname) { return cast(GLFWglproc, null); }
void glfwInitAllocator(GLFWallocator* allocator) { }
